<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x11"
    orientation="0"
    id="@+id/widget_4x1_LinearLayout"
    layout_width="-1"
    layout_height="-1">
    <LinearLayout
        orientation="0"
        layout_width="-2"
        layout_height="90dp">
        <LinearLayout
            layout_gravity="0x10"
            orientation="0"
            layout_width="-2"
            layout_height="-2">
            <TextView
                id="@+id/widget4x1_steps"
                layout_width="-2"
                layout_height="-2"
                text="@string/IDS_plugindameon_hw_phonecounter_widget_defualt_value"
                singleLine="true"
                style="@style/hw_widget_4x1_text_prefix_style_little_land"/>
            <TextView
                id="@+id/widget4x1_steps_unit"
                layout_width="-2"
                layout_height="-2"
                text="@string/IDS_plugindameon_hw_phonecounter_widget_step_unit"
                singleLine="true"
                style="@style/hw_widget_4x1_text_unit_style_land"/>
        </LinearLayout>
    </LinearLayout>
    <ImageView
        id="@+id/split"
        layout_width="4dp"
        layout_height="-1"
        src="@drawable/_2131428910_res_0x7f0b062e"
        scaleType="1"
        layout_marginStart="15dp"
        layout_marginEnd="15dp"/>
    <LinearLayout
        orientation="0"
        layout_width="-2"
        layout_height="90dp">
        <LinearLayout
            layout_gravity="0x10"
            orientation="1"
            layout_width="-1"
            layout_height="-2">
            <LinearLayout
                orientation="1"
                layout_width="-2"
                layout_height="-2">
                <TextView
                    id="@+id/widget4x1_stepGoal_prefix"
                    layout_width="-2"
                    layout_height="-2"
                    text="@string/IDS_plugindameon_hw_phonecounter_widget_goal_prefix"
                    singleLine="true"
                    style="@style/hw_widget_4x1_text_subPrefix_style_land"/>
                <TextView
                    id="@+id/widget4x1_stepGoal"
                    layout_width="-2"
                    layout_height="-2"
                    text="@string/IDS_plugindameon_hw_phonecounter_widget_defualt_value"
                    singleLine="true"
                    style="@style/hw_widget_4x1_text_unit_style_land"/>
            </LinearLayout>
            <LinearLayout
                orientation="1"
                layout_width="-2"
                layout_height="-2">
                <TextView
                    id="@+id/widget4x1_kcal_prefix"
                    layout_width="-2"
                    layout_height="-2"
                    text="@string/IDS_plugindameon_hw_phonecounter_widget_kalo_prefix"
                    singleLine="true"
                    style="@style/hw_widget_4x1_text_subPrefix_style_land"/>
                <LinearLayout
                    orientation="0"
                    layout_width="-2"
                    layout_height="-2">
                    <TextView
                        id="@+id/widget4x1_kcal"
                        layout_width="-2"
                        layout_height="-2"
                        text="@string/IDS_plugindameon_hw_phonecounter_widget_defualt_value"
                        singleLine="true"
                        style="@style/hw_widget_4x1_text_unit_style_land"/>
                    <TextView
                        id="@+id/widget4x1_kcal_unit"
                        layout_width="-2"
                        layout_height="-2"
                        text="@string/IDS_plugindameon_hw_phonecounter_widget_kalo_unit"
                        singleLine="true"
                        layout_marginStart="4dp"
                        style="@style/hw_widget_4x1_text_subPrefix_style_land"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
