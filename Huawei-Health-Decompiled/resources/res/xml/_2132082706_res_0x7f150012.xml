<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        icon="@drawable/ic_btn_run"
        enabled="true"
        shortcutId="SC_EXERCISE"
        shortcutShortLabel="@string/IDS_hw_shortcuts_start_exercise"
        shortcutLongLabel="@string/IDS_hw_shortcuts_start_exercise"
        shortcutDisabledMessage="@string/IDS_hw_shortcuts_disable">
