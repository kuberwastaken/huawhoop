<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-2"
    layout_height="-2"
    layout_marginBottom="@dimen/_2131362797_res_0x7f0a03ed">
    <ImageView
        id="@+id/tb_my_user_icon"
        layout_width="@dimen/_2131362804_res_0x7f0a03f4"
        layout_height="@dimen/_2131362804_res_0x7f0a03f4"
        src="@drawable/feedback_sdk_me_head_icon_def"
        layout_marginStart="@dimen/_2131362815_res_0x7f0a03ff"
        layout_alignParentEnd="true"/>
    <RelativeLayout
        id="@+id/rl_video_frame"
        background="@drawable/feedback_sdk_bg_question_from"
        visibility="2"
        layout_width="90dp"
        layout_height="90dp"
        layout_toStartOf="@+id/tb_my_user_icon">
        <ImageView
            id="@+id/video_list"
            layout_width="32dp"
            layout_height="32dp"
            layout_marginTop="20dp"
            layout_marginBottom="9dp"
            src="@drawable/feedback_icon_video"
            layout_centerInParent="true"/>
    </RelativeLayout>
    <ImageView
        id="@+id/img_video_failed"
        visibility="2"
        layout_width="@dimen/_2131362797_res_0x7f0a03ed"
        layout_height="@dimen/_2131362797_res_0x7f0a03ed"
        src="@drawable/feedback_icon_notice"
        layout_centerVertical="true"
        layout_marginEnd="@dimen/_2131362813_res_0x7f0a03fd"
        layout_toStartOf="@+id/rl_video_frame"/>
    <RelativeLayout
        id="@+id/rl_video_progress"
        background="@drawable/feedback_sdk_bg_question_from"
        visibility="2"
        layout_width="90dp"
        layout_height="90dp"
        layout_toStartOf="@+id/tb_my_user_icon">
        <ProgressBar
            layout_width="-2"
            layout_height="-2"
            layout_centerInParent="true"/>
    </RelativeLayout>
    <ImageView
        id="@+id/video_frame"
        visibility="2"
        layout_width="90dp"
        layout_height="90dp"
        layout_toStartOf="@+id/tb_my_user_icon"/>
</RelativeLayout>
