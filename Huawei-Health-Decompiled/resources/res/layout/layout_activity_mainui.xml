<?xml version="1.0" encoding="utf-8"?>
<com.huawei.ui.commonui.view.HealthRelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/hw_health_main_layout"
    layout_width="-1"
    layout_height="-1">
    <SurfaceView
        layout_width="0dp"
        layout_height="0dp"/>
    <com.huawei.ui.commonui.viewpager.HealthViewPager
        id="@+id/hw_health_main_viewpager"
        layout_width="-1"
        layout_height="-2"
        layout_above="@+id/hw_main_tabs_layout"
        importantForAccessibility="2"/>
    <LinearLayout
        orientation="1"
        id="@+id/hw_main_tabs_layout"
        clipChildren="false"
        layout_width="-1"
        layout_height="-2"
        layout_alignParentBottom="true">
        <FrameLayout
            id="@+id/extend_pic_padding"
            background="@color/_2131296984_res_0x7f0902d8"
            visibility="2"
            layout_width="-1"
            layout_height="4dp"/>
        <com.huawei.ui.commonui.scrollview.HealthBottomView
            id="@+id/hw_main_tabs"
            layout_width="-1"
            layout_height="-2"
            layout_alignParentBottom="true"
            NOT_FOUND_0xb="true"
            NOT_FOUND_0xc="@drawable/healthbottomview_item_background_selector"
            NOT_FOUND_0xd="@color/_2131299182_res_0x7f090b6e"
            style="@style/Health.CommonUI.HealthBottomView"/>
    </LinearLayout>
    <ViewStub
        id="@+id/viewstub_mainui_update_guide"
        layout="@layout/layout_activity_mainui_update_guide"
        layout_width="-1"
        layout_height="-1"/>
    <ViewStub
        id="@+id/viewstub_mainui_startpage"
        layout="@layout/layout_activity_mainui_startpage"
        layout_width="-1"
        layout_height="-1"/>
    <ViewStub
        id="@+id/viewstub_mainui_privacy_startpage"
        layout="@layout/emui_privacy_statement_layout"
        layout_width="-1"
        layout_height="-1"/>
    <ViewStub
        id="@+id/viewstub_mainui_privacy_beta_user_agreement"
        layout="@layout/emui_privacy_beta_user_agreement_layout"
        layout_width="-1"
        layout_height="-1"/>
    <ViewStub
        id="@+id/viewstub_mainui_privacy_beta_user_agreement_half_screen"
        layout="@layout/emui_privacy_beta_user_agreement_half_screen_layout"
        layout_width="-1"
        layout_height="-1"/>
    <ViewStub
        id="@+id/viewstub_mainui_privacy_startpage_half_screen"
        layout="@layout/emui_privacy_statement_half_screen"
        layout_width="-1"
        layout_height="-1"/>
    <ViewStub
        id="@+id/viewstub_mainui_privacy_hong_kong_startpage"
        layout="@layout/emui_privacy_statement_hong_kong_layout"
        layout_width="-1"
        layout_height="-1"/>
    <ViewStub
        id="@+id/viewstub_mainui_privacy_hong_kong_half_screen"
        layout="@layout/emui_privacy_statement_hong_kong_half_screen"
        layout_width="-1"
        layout_height="-1"/>
    <ViewStub
        id="@+id/viewstub_mainui_privacy_startpage_overseas"
        layout="@layout/emui_privacy_statement_overseas_layout"
        layout_width="-1"
        layout_height="-1"/>
    <ViewStub
        id="@+id/viewstub_mainui_privacy_overseas_half_screen"
        layout="@layout/emui_privacy_statement_overseas_half_screen"
        layout_width="-1"
        layout_height="-1"/>
    <ViewStub
        id="@+id/viewstub_hi_ad_splash"
        layout="@layout/activity_hi_ad_splash"
        layout_width="-1"
        layout_height="-1"/>
    <LinearLayout
        orientation="1"
        id="@+id/member_guide_view"
        layout_width="-1"
        layout_height="-1"/>
</com.huawei.ui.commonui.view.HealthRelativeLayout>
