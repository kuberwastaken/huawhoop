<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_gravity="0x10"
    orientation="1"
    layout_width="-1"
    layout_height="-2"
    baselineAligned="false">
    <com.huawei.ui.commonui.healthtextview.HealthTextView
        layout_gravity="0x10"
        id="@+id/textView_content"
        layout_width="-2"
        layout_height="-2"
        lineSpacingMultiplier="1.1"
        paddingStart="@dimen/_2131362493_res_0x7f0a02bd"
        paddingEnd="@dimen/_2131362493_res_0x7f0a02bd"
        style="@style/CustomDialog_message"/>
    <RelativeLayout
        id="@+id/relativelayout_log_exclude_capture"
        layout_width="-1"
        layout_height="@dimen/_2131362377_res_0x7f0a0249">
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            text="@string/IDS_device_exclude_capture"
            layout_centerVertical="true"
            style="@style/list_text_title_primary"/>
        <com.huawei.ui.commonui.radiobutton.HealthRadioButton
            id="@+id/radiobutton_log_exclude_capture"
            focusable="false"
            clickable="false"
            layout_width="-2"
            layout_height="-2"
            layout_centerVertical="true"
            layout_alignParentEnd="true"
            style="@style/health_radio_button_style"/>
    </RelativeLayout>
    <RelativeLayout
        id="@+id/relativelayout_log_include_capture"
        layout_width="-1"
        layout_height="@dimen/_2131362377_res_0x7f0a0249">
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            text="@string/IDS_device_include_capture"
            layout_centerVertical="true"
            style="@style/list_text_title_primary"/>
        <com.huawei.ui.commonui.radiobutton.HealthRadioButton
            id="@+id/radiobutton_log_include_capture"
            focusable="false"
            clickable="false"
            layout_width="-2"
            layout_height="-2"
            layout_centerVertical="true"
            layout_alignParentEnd="true"
            style="@style/health_radio_button_style"/>
    </RelativeLayout>
    <com.huawei.ui.commonui.healthtextview.HealthTextView
        text="@string/IDS_device_extra_tips"
        layout_centerVertical="true"
        style="@style/list_text_title_second"/>
</LinearLayout>
