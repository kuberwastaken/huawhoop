<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    background="@android:color/transparent"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        gravity="0x50"
        orientation="0"
        layout_width="-1"
        layout_height="-2"
        layout_marginHorizontal="16dp">
        <LinearLayout
            layout_gravity="0x50"
            layout_width="0dp"
            layout_height="-2"
            layout_weight="1">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365484_res_0x7f0a0e6c"
                textColor="@color/_2131299852_res_0x7f090e0c"
                id="@+id/title"
                layout_width="-2"
                layout_height="-2"
                fontFamily="@string/_2130852834_res_0x7f023be2"/>
            <ImageView
                id="@+id/title_icon"
                visibility="2"
                layout_width="@dimen/_2131364619_res_0x7f0a0b0b"
                layout_height="@dimen/_2131364619_res_0x7f0a0b0b"
                src="@drawable/_2131430524_res_0x7f0b0c7c"/>
        </LinearLayout>
        <View
            layout_width="0dp"
            layout_height="-1"
            layout_weight="0.1"/>
        <RelativeLayout
            gravity="0x50"
            layout_gravity="0x50"
            layout_width="-2"
            layout_height="-2">
            <ImageView
                id="@+id/remind_arrow"
                layout_width="-2"
                layout_height="-2"
                baselineAlignBottom="true"
                layout_alignBaseline="@+id/value"
                layout_alignParentStart="true"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="28dp"
                textColor="@color/_2131299847_res_0x7f090e07"
                id="@+id/value"
                layout_width="-2"
                layout_height="-2"
                text="0"
                fontFamily="@string/_2130852833_res_0x7f023be1"
                layout_marginStart="4dp"
                layout_toEndOf="@+id/remind_arrow"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="11dp"
                textColor="@color/_2131299847_res_0x7f090e07"
                ellipsize="0"
                id="@+id/unit"
                layout_width="-2"
                layout_height="-2"
                maxLines="10"
                maxEms="6"
                layout_alignBaseline="@+id/value"
                inputType="0x20001"
                fontFamily="@string/_2130852834_res_0x7f023be2"
                layout_marginStart="4dp"
                layout_toEndOf="@+id/value"/>
        </RelativeLayout>
    </LinearLayout>
    <com.huawei.ui.commonui.dynamicchart.DynamicChart
        id="@+id/dynamic_chart"
        layout_width="-1"
        layout_height="-1"/>
</LinearLayout>
