<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:setting="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    layout_height="-1">
    <ImageView
        id="@+id/sleep_course_background_image"
        layout_width="-1"
        layout_height="-1"
        scaleType="1"/>
    <com.huawei.ui.commonui.scrollview.HealthScrollView
        id="@+id/series_course_scroll_view"
        scrollbars="0x0"
        layout_width="-1"
        layout_height="-1"
        NOT_FOUND_0x12="true"
        NOT_FOUND_0x13="true">
        <LinearLayout
            orientation="1"
            layout_width="-2"
            layout_height="-2">
            <com.huawei.ui.commonui.titlebar.CustomTitleBar
                id="@+id/sleep_popular_courses_title_bar"
                layout_width="-1"
                layout_height="-2"
                NOT_FOUND_0x11="2"
                NOT_FOUND_0x14="false"/>
            <LinearLayout
                layout_gravity="0x1"
                orientation="1"
                id="@+id/popular_courses_top_layout"
                layout_width="-1"
                layout_height="-2">
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    textSize="@dimen/_2131363033_res_0x7f0a04d9"
                    textColor="@color/_2131299847_res_0x7f090e07"
                    id="@+id/popular_courses_text"
                    visibility="0"
                    layout_width="-1"
                    layout_height="-2"
                    fontFamily="@string/_2130852833_res_0x7f023be1"
                    layout_marginStart="@dimen/_2131363021_res_0x7f0a04cd"
                    layout_marginEnd="@dimen/_2131363021_res_0x7f0a04cd"/>
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    textSize="@dimen/_2131362955_res_0x7f0a048b"
                    textColor="@color/_2131299847_res_0x7f090e07"
                    id="@+id/popular_courses_sub_text"
                    visibility="0"
                    layout_width="-1"
                    layout_height="-2"
                    layout_marginTop="@dimen/_2131363051_res_0x7f0a04eb"
                    alpha="@dimen/_2131365229_res_0x7f0a0d6d"
                    fontFamily="@string/_2130852834_res_0x7f023be2"
                    layout_marginStart="@dimen/_2131363021_res_0x7f0a04cd"
                    layout_marginEnd="@dimen/_2131363021_res_0x7f0a04cd"/>
            </LinearLayout>
            <LinearLayout
                orientation="1"
                id="@+id/series_course_tab_layout"
                layout_width="-1"
                layout_height="-2"
                layout_marginTop="@dimen/_2131362970_res_0x7f0a049a"
                layout_marginBottom="@dimen/_2131362578_res_0x7f0a0312">
                <com.huawei.ui.commonui.subtab.HealthSubTabWidget
                    id="@+id/series_course_sub_tab"
                    background="@color/_2131296984_res_0x7f0902d8"
                    layout_width="-1"
                    layout_height="-2"
                    style="@style/health_sub_tab_style_series_course"/>
                <com.huawei.ui.commonui.viewpager.HealthViewPager
                    id="@+id/series_course_sub_tab_vp"
                    layout_width="-1"
                    layout_height="-1"/>
            </LinearLayout>
        </LinearLayout>
    </com.huawei.ui.commonui.scrollview.HealthScrollView>
    <include
        id="@+id/course_loading_layout"
        visibility="2"
        layout_width="-1"
        layout_height="-1"
        layout="@layout/common_loading_layout"/>
    <include
        layout_gravity="0x11"
        id="@+id/no_network_layout"
        visibility="2"
        layout_width="-1"
        layout_height="-1"
        layout="@layout/no_network_layout"/>
</RelativeLayout>
