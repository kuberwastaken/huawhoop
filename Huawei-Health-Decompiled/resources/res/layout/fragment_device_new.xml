<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x1"
    orientation="1"
    id="@+id/device_card_layout"
    layout_width="-1"
    layout_height="-1">
    <LinearLayout
        orientation="0"
        id="@+id/switch_device_layout"
        background="@drawable/device_switch_tab_bg"
        layout_width="-2"
        layout_height="@dimen/_2131363090_res_0x7f0a0512"
        layout_below="@+id/device_tab_titlebar"
        layout_centerHorizontal="true">
        <com.huawei.uikit.hwtextview.widget.HwTextView
            id="@+id/switch_device"
            text="@string/IDS_device_title_use"
            style="@style/device_tab_text"/>
        <com.huawei.uikit.hwtextview.widget.HwTextView
            id="@+id/switch_web"
            text="@string/_2130848272_res_0x7f022a10"
            style="@style/device_tab_text"/>
    </LinearLayout>
    <com.huawei.ui.commonui.titlebar.CustomTitleBar
        id="@+id/device_tab_titlebar"
        layout_width="-1"
        layout_height="-2"
        layout_alignParentTop="true"
        layout_marginStart="@dimen/_2131364901_res_0x7f0a0c25"/>
    <com.huawei.ui.commonui.viewpager.HealthViewPager
        id="@+id/hw_device_viewpager"
        layout_width="-1"
        layout_height="-1"
        layout_marginTop="@dimen/_2131362568_res_0x7f0a0308"
        layout_below="@+id/switch_device_layout"
        importantForAccessibility="2"/>
</RelativeLayout>
