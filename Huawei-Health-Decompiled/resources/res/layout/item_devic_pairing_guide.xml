                gravity="0x50"
                id="@+id/device_name"
                paddingTop="@dimen/_2131364491_res_0x7f0a0a8b"
                paddingBottom="@dimen/_2131364488_res_0x7f0a0a88"
                layout_width="-1"
                layout_height="-2"
                minHeight="@dimen/_2131364484_res_0x7f0a0a84"
                maxLines="2"
                fontFamily="@string/_2130852833_res_0x7f023be1"
                textDirection="5"
                textAlignment="5"
                breakStrategy="1"
                hyphenationFrequency="1"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                textColor="@color/_2131297422_res_0x7f09048e"
                id="@+id/pair_guide_text"
                layout_width="-2"
                layout_height="-2"
                fontFamily="@string/_2130852834_res_0x7f023be2"
                textDirection="5"
                breakStrategy="1"
                hyphenationFrequency="1"/>
        </LinearLayout>
        <RelativeLayout
            layout_width="160dp"
            layout_height="160dp">
            <ImageView
                id="@+id/device_image"
                layout_width="160dp"
                layout_height="160dp"/>
            <ImageView
                id="@+id/device_image_anim"
                visibility="2"
                layout_width="-2"
                layout_height="160dp"
                layout_centerHorizontal="true"/>
        </RelativeLayout>
    </LinearLayout>
</RelativeLayout>
