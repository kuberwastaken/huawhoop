<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    layout_height="-2"
    layout_marginBottom="32dp"
    minHeight="160dp"
    textDirection="5"
    layoutDirection="3">
    <LinearLayout
        orientation="0"
        layout_width="-1"
        layout_height="-2">
        <LinearLayout
