<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/action"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        layout_height="-2"
        layout_marginLeft="24dp"
        layout_marginRight="16dp"
        layout_marginBottom="16dp"
        layout_marginStart="24dp"
        layout_marginEnd="16dp">
        <RelativeLayout
            paddingTop="24dp"
            layout_width="-1"
            layout_height="-2"
            layout_marginBottom="4dp">
            <TextView
                textSize="@dimen/upsdk_master_body_2"
                textColor="@color/upsdk_color_gray_7"
                id="@+id/third_app_dl_progress_text"
                layout_width="-2"
                layout_height="-2"
                layout_marginRight="48dp"
                layout_alignParentRight="true"
                layout_marginEnd="48dp"
                layout_alignParentEnd="true"/>
            <TextView
                textSize="@dimen/upsdk_master_body_2"
                textColor="@color/upsdk_color_gray_10"
                id="@+id/third_app_warn_text"
                layout_width="-1"
                layout_height="-2"
                layout_marginRight="16dp"
                layout_toLeftOf="@+id/third_app_dl_progress_text"
                layout_marginEnd="16dp"
                layout_toStartOf="@+id/third_app_dl_progress_text"/>
        </RelativeLayout>
        <RelativeLayout
            gravity="0x10"
            layout_width="-1"
            layout_height="-2">
            <RelativeLayout
                id="@+id/cancel_bg"
                background="@drawable/upsdk_third_download_bg"
                focusable="true"
                layout_width="40dp"
                layout_height="40dp"
                layout_alignParentRight="true"
                layout_centerVertical="true"
                layout_alignParentEnd="true">
                <ImageView
                    id="@+id/cancel_imageview"
                    background="@drawable/upsdk_cancel_normal"
                    layout_width="24dp"
                    layout_height="24dp"
                    layout_centerInParent="true"/>
            </RelativeLayout>
            <ProgressBar
                id="@+id/third_app_dl_progressbar"
                layout_width="-1"
                layout_height="-2"
                layout_marginRight="8dp"
                layout_toLeftOf="@+id/cancel_bg"
                layout_centerVertical="true"
                layout_marginEnd="8dp"
                layout_toStartOf="@+id/cancel_bg"
                style="?android:attr/progressBarStyleHorizontal"/>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
