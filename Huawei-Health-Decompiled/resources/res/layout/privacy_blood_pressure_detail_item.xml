<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/privacy_item_content_rl"
    layout_width="-1"
    layout_height="-2">
    <RelativeLayout
        id="@+id/privacy_item_rl"
        background="@drawable/_2131427891_res_0x7f0b0233"
        layout_width="-1"
        layout_height="-2"
        minHeight="@dimen/_2131363641_res_0x7f0a0739"
        layout_centerVertical="true"
        paddingHorizontal="@dimen/_2131362013_res_0x7f0a00dd">
        <LinearLayout
            orientation="1"
            id="@+id/privacy_data_layout"
            layout_width="-2"
            layout_height="-2"
            layout_centerVertical="true">
            <LinearLayout
                orientation="0"
                layout_width="-2"
                layout_height="-2">
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    id="@+id/privacy_detail_title"
                    fontFamily="@string/_2130852833_res_0x7f023be1"
                    style="@style/list_text_title_primary"/>
                <ImageView
                    layout_gravity="0x10"
                    id="@+id/privacy_title_icon"
                    layout_width="-2"
                    layout_height="-2"/>
            </LinearLayout>
            <LinearLayout
                orientation="0"
                layout_width="-2"
                layout_height="-2">
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    layout_gravity="0x10"
                    id="@+id/privacy_detail_desc"
                    style="@style/list_text_title_second"/>
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                    layout_gravity="0x10"
                    id="@+id/privacy_value_status"
                    layout_width="-2"
                    layout_height="-2"
                    fontFamily="@string/_2130852834_res_0x7f023be2"/>
            </LinearLayout>
        </LinearLayout>
        <com.huawei.ui.commonui.divider.HealthDivider
            id="@+id/data_line"
            layout_alignParentBottom="true"
            layout_alignStart="@+id/data_layout"
            style="@style/commonui_item_divide_line_new"/>
    </RelativeLayout>
</RelativeLayout>
