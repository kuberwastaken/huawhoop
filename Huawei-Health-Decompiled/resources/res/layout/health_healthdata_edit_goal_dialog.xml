            id="@+id/edit_goal"
            layout_width="-1"
            layout_height="-2"
            singleLine="true"
            maxLength="4"
            inputType="0x2002"
            layoutDirection="3"
            style="@style/Widget.Emui.HwEditText.Linear"/>
    </com.huawei.ui.commonui.edittext.HealthErrorTipTextLayout>
</RelativeLayout>
