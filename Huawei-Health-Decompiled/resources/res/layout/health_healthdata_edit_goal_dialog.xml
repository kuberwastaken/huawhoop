<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    layout_height="-2">
    <com.huawei.ui.commonui.edittext.HealthErrorTipTextLayout
        id="@+id/edit_goal_layout"
        layout_width="-1"
        layout_height="-2"
        layoutDirection="3"
        NOT_FOUND_0x7="true"
        NOT_FOUND_0x8="1">
