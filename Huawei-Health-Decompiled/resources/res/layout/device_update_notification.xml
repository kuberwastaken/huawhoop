<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/add_music_to_watch_layout"
    layout_width="-1"
    layout_height="-2"
    layout_marginTop="8dp"
    layout_marginBottom="8dp"
    paddingStart="12dp"
    paddingEnd="16dp">
    <LinearLayout
        orientation="0"
        layout_width="-1"
        layout_height="-2"
        minHeight="20dp">
        <ImageView
            id="@+id/touch_app_image_view"
            layout_width="-2"
            layout_height="-1"
            src="@drawable/healthlogo_ic_notification"/>
        <TextView
            textSize="12sp"
            textColor="@color/_2131298206_res_0x7f09079e"
            id="@+id/touch_app_name"
            layout_width="-2"
            layout_height="-1"
            text="@string/IDS_app_name_health"
            layout_marginStart="8dp"/>
        <TextView
            textSize="12sp"
            textColor="@color/_2131298206_res_0x7f09079e"
            id="@+id/touch_transfer_percent"
            layout_width="-2"
            layout_height="-1"
            layout_marginStart="8dp"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        layout_height="-2"
        layout_marginTop="2dp"
        layout_marginBottom="4dp">
        <TextView
            textAppearance="@android:style/TextAppearance.Material.Notification.Info"
            textSize="@dimen/_2131365502_res_0x7f0a0e7e"
            textColor="@color/_2131298206_res_0x7f09079e"
            ellipsize="3"
            id="@+id/touch_transfer_title"
            layout_width="-1"
            layout_height="-2"
            fontFamily="@string/_2130852833_res_0x7f023be1"
            layout_alignParentStart="true"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        layout_width="-1"
        layout_height="-2"
        layout_marginBottom="8dp"
        minHeight="@dimen/_2131363032_res_0x7f0a04d8">
        <LinearLayout
            orientation="0"
            layout_width="-1"
            layout_height="-2">
            <ProgressBar
                layout_gravity="0x10"
                id="@+id/touch_transfer_progress"
                layout_width="-1"
                layout_height="2dp"
                progressDrawable="@drawable/_2131427969_res_0x7f0b0281"
                layout_weight="1"
                style="?android:attr/progressBarStyleHorizontal"/>
            <ImageView
                id="@+id/progress_cancel"
                clickable="true"
                layout_width="@dimen/_2131363021_res_0x7f0a04cd"
                layout_height="@dimen/_2131363021_res_0x7f0a04cd"
                src="@drawable/_2131427710_res_0x7f0b017e"
                layout_marginStart="@dimen/_2131362934_res_0x7f0a0476"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
