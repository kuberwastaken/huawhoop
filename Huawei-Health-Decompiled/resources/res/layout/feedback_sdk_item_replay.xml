<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-2"
    layout_height="-2"
    layout_marginBottom="@dimen/_2131362797_res_0x7f0a03ed">
    <ImageView
        id="@+id/tb_my_user_icon"
        layout_width="@dimen/_2131362804_res_0x7f0a03f4"
        layout_height="@dimen/_2131362804_res_0x7f0a03f4"
        src="@drawable/feedback_sdk_serviceavatar"
        layout_marginEnd="@dimen/_2131362815_res_0x7f0a03ff"/>
    <RelativeLayout
        id="@+id/rl_replay_img_failed"
        background="@drawable/feedback_sdk_bg_question_from"
        visibility="2"
        layout_width="90dp"
        layout_height="90dp"
        layout_toEndOf="@+id/tb_my_user_icon">
        <ImageView
            id="@+id/replay_img_item"
            layout_width="32dp"
            layout_height="32dp"
            layout_marginTop="20dp"
            layout_marginBottom="9dp"
            src="@drawable/feedback_icon_pic"
            scaleType="6"
            layout_centerInParent="true"/>
    </RelativeLayout>
    <ImageView
        id="@+id/replay_img_failed"
        visibility="2"
        layout_width="@dimen/_2131362797_res_0x7f0a03ed"
        layout_height="@dimen/_2131362797_res_0x7f0a03ed"
        src="@drawable/feedback_icon_notice"
        layout_centerVertical="true"
        layout_marginStart="@dimen/_2131362813_res_0x7f0a03fd"
        layout_toEndOf="@+id/rl_replay_img_failed"/>
    <RelativeLayout
        id="@+id/replay_img_progress"
        background="@drawable/feedback_sdk_bg_question_from"
        visibility="2"
        layout_width="90dp"
        layout_height="90dp"
        layout_toEndOf="@+id/tb_my_user_icon">
        <ProgressBar
            layout_width="-2"
            layout_height="-2"
            layout_centerInParent="true"/>
    </RelativeLayout>
    <ImageView
        id="@+id/replay_img_success"
        visibility="2"
        layout_width="90dp"
        layout_height="90dp"
        layout_toEndOf="@+id/tb_my_user_icon"/>
</RelativeLayout>
