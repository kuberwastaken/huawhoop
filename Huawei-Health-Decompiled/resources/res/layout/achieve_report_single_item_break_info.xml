<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    layout_width="-1"
    layout_height="-2">
    <RelativeLayout
        orientation="1"
        id="@+id/line_layout"
        layout_width="9dp"
        layout_height="-2">
        <ImageView
            layout_gravity="0x11"
            id="@+id/image_line"
            background="@drawable/_2131427700_res_0x7f0b0174"
            layout_width="1.5dp"
            layout_height="-1"
            layout_centerHorizontal="true"/>
        <ImageView
            id="@+id/image_dot"
            background="@drawable/_2131427699_res_0x7f0b0173"
            layout_width="9dp"
            layout_height="9dp"
            layout_marginTop="12dp"/>
    </RelativeLayout>
    <LinearLayout
        orientation="1"
        id="@+id/index_area"
        layout_width="-1"
        layout_height="-2"
        layout_marginStart="14dp">
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365497_res_0x7f0a0e79"
            textColor="@color/_2131299845_res_0x7f090e05"
            ellipsize="3"
            gravity="0x800003"
            id="@+id/index_value"
            layout_width="-2"
            layout_height="-2"
            layout_marginBottom="10dp"
            maxLines="1"
            fontFamily="@string/_2130852833_res_0x7f023be1"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365484_res_0x7f0a0e6c"
            textColor="@color/_2131299850_res_0x7f090e0a"
            ellipsize="3"
            gravity="0x800003"
            id="@+id/index_desc"
            layout_width="-2"
            layout_height="-2"
            layout_marginBottom="24dp"
            maxLines="2"
            fontFamily="@string/_2130852834_res_0x7f023be2"/>
    </LinearLayout>
</LinearLayout>
