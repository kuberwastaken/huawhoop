<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/buttonPanel"
    layout_width="-1"
    layout_height="-2"
    minHeight="@dimen/hw_cloud_dialog_title_layout_min_height"
    fillViewport="true"
    scrollIndicators="0x3">
    <LinearLayout
        gravity="0x50"
        orientation="0"
        id="@+id/button_container"
        paddingLeft="12dp"
        paddingRight="12dp"
        layout_width="-1"
        layout_height="-2"
        layoutDirection="3">
        <Button
            ellipsize="3"
            gravity="0x11"
            layout_gravity="0x10"
            id="@android:id/button3"
            layout_width="0dp"
            layout_height="40dp"
            baselineAlignBottom="true"
            maxLines="1"
            singleLine="true"
            layout_weight="1"/>
        <android.widget.Space
            id="@+id/spacer"
            visibility="1"
            layout_width="0dp"
            layout_height="0dp"/>
        <Button
            ellipsize="3"
            gravity="0x11"
            layout_gravity="0x10"
            id="@android:id/button2"
            layout_width="0dp"
            layout_height="40dp"
            baselineAlignBottom="true"
            maxLines="1"
            singleLine="true"
            layout_weight="1"/>
        <Button
            ellipsize="3"
            gravity="0x11"
            layout_gravity="0x10"
            id="@android:id/button1"
            layout_width="0dp"
            layout_height="40dp"
            baselineAlignBottom="true"
            maxLines="1"
            singleLine="true"
            layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
