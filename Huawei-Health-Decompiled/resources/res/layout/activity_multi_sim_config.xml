<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:setting="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@color/_2131296979_res_0x7f0902d3"
    layout_width="-1"
    layout_height="-1">
    <com.huawei.ui.commonui.titlebar.CustomTitleBar
        id="@+id/multi_sim_config_title_bar"
        layout_width="-1"
        layout_height="-2"
        NOT_FOUND_0x6="2"
        NOT_FOUND_0x7="@string/_2130849066_res_0x7f022d2a"/>
    <RelativeLayout
        layout_width="-2"
        layout_height="-2">
        <RelativeLayout
            id="@+id/multi_sim_open_error_bar"
            layout_width="-2"
            layout_height="-2">
            <include layout="@layout/bt_disconnect_layout"/>
            <include layout="@layout/network_error_layout"/>
            <include layout="@layout/no_sim_error_layout"/>
            <include layout="@layout/bt_connecting_layout"/>
        </RelativeLayout>
        <RelativeLayout
            layout_width="-2"
            layout_height="-2"
            layout_below="@+id/multi_sim_open_error_bar">
            <include layout="@layout/multi_sim_config_waiting"/>
            <include layout="@layout/multi_sim_config_unbind"/>
            <include layout="@layout/multi_sim_config_open_error"/>
            <include layout="@layout/multi_sim_config_query_error"/>
            <include layout="@layout/multi_sim_config_fail"/>
            <include layout="@layout/multi_sim_config_start"/>
        </RelativeLayout>
    </RelativeLayout>
</LinearLayout>
