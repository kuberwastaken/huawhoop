<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/report_index_table_item"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        orientation="0"
        id="@+id/report_index_table_item_content"
        layout_width="-1"
        layout_height="-1">
        <LinearLayout
            gravity="0x11"
            orientation="1"
            id="@+id/index_name_and_unit"
            layout_width="0dp"
            layout_height="-1"
            layout_weight="4">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="8dp"
                textColor="@color/_2131299845_res_0x7f090e05"
                id="@+id/index_name"
                layout_width="-2"
                layout_height="-2"
                fontFamily="@string/_2130852833_res_0x7f023be1"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="6dp"
                textColor="@color/_2131299850_res_0x7f090e0a"
                id="@+id/index_unit"
                layout_width="-2"
                layout_height="-2"/>
        </LinearLayout>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            id="@+id/dash_vertical_line_1"
            background="@drawable/_2131427974_res_0x7f0b0286"
            layout_width="@dimen/_2131363795_res_0x7f0a07d3"
            layout_height="-1"
            layerType="1"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="8dp"
            textColor="@color/_2131299845_res_0x7f090e05"
            gravity="0x11"
            id="@+id/index_measure_value"
            layout_width="0dp"
            layout_height="-1"
            layout_weight="3"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            id="@+id/dash_vertical_line_2"
            background="@drawable/_2131427974_res_0x7f0b0286"
            layout_width="@dimen/_2131363795_res_0x7f0a07d3"
            layout_height="-1"
            layerType="1"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="8dp"
            textColor="@color/_2131299845_res_0x7f090e05"
            gravity="0x11"
            id="@+id/index_normal_range"
            layout_width="0dp"
            layout_height="-1"
            layout_weight="3"/>
    </LinearLayout>
    <View
        layout_gravity="0x11"
        id="@+id/row_seperator"
        background="@drawable/_2131427970_res_0x7f0b0282"
        layout_width="-1"
        layout_height="@dimen/_2131363766_res_0x7f0a07b6"/>
</LinearLayout>
