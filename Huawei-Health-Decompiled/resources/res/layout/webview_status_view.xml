<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/status_layout_main"
    visibility="2"
    layout_width="-1"
    layout_height="-1">
    <LinearLayout
        gravity="0x11"
        id="@+id/layout_privacy_set_network"
        layout_width="-1"
        layout_height="-2"
        layout_marginBottom="@dimen/_2131363333_res_0x7f0a0605"
        weightSum="1"
        layout_alignParentBottom="true"
        layout_centerHorizontal="true">
        <Button
