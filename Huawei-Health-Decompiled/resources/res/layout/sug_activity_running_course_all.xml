<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    background="@color/_2131296667_res_0x7f09019b"
    layout_width="-1"
    layout_height="-1">
    <FrameLayout
        layout_width="-1"
        layout_height="-2">
        <com.huawei.ui.commonui.titlebar.CustomTitleBar xmlns:setting="http://schemas.android.com/apk/res-auto"
            id="@+id/sug_fitness_title"
            layout_width="-1"
            layout_height="-2"
            NOT_FOUND_0x7="3"
            NOT_FOUND_0x8="@drawable/_2131431795_res_0x7f0b1173"
            NOT_FOUND_0x9="@string/_2130847656_res_0x7f0227a8"
            NOT_FOUND_0xa="@string/_2130849647_res_0x7f022f6f"/>
        <fragment
            name="com.huawei.health.suggestion.ui.fragment.FitnessSearchFragmentBar"
            id="@+id/fragment_FitSearchFragmentBar"
            layout_width="-1"
            layout_height="-2"/>
    </FrameLayout>
    <FrameLayout
        id="@+id/sug_march_frame"
        layout_width="-1"
        layout_height="-1">
        <FrameLayout
            id="@+id/normal_content_layout"
            background="@color/_2131296667_res_0x7f09019b"
            layout_width="-1"
            layout_height="-1">
            <LinearLayout
                orientation="1"
                layout_width="-1"
                layout_height="-2">
                <com.huawei.ui.commonui.subtab.HealthSubTabWidget
                    id="@+id/sug_run_detail_tab"
                    layout_width="-1"
                    layout_height="-2"
                    style="@style/health_sub_tab_style"/>
                <com.huawei.ui.commonui.viewpager.HealthViewPager
                    id="@+id/sug_run_detail_vp"
                    layout_width="-1"
                    layout_height="-1"/>
            </LinearLayout>
            <com.huawei.health.suggestion.ui.view.FitnessEmptyView
                id="@+id/sug_search_empty_view"
                visibility="2"
                layout_width="-1"
                layout_height="-1"/>
        </FrameLayout>
        <FrameLayout
            id="@+id/search_content_layout"
            visibility="1"
            layout_width="-1"
            layout_height="-1">
            <fragment
                name="com.huawei.health.suggestion.ui.fragment.FitSearchFragmentRecyclerView"
                id="@+id/fragment_FitSearchFragmentRecyclerView"
                layout_width="-1"
                layout_height="-1"/>
            <fragment
                name="com.huawei.health.suggestion.ui.fragment.FitSearchFragmentFlowLayout"
                id="@+id/fragment_FitSearchFragmentFlowLayout"
                layout_width="-1"
                layout_height="-1"/>
            <include
                visibility="2"
                layout="@layout/sug_search_no_show"/>
        </FrameLayout>
    </FrameLayout>
</LinearLayout>
