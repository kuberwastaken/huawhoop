<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    layout_height="-2"
    paddingStart="@dimen/_2131362801_res_0x7f0a03f1"
    paddingEnd="@dimen/_2131362801_res_0x7f0a03f1">
    <TextView
        textSize="16sp"
        textColor="@color/feedback_sdk_text_normal_black"
        id="@+id/list_dialog_item_content"
        layout_width="-2"
        layout_height="-2"
        layout_marginTop="10dp"
        layout_marginBottom="10dp"
        layout_centerVertical="true"/>
    <RadioButton
        id="@+id/list_dialog_item_radio"
        focusable="false"
        clickable="false"
        layout_width="-2"
        layout_height="-2"
        layout_marginTop="10dp"
        layout_marginBottom="10dp"
        layout_centerVertical="true"
        layout_alignParentEnd="true"/>
    <View
        id="@+id/list_dialog_item_line"
        background="@color/feedback_sdk_grid_divider_color"
        layout_width="-1"
        layout_height="0.5dp"
        layout_alignParentBottom="true"/>
</RelativeLayout>
