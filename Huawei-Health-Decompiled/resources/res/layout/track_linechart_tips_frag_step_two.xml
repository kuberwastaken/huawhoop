<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    background="#7f000000"
    clickable="true"
    layout_width="-1"
    layout_height="-1">
    <RelativeLayout
        id="@+id/step_two_click_tips"
        layout_width="-2"
        layout_height="10dp"/>
    <RelativeLayout
        id="@+id/step_top_button_click_tips"
        layout_width="-2"
        layout_height="48dp"
        layout_below="@+id/step_two_click_tips">
        <RelativeLayout
            gravity="0x50"
            layout_width="-1"
            layout_height="-2"
            layout_marginBottom="8dp"
            layout_alignParentBottom="true">
            <ImageView
                id="@+id/first_button"
                background="@drawable/_2131432397_res_0x7f0b13cd"
                layout_width="-2"
                layout_height="-2"
                layout_marginEnd="18dp"
                layout_alignParentEnd="true"/>
            <ImageView
                id="@+id/second_button"
                background="@drawable/_2131432397_res_0x7f0b13cd"
                layout_width="-2"
                layout_height="-2"
                layout_marginEnd="10dp"
                layout_toStartOf="@+id/first_button"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365501_res_0x7f0a0e7d"
                textColor="#ffffffff"
                layout_width="-2"
                layout_height="-2"
                text="@string/_2130842858_res_0x7f0214ea"
                layout_centerVertical="true"
                layout_marginEnd="12dp"
                layout_toStartOf="@+id/second_button"/>
        </RelativeLayout>
    </RelativeLayout>
    <LinearLayout
        orientation="1"
        id="@+id/all_content"
        layout_width="-1"
        layout_height="-1">
        <View
            clickable="false"
            layout_width="-1"
            layout_height="0dp"
            layout_weight="1"/>
        <ImageView
            layout_gravity="0x1"
            clickable="false"
            layout_width="-2"
            layout_height="-2"
            src="@drawable/pic_tips_size"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365501_res_0x7f0a0e7d"
            textColor="#ffffffff"
            layout_gravity="0x1"
            id="@+id/tips_message"
            clickable="false"
            layout_width="-2"
            layout_height="-2"
            layout_marginTop="8dp"
            text="@string/_2130842737_res_0x7f021471"/>
        <FrameLayout
            layout_width="-1"
            layout_height="-2"
            layout_marginTop="31dp"
            layout_marginBottom="8dp">
            <LinearLayout
                orientation="1"
                id="@+id/stepper_two"
                clickable="false"
                layout_width="-1"
                layout_height="-2">
                <ImageView
                    layout_gravity="0x1"
                    visibility="2"
                    clickable="false"
                    layout_width="-2"
                    layout_height="-2"
                    src="@drawable/_2131430802_res_0x7f0b0d92"/>
            </LinearLayout>
            <LinearLayout
                orientation="1"
                id="@+id/tips_close_btn"
                layout_width="-1"
                layout_height="-2">
                <ImageView
                    layout_gravity="0x800005"
                    layout_width="-2"
                    layout_height="-2"
                    src="@drawable/_2131430849_res_0x7f0b0dc1"
                    layout_marginEnd="10dp"/>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</RelativeLayout>
