            layout_height="-2"
            layout_marginBottom="@dimen/_2131365349_res_0x7f0a0de5"
            text="@string/_2130842408_res_0x7f021328"
            layout_alignParentBottom="true"
            layout_marginStart="@dimen/_2131362540_res_0x7f0a02ec"
            layout_marginEnd="@dimen/_2131362540_res_0x7f0a02ec"/>
