<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/service_item_layout"
    background="@color/_2131296334_res_0x7f09004e"
    layout_width="-1"
    layout_height="-1">
    <include layout="@layout/watchface_activity_common_toolbar"/>
    <LinearLayout
        orientation="1"
        id="@+id/service_item_linear"
        layout_width="-1"
        layout_height="-1"
        layout_marginTop="@dimen/_2131362536_res_0x7f0a02e8"
