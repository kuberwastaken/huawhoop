        <ImageView
            gravity="0x11"
            id="@+id/service_info_loading"
            layout_width="-1"
            layout_height="-2"
            src="@drawable/_2131432590_res_0x7f0b148e"
            style="@style/watch_face_default_img_tint"/>
    </LinearLayout>
