<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:setting="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    layout_height="-1">
    <RelativeLayout
        gravity="0x10"
        id="@+id/stress_titlebar"
        layout_width="-1"
        layout_height="40dp">
        <ImageView
            id="@+id/stress_titlebar_iv"
            background="@drawable/_2131428608_res_0x7f0b0500"
            layout_width="@dimen/_2131365533_res_0x7f0a0e9d"
            layout_height="@dimen/_2131365533_res_0x7f0a0e9d"
            layout_centerVertical="true"
            layout_marginStart="@dimen/_2131365538_res_0x7f0a0ea2"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131362346_res_0x7f0a022a"
            textColor="@color/_2131296884_res_0x7f090274"
            ellipsize="3"
            gravity="0x800013"
            id="@+id/stress_titlebar_title_text"
            layout_width="-1"
            layout_height="-1"
            maxLines="2"
            layout_centerVertical="true"
            layout_marginStart="@dimen/_2131365538_res_0x7f0a0ea2"
            layout_toEndOf="@+id/stress_titlebar_iv"/>
    </RelativeLayout>
    <com.huawei.ui.commonui.progressbar.HealthProgressBar
        id="@+id/load_url_progress"
        visibility="0"
        layout_width="-1"
        layout_height="4dp"
        max="100"
        layout_below="@+id/stress_titlebar"
        style="@style/health_progressbar_style_horizontal"/>
    <WebView
        id="@+id/web_stress"
        layout_width="-1"
        layout_height="-1"
        layout_below="@+id/load_url_progress"/>
</RelativeLayout>
