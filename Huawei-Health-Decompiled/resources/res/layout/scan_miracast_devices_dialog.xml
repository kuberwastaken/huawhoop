<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        orientation="1"
        id="@+id/scan_device_linearlayout"
        layout_width="-1"
        layout_height="-2">
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365482_res_0x7f0a0e6a"
            textColor="@color/_2131299845_res_0x7f090e05"
            id="@+id/scan_miracast_devices"
            layout_width="-1"
            layout_height="-2"
            text="@string/ie_scan_miracast_devices"
            lineSpacingMultiplier="1.1"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365483_res_0x7f0a0e6b"
            textColor="@color/_2131299850_res_0x7f090e0a"
            id="@+id/scan_miracast_devices_hint"
            layout_width="-1"
            layout_height="-2"
            text="@string/ie_scan_miracast_devices_hint"
            lineSpacingMultiplier="1.1"/>
    </LinearLayout>
    <ListView
        scrollbarSize="3dp"
        scrollbarThumbVertical="@drawable/_2131428102_res_0x7f0b0306"
        id="@+id/miracast_device_list"
        visibility="2"
        layout_width="-1"
        layout_height="180dp"
        divider="@null"
        scrollbarFadeDuration="0"
        fadeScrollbars="true"
        paddingEnd="3dp"/>
</RelativeLayout>
