<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/status_bar_latest_event_content"
    layout_width="-1"
    layout_height="128dp">
    <include
        layout_width="@dimen/_2131365122_res_0x7f0a0d02"
        layout_height="@dimen/_2131365121_res_0x7f0a0d01"
        layout="@layout/notification_template_icon_group"/>
    <include
        layout_width="48dp"
        layout_height="48dp"
        layout_marginLeft="2dp"
        layout_marginRight="2dp"
        layout_alignParentRight="true"
        layout_alignParentEnd="true"
        layout="@layout/notification_media_cancel_action"/>
    <LinearLayout
        orientation="0"
        id="@+id/notification_main_column_container"
        paddingTop="@dimen/_2131365123_res_0x7f0a0d03"
        layout_width="-1"
        layout_height="-2"
        layout_marginLeft="@dimen/_2131365121_res_0x7f0a0d01"
        minHeight="@dimen/_2131365121_res_0x7f0a0d01"
        layout_toLeftOf="@+id/cancel_action"
        layout_marginStart="@dimen/_2131365121_res_0x7f0a0d01"
        layout_toStartOf="@+id/cancel_action">
        <FrameLayout
            id="@+id/notification_main_column"
            layout_width="-1"
            layout_height="-2"
            layout_marginLeft="@dimen/_2131365120_res_0x7f0a0d00"
            layout_marginRight="8dp"
            layout_marginBottom="8dp"
            layout_weight="1"
            layout_marginStart="@dimen/_2131365120_res_0x7f0a0d00"
            layout_marginEnd="8dp"/>
        <FrameLayout
            id="@+id/right_side"
            paddingTop="@dimen/_2131365126_res_0x7f0a0d06"
            layout_width="-2"
            layout_height="-2"
            layout_marginRight="8dp"
            layout_marginEnd="8dp">
            <DateTimeView
                textAppearance="@style/TextAppearance.Compat.Notification.Time.Media"
                layout_gravity="0x800035"
                id="@+id/time"
                visibility="2"
                layout_width="-2"
                layout_height="-2"
                singleLine="true"/>
            <Chronometer
                textAppearance="@style/TextAppearance.Compat.Notification.Time.Media"
                layout_gravity="0x800035"
                id="@+id/chronometer"
                visibility="2"
                layout_width="-2"
                layout_height="-2"
                singleLine="true"/>
            <TextView
                textAppearance="@style/TextAppearance.Compat.Notification.Info.Media"
                layout_gravity="0x800055"
                id="@+id/info"
                layout_width="-2"
                layout_height="-2"
                layout_marginTop="20dp"
                singleLine="true"/>
        </FrameLayout>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        id="@+id/media_actions"
        layout_width="-1"
        layout_height="48dp"
        layout_marginLeft="12dp"
        layout_marginRight="12dp"
        layout_alignParentBottom="true"
        layoutDirection="0"/>
    <ImageView
        id="@+id/action_divider"
        background="?android:attr/dividerHorizontal"
        layout_width="-1"
        layout_height="1dp"
        layout_above="@+id/media_actions"/>
</RelativeLayout>
