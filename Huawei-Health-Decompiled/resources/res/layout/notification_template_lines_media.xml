<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    paddingTop="2dp"
    paddingRight="8dp"
    paddingBottom="2dp"
    layout_width="-2"
    layout_height="-2"
    paddingEnd="8dp">
    <LinearLayout
        orientation="0"
        id="@+id/line1"
        paddingTop="6dp"
        layout_width="-1"
        layout_height="-2"
        layout_marginLeft="@dimen/_2131365120_res_0x7f0a0d00"
        layout_marginStart="@dimen/_2131365120_res_0x7f0a0d00">
        <TextView
            textAppearance="@style/TextAppearance.Compat.Notification.Title.Media"
            ellipsize="4"
            id="@+id/title"
            fadingEdge="0x1000"
            layout_width="-1"
            layout_height="-2"
            singleLine="true"
            layout_weight="1"/>
        <DateTimeView
            textAppearance="@style/TextAppearance.Compat.Notification.Time.Media"
            layout_gravity="0x11"
            id="@+id/time"
            paddingLeft="8dp"
            visibility="2"
            layout_width="-2"
            layout_height="-2"
            singleLine="true"
            layout_weight="0"
            paddingStart="8dp"/>
        <Chronometer
            textAppearance="@style/TextAppearance.Compat.Notification.Time.Media"
            layout_gravity="0x11"
            id="@+id/chronometer"
            paddingLeft="8dp"
            visibility="2"
            layout_width="-2"
            layout_height="-2"
            singleLine="true"
            layout_weight="0"
            paddingStart="8dp"/>
    </LinearLayout>
    <TextView
        textAppearance="@style/TextAppearance.Compat.Notification.Line2.Media"
        ellipsize="4"
        id="@+id/text2"
        visibility="2"
        fadingEdge="0x1000"
        layout_width="-1"
        layout_height="-2"
        layout_marginLeft="@dimen/_2131365120_res_0x7f0a0d00"
        layout_marginTop="-2dp"
        layout_marginBottom="-2dp"
        singleLine="true"
        layout_marginStart="@dimen/_2131365120_res_0x7f0a0d00"/>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/line3"
        layout_width="-1"
        layout_height="-2"
        layout_marginLeft="@dimen/_2131365120_res_0x7f0a0d00"
        layout_marginStart="@dimen/_2131365120_res_0x7f0a0d00">
        <TextView
            textAppearance="@style/TextAppearance.Compat.Notification.Media"
            ellipsize="4"
            layout_gravity="0x11"
            id="@+id/text"
            fadingEdge="0x1000"
            layout_width="0dp"
            layout_height="-2"
            singleLine="true"
            layout_weight="1"/>
        <TextView
            textAppearance="@style/TextAppearance.Compat.Notification.Info.Media"
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/info"
            paddingLeft="8dp"
            layout_width="-2"
            layout_height="-2"
            singleLine="true"
            layout_weight="0"
            paddingStart="8dp"/>
    </LinearLayout>
</LinearLayout>
