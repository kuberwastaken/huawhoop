<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    layout_height="-2"
    layout_marginTop="5dp"
    layout_marginBottom="5dp"
    layout_marginStart="10dp"
    layout_marginEnd="10dp">
    <ImageView
        layout_gravity="0x10"
        id="@+id/wear_engine_third_party_app_icon_id"
        layout_width="48dp"
        layout_height="48dp"
        layout_marginStart="0dp"
        layout_marginEnd="0dp"/>
    <LinearLayout
        layout_gravity="0x50"
        orientation="1"
        layout_width="-2"
        layout_height="-2"
        layout_marginStart="10dp">
        <LinearLayout
            orientation="1"
            id="@+id/wear_engine_third_party_app_name_text_layout_id"
            layout_width="-1"
            layout_height="-2"
            layout_marginBottom="12dp">
            <RelativeLayout
                orientation="0"
                layout_width="-1"
                layout_height="-2"
                layout_marginStart="16dp">
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    textColor="@color/_2131299845_res_0x7f090e05"
                    id="@+id/wear_engine_third_party_app_name_text_id"
                    layout_width="-2"
                    layout_height="-2"/>
                <ImageView
                    id="@+id/wear_engine_third_party_app_arrow_gray_id"
                    layout_width="12dp"
                    layout_height="24dp"
                    tint="@color/_2131296695_res_0x7f0901b7"
                    layout_centerVertical="true"
                    layout_alignParentEnd="true"
                    tintMode="5"
                    style="@style/health_default_background_tint"/>
            </RelativeLayout>
        </LinearLayout>
        <View
            id="@+id/wear_engine_third_party_app_view_id"
            background="@color/_2131297367_res_0x7f090457"
            visibility="0"
            layout_width="-1"
            layout_height="1dp"/>
    </LinearLayout>
</LinearLayout>
