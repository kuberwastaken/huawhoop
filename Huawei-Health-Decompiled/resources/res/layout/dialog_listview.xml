<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    background="@drawable/_2131427511_res_0x7f0b00b7"
    layout_width="-1"
    layout_height="-2"
    layout_marginStart="4dp"
    layout_marginEnd="4dp">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        layout_height="-2">
        <RelativeLayout
            layout_width="-1"
            layout_height="-2"
            layout_marginStart="24dp">
            <com.huawei.ui.commonui.progressbar.HealthProgressBar
                id="@+id/dialog_listview_loading"
                layout_width="-2"
                layout_height="-2"
                tint="@color/_2131296695_res_0x7f0901b7"
                layout_centerVertical="true"
                layout_marginEnd="20dp"
                layout_alignParentEnd="true"
                tintMode="5"
                style="@style/hw_health_progressbar_style_small"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365500_res_0x7f0a0e7c"
                textColor="@color/_2131299845_res_0x7f090e05"
                id="@+id/title_listview_tv"
                paddingTop="16dp"
                paddingBottom="15.8dp"
                layout_width="-2"
                layout_height="-2"
                text="@string/IDS_device_mgr_device_scaning_title"
                fontFamily="HwChinese-medium"
                layout_marginEnd="52dp"/>
        </RelativeLayout>
        <ListView
            scrollbarSize="3dp"
            scrollbarThumbVertical="@drawable/_2131428102_res_0x7f0b0306"
            id="@+id/device_list"
            layout_width="-1"
            layout_height="192dp"
            divider="@null"
            scrollbarFadeDuration="0"
            fadeScrollbars="true"
            paddingEnd="3dp"
            layout_marginStart="24dp"/>
    </LinearLayout>
</RelativeLayout>
