<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.view.menu.ListMenuItemView xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-2"
    minWidth="196dp">
    <ImageView
        id="@+id/group_divider"
        background="@drawable/_2131427425_res_0x7f0b0061"
        layout_width="-1"
        layout_height="1dp"
        layout_marginTop="4dp"
        layout_marginBottom="4dp"/>
    <LinearLayout
        id="@+id/content"
        duplicateParentState="true"
        layout_width="-1"
        layout_height="?attr/_2131100138_res_0x7f0601ea"
        style="@style/RtlOverlay.Widget.AppCompat.PopupMenuItem">
        <RelativeLayout
            layout_gravity="0x10"
            duplicateParentState="true"
            layout_width="0dp"
            layout_height="-2"
            layout_weight="1"
            style="@style/RtlOverlay.Widget.AppCompat.PopupMenuItem.InternalGroup">
            <TextView
                textAppearance="?attr/_2131101686_res_0x7f0607f6"
                ellipsize="4"
                id="@+id/title"
                fadingEdge="0x1000"
                duplicateParentState="true"
                layout_width="-1"
                layout_height="-2"
                singleLine="true"
                layout_alignParentTop="true"
                style="@style/RtlOverlay.Widget.AppCompat.PopupMenuItem.Text"/>
            <TextView
                textAppearance="?attr/_2131101695_res_0x7f0607ff"
                id="@+id/shortcut"
                duplicateParentState="true"
                layout_width="-2"
                layout_height="-2"
                singleLine="true"
                layout_below="@+id/title"
                style="@style/RtlOverlay.Widget.AppCompat.PopupMenuItem.Text"/>
        </RelativeLayout>
        <ImageView
            layout_gravity="0x11"
            id="@+id/submenuarrow"
            visibility="2"
            layout_width="-2"
            layout_height="-2"
            scaleType="5"
            style="@style/RtlOverlay.Widget.AppCompat.PopupMenuItem.SubmenuArrow"/>
    </LinearLayout>
</androidx.appcompat.view.menu.ListMenuItemView>
