<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-2">
    <include layout="@layout/watchface_dialog_title_view"/>
    <com.huawei.uikit.phone.hwtextview.widget.HwTextView
        ellipsize="3"
        gravity="0x10"
        layout_gravity="0x10"
        id="@+id/tv_text_alert_title"
        visibility="2"
        layout_width="-1"
        layout_height="-2"
        layout_marginTop="30dp"
        layout_marginStart="@dimen/_2131362548_res_0x7f0a02f4"
        layout_marginEnd="@dimen/_2131362548_res_0x7f0a02f4"
        style="@style/watch_face_CustomDialog_title"/>
    <LinearLayout
        gravity="0x11"
        layout_gravity="0x10"
        layout_width="-1"
        layout_height="-2"
        paddingStart="0dp"
        paddingEnd="0dp"
        layout_marginStart="@dimen/_2131362548_res_0x7f0a02f4"
        layout_marginEnd="@dimen/_2131362548_res_0x7f0a02f4">
        <LinearLayout
            gravity="0x11"
            id="@+id/ll_text_alert_message_layout"
            visibility="0"
            layout_width="-1"
            layout_height="-2">
            <com.huawei.uikit.phone.hwtextview.widget.HwTextView
                layout_gravity="0x10"
                id="@+id/tv_text_alert_message"
                layout_width="-2"
                layout_height="-2"
                lineSpacingMultiplier="1.1"
                breakStrategy="1"
                hyphenationFrequency="1"
                style="@style/watch_face_customDialog_message"/>
        </LinearLayout>
    </LinearLayout>
    <include layout="@layout/watchface_dialog_alert_button"/>
</LinearLayout>
