<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    background="@color/_2131296667_res_0x7f09019b"
    layout_width="-1"
    layout_height="-1">
    <FrameLayout
        layout_width="-2"
        layout_height="-2">
        <com.huawei.ui.commonui.titlebar.CustomTitleBar xmlns:setting="http://schemas.android.com/apk/res-auto"
            id="@+id/sug_fitness_title"
            layout_width="-1"
            layout_height="-2"
            NOT_FOUND_0xe="2"
            NOT_FOUND_0xf="@string/_2130849542_res_0x7f022f06"/>
        <FrameLayout
            layout_gravity="0x800015"
            fitsSystemWindows="true"
            layout_width="-2"
            layout_height="-2"
            layout_marginEnd="@dimen/_2131364900_res_0x7f0a0c24">
            <ImageView
                id="@+id/sug_wear_report"
                visibility="2"
                layout_width="-2"
                layout_height="-2"
                src="@drawable/_2131432122_res_0x7f0b12ba"
                onClick="toreport"
                style="@style/health_default_img_tint"/>
        </FrameLayout>
    </FrameLayout>
    <com.huawei.ui.commonui.subtab.HealthSubTabWidget
        id="@+id/sug_event_pst"
        layout_width="-1"
        layout_height="-2"
        style="@style/health_sub_tab_style"/>
    <RelativeLayout
        layout_width="-1"
        layout_height="-1">
        <com.huawei.ui.commonui.viewpager.HealthViewPager
            id="@+id/sug_train_event_vp"
            layout_width="-1"
            layout_height="-1"
            layout_above="@+id/sug_event_toreport"/>
        <FrameLayout
            id="@+id/sug_event_toreport"
            layout_width="-1"
            layout_height="-2"
            layout_alignParentBottom="true"
            layout_centerInParent="true">
            <com.huawei.ui.commonui.toolbar.HealthToolBar
                id="@+id/tool_bar"
                layout_width="-1"
                layout_height="-2"/>
        </FrameLayout>
    </RelativeLayout>
</LinearLayout>
