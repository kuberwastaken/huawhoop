<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-2"
    layout_marginStart="4dp"
    layout_marginEnd="4dp">
    <LinearLayout
        orientation="0"
        id="@+id/device_search_listview_title_ll"
        layout_width="-1"
        layout_height="-2"
        layout_marginStart="24dp">
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365482_res_0x7f0a0e6a"
            textColor="@color/_2131299845_res_0x7f090e05"
            id="@+id/device_search_listview_title"
            paddingTop="16dp"
            paddingBottom="15.8dp"
            layout_width="-2"
            layout_height="-2"
            text="@string/IDS_device_mgr_device_scaning_title"
            layout_weight="1"
            fontFamily="HwChinese-medium"
            layout_marginEnd="52dp"/>
        <com.huawei.ui.commonui.progressbar.HealthProgressBar
            layout_gravity="0x10"
            id="@+id/dialog_listview_loading"
            layout_width="-2"
            layout_height="-2"
            layout_marginEnd="20dp"
            style="@style/hw_health_progressbar_style_small"/>
    </LinearLayout>
    <ListView
        scrollbarSize="3dp"
        scrollbarThumbVertical="@drawable/_2131428102_res_0x7f0b0306"
        id="@+id/device_list"
        layout_width="-1"
        layout_height="192dp"
        divider="@null"
        scrollbarFadeDuration="0"
        fadeScrollbars="true"
        paddingEnd="3dp"
        layout_marginStart="24dp"/>
</LinearLayout>
