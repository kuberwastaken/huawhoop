<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:setting="http://schemas.android.com/apk/res-auto"
    id="@+id/knit_detail_layout"
    background="@color/_2131297867_res_0x7f09064b"
    layout_width="-1"
    layout_height="-1">
    <LinearLayout
        gravity="0x10"
        id="@+id/knit_measure_toast_layout"
        background="@color/_2131296667_res_0x7f09019b"
        layout_width="-1"
        layout_height="-2"
        layout_below="@+id/knit_health_detail_title_bar">
        <com.huawei.ui.commonui.cardview.HealthCardView
            orientation="1"
            id="@+id/knit_measure_toast"
            visibility="2"
            layout_width="-1"
            layout_height="-2"
            layout_marginStart="@dimen/_2131362372_res_0x7f0a0244"
            layout_marginEnd="@dimen/_2131362371_res_0x7f0a0243"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        id="@+id/knit_health_detail_title_bar_container"
        layout_width="-1"
        layout_height="-2"
        layout_below="@+id/knit_measure_toast_layout">
        <ViewStub
            id="@+id/knit_sub_tab_widget_stub"
            layout_width="-1"
            layout_height="-2"/>
    </LinearLayout>
    <FrameLayout
        orientation="1"
        id="@+id/knit_health_detail_layout"
        layout_width="-1"
        layout_height="-2"
        layout_above="@+id/knit_health_detail_tool_bar"
        layout_below="@+id/knit_health_detail_title_bar_container"
        layout_centerHorizontal="true">
        <LinearLayout
            orientation="1"
            id="@+id/knit_health_detail_default_layout"
            visibility="2"
            layout_width="-1"
            layout_height="-1"/>
        <com.huawei.ui.commonui.viewpager.HealthViewPager
            id="@+id/knit_view_pager"
            visibility="2"
            layout_width="-1"
            layout_height="-2"
            importantForAccessibility="2"/>
    </FrameLayout>
    <com.huawei.ui.commonui.view.ShareBitmapViewGroup
        orientation="1"
        id="@+id/share_container"
        visibility="1"
        layout_width="-1"
        layout_height="-2"/>
    <FrameLayout
        id="@+id/knit_health_detail_empty_layout"
        visibility="2"
        layout_width="-1"
        layout_height="-1"
        layout_above="@+id/knit_health_detail_tool_bar"/>
    <com.huawei.ui.commonui.titlebar.CustomTitleBar
        id="@+id/knit_health_detail_title_bar"
        layout_width="-1"
        layout_height="-2"
        NOT_FOUND_0xf="2"
        NOT_FOUND_0x10="false"/>
    <com.huawei.ui.commonui.toolbar.HealthToolBar
        layout_gravity="0x1"
        id="@+id/knit_health_detail_tool_bar"
        layout_width="-1"
        layout_height="-2"
        layout_alignParentBottom="true"/>
    <LinearLayout
        orientation="1"
        id="@+id/extra_layout_container"
        layout_width="-1"
        layout_height="-1"/>
</RelativeLayout>
