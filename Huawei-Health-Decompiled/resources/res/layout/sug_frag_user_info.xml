<?xml version="1.0" encoding="utf-8"?>
<com.huawei.ui.commonui.columnlayout.HealthColumnRelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    layout_height="-1">
    <com.huawei.ui.commonui.scrollview.HealthScrollView
        id="@+id/scroll_view"
        layout_width="-1"
        layout_height="-1"
        layout_above="@+id/sug_layout_btn">
        <RelativeLayout
            layout_width="-1"
            layout_height="-1">
            <include
                id="@+id/layout_tips"
                layout_width="-1"
                layout_height="-2"
                layout="@layout/sug_frag_run_plan_tips"/>
            <View
                id="@+id/spring_view"
                layout_width="-1"
                layout_height="-2"/>
            <com.huawei.ui.commonui.cardview.HealthCardView
                id="@+id/card_view_info"
                layout_width="-1"
                layout_height="-2"
                layout_below="@+id/spring_view"
                layout_marginStart="@dimen/_2131362478_res_0x7f0a02ae"
                layout_marginEnd="@dimen/_2131362477_res_0x7f0a02ad">
                <com.huawei.ui.commonui.columnlayout.HealthColumnLinearLayout
                    orientation="1"
                    layout_width="-1"
                    layout_height="-2"
                    layout_marginTop="@dimen/_2131362334_res_0x7f0a021e"
                    layout_marginBottom="@dimen/_2131362334_res_0x7f0a021e"
                    layout_marginStart="@dimen/_2131362013_res_0x7f0a00dd"
                    layout_marginEnd="@dimen/_2131362011_res_0x7f0a00db">
                    <include
                        id="@+id/user_gender"
                        layout="@layout/sug_frag_single_user_info"/>
                    <com.huawei.ui.commonui.divider.HealthDivider
                        layout_width="-1"
                        layout_height="-2"
                        layout_marginStart="@dimen/_2131362013_res_0x7f0a00dd"
                        layout_marginEnd="@dimen/_2131362011_res_0x7f0a00db"/>
                    <include
                        id="@+id/user_birth_date"
                        layout="@layout/sug_frag_single_user_info"/>
                    <com.huawei.ui.commonui.divider.HealthDivider
                        layout_width="-1"
                        layout_height="-2"
                        layout_marginStart="@dimen/_2131362013_res_0x7f0a00dd"
                        layout_marginEnd="@dimen/_2131362011_res_0x7f0a00db"/>
                    <include
                        id="@+id/user_height"
                        layout="@layout/sug_frag_single_user_info"/>
                    <com.huawei.ui.commonui.divider.HealthDivider
                        layout_width="-1"
                        layout_height="-2"
                        layout_marginStart="@dimen/_2131362013_res_0x7f0a00dd"
                        layout_marginEnd="@dimen/_2131362011_res_0x7f0a00db"/>
                    <include
                        id="@+id/user_weight"
                        layout="@layout/sug_frag_single_user_info"/>
                </com.huawei.ui.commonui.columnlayout.HealthColumnLinearLayout>
            </com.huawei.ui.commonui.cardview.HealthCardView>
        </RelativeLayout>
    </com.huawei.ui.commonui.scrollview.HealthScrollView>
    <RelativeLayout
        gravity="0x11"
        id="@+id/sug_layout_btn"
        paddingTop="@dimen/_2131362575_res_0x7f0a030f"
        paddingBottom="@dimen/_2131362369_res_0x7f0a0241"
        layout_width="-1"
        layout_height="-2"
        layout_alignParentBottom="true">
        <com.huawei.ui.commonui.columnlayout.HealthColumnLinearLayout
            layout_width="-2"
            layout_height="-2"
            NOT_FOUND_0xf="1">
            <com.huawei.ui.commonui.button.HealthButton
                id="@+id/sug_btn_next"
                layout_width="-2"
                layout_height="-2"
                text="@string/IDS_device_show_confirm_next"
                style="@style/Health.CommonUI.HealthButton"/>
        </com.huawei.ui.commonui.columnlayout.HealthColumnLinearLayout>
    </RelativeLayout>
</com.huawei.ui.commonui.columnlayout.HealthColumnRelativeLayout>
