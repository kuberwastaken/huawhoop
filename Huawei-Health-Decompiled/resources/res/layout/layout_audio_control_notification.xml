<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    layout_height="72dp">
    <LinearLayout
        gravity="0x10"
        orientation="1"
        layout_width="-1"
        layout_height="-1"
        layout_toStartOf="@+id/rl_audioStatus"
        layout_toEndOf="@+id/rl_audioImage">
        <TextView
            textSize="@dimen/_2131365501_res_0x7f0a0e7d"
            textColor="@color/_2131299845_res_0x7f090e05"
            ellipsize="3"
            id="@+id/tv_audioName"
            layout_width="-1"
            layout_height="-2"
            maxLines="1"
            fontFamily="@string/_2130852833_res_0x7f023be1"/>
        <TextView
            textSize="@dimen/_2131365484_res_0x7f0a0e6c"
            textColor="@color/_2131299850_res_0x7f090e0a"
            ellipsize="3"
            id="@+id/tv_audioSource"
            layout_width="-1"
            layout_height="-2"
            layout_marginTop="2dp"
            maxLines="1"
            fontFamily="@string/_2130852834_res_0x7f023be2"/>
    </LinearLayout>
    <RelativeLayout
        id="@+id/rl_audioImage"
        layout_width="48dp"
        layout_height="48dp"
        layout_marginTop="12dp"
        layout_marginBottom="12dp"
        layout_marginStart="12dp"
        layout_marginEnd="16dp">
        <ImageView
            id="@+id/iv_audioImage"
            layout_width="-1"
            layout_height="-1"
            src="@mipmap/_2131820837_res_0x7f110125"
            scaleType="1"
            layout_centerInParent="true"/>
        <ImageView
            id="@+id/iv_audioLogo"
            visibility="1"
            layout_width="16dp"
            layout_height="16dp"
            src="@mipmap/_2131820837_res_0x7f110125"
            layout_alignParentBottom="true"
            layout_alignParentEnd="true"/>
    </RelativeLayout>
    <RelativeLayout
        id="@+id/rl_audioStatus"
        layout_width="40dp"
        layout_height="40dp"
        layout_centerVertical="true"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"
        layout_alignParentEnd="true">
        <ImageView
            id="@+id/iv_audioStatus"
            layout_width="32dp"
            layout_height="32dp"
            scaleType="1"
            layout_centerInParent="true"/>
    </RelativeLayout>
</RelativeLayout>
