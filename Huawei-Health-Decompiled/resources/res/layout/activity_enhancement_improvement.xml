<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    background="@color/_2131296700_res_0x7f0901bc"
    fitsSystemWindows="true"
    clipToPadding="true"
    layout_width="-1"
    layout_height="-1">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        layout_height="-1"
        paddingStart="26dp"
        paddingEnd="26dp">
        <ListView
            id="@+id/list_view_content"
            visibility="0"
            scrollbars="0x0"
            layout_width="-1"
            layout_height="0dp"
            listSelector="@android:color/transparent"
            divider="@null"
            layout_weight="1"/>
        <LinearLayout
            orientation="0"
            id="@+id/ll_bottom"
            layout_width="-1"
            layout_height="48dp">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="15sp"
                textColor="@color/_2131299845_res_0x7f090e05"
                layout_gravity="0x10"
                id="@+id/agreement_declaration_text_view_back"
                layout_width="-2"
                layout_height="-2"
                text="@string/_2130844229_res_0x7f021a45"
                textAllCaps="true"/>
            <View
                visibility="1"
                layout_width="0dp"
                layout_height="1dp"
                layout_weight="1"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="15sp"
                textColor="@color/_2131299845_res_0x7f090e05"
                layout_gravity="0x10"
                id="@+id/agreement_declaration_text_view_next"
                layout_width="-2"
                layout_height="-2"
                text="@string/_2130844228_res_0x7f021a44"
                textAllCaps="true"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
