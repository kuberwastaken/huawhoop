<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    layout_width="-1"
    layout_height="-2">
    <ImageView
        layout_gravity="0x10"
        id="@+id/ic_miracast_device_type"
        layout_width="-2"
        layout_height="-2"
        src="@drawable/ic_device_miracast"/>
    <RelativeLayout
        orientation="1"
        layout_width="-1"
        layout_height="64dp"
        layout_marginStart="16dp">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            layout_height="-2"
            layout_centerVertical="true">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365482_res_0x7f0a0e6a"
                textColor="@color/_2131299845_res_0x7f090e05"
                id="@+id/item_miracast_device_name"
                layout_width="-1"
                layout_height="-2"
                layout_weight="1"
                lineSpacingMultiplier="1.1"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                textColor="@color/_2131299850_res_0x7f090e0a"
                id="@+id/scan_miracast_devices_hint"
                layout_width="-1"
                layout_height="-2"
                text="@string/_2130837509_res_0x7f020005"
                layout_weight="1"
                lineSpacingMultiplier="1.1"/>
        </LinearLayout>
        <View
            id="@+id/item_miracast_device_line"
            background="@color/_2131296923_res_0x7f09029b"
            layout_width="-1"
            layout_height="1px"
            layout_alignParentBottom="true"/>
    </RelativeLayout>
</LinearLayout>
