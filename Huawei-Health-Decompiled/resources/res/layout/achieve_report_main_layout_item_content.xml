<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/item_content_rl"
    background="@color/_2131296667_res_0x7f09019b"
    layout_width="-1"
    layout_height="-2"
    minHeight="@dimen/_2131363550_res_0x7f0a06de"
    layout_centerVertical="true"
    paddingStart="@dimen/_2131364900_res_0x7f0a0c24"
    paddingEnd="@dimen/_2131364901_res_0x7f0a0c25">
    <ImageView
        id="@+id/content_icon"
        layout_width="-2"
        layout_height="-2"
        layout_centerVertical="true"
        style="@style/health_default_background_tint"/>
    <LinearLayout
        orientation="1"
        id="@+id/data_layout"
        layout_width="-2"
        layout_height="-2"
        layout_weight="1"
        layout_centerVertical="true"
        layout_marginStart="@dimen/_2131363516_res_0x7f0a06bc"
        layout_toEndOf="@+id/content_icon">
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            id="@+id/content_title"
            layout_width="-2"
            layout_height="-2"
            maxWidth="@dimen/_2131362982_res_0x7f0a04a6"
            text="@string/_2130841050_res_0x7f020dda"
            style="@style/list_text_title_primary"/>
        <LinearLayout
            orientation="0"
            id="@+id/content_layout"
            layout_width="-2"
            layout_height="-2"
            maxWidth="@dimen/_2131362982_res_0x7f0a04a6">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                id="@+id/content_value"
                layout_width="-2"
                layout_height="-2"
                text="@string/_2130841049_res_0x7f020dd9"
                textDirection="5"
                style="@style/list_text_title_second"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                id="@+id/content_unit"
                visibility="2"
                layout_width="-2"
                layout_height="-2"
                text="@string/_2130844418_res_0x7f021b02"
                layout_marginStart="@dimen/_2131363520_res_0x7f0a06c0"
                style="@style/list_text_title_second"/>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        layout_width="-2"
        layout_height="-2"
        layout_weight="1"
        layout_centerVertical="true"
        layout_marginStart="@dimen/_2131363537_res_0x7f0a06d1"
        layout_toEndOf="@+id/data_layout"
        layout_alignParentEnd="true">
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            gravity="0x800005"
            id="@+id/content_desc"
            layout_width="-2"
            layout_height="-2"
            text="@string/_2130841049_res_0x7f020dd9"
            layout_alignParentEnd="true"
            breakStrategy="1"
            hyphenationFrequency="1"
            style="@style/list_text_title_right"/>
        <LinearLayout
            orientation="0"
            id="@+id/record_data_layout"
            visibility="2"
            layout_width="-2"
            layout_height="-2"
            layout_weight="1"
            layout_centerVertical="true"
            fontFamily="sans-serif-regular"
            layout_marginStart="@dimen/_2131363537_res_0x7f0a06d1"
            layout_alignParentEnd="true">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                id="@+id/record_data"
                layout_width="0px"
                layout_height="-2"
                text="@string/_2130841049_res_0x7f020dd9"
                layout_weight="1"
                style="@style/list_text_title_right"/>
            <ImageView
                layout_gravity="0x10"
                id="@+id/record_arrow"
                layout_width="-2"
                layout_height="-2"
                src="@drawable/_2131427877_res_0x7f0b0225"
                layout_marginStart="@dimen/_2131363537_res_0x7f0a06d1"
                style="@style/health_default_img_tint"/>
        </LinearLayout>
    </RelativeLayout>
    <com.huawei.ui.commonui.divider.HealthDivider
        id="@+id/data_line"
        layout_width="-1"
        layout_height="-2"
        layout_alignParentBottom="true"
        layout_alignStart="@+id/data_layout"/>
</RelativeLayout>
