<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:setting="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/main"
    layout_width="-1"
    layout_height="-1">
    <com.huawei.ui.commonui.titlebar.CustomTitleBar
        id="@+id/pair_guide_custom_title"
        layout_width="-1"
        layout_height="-2"
        NOT_FOUND_0x19="2"
        NOT_FOUND_0x1b="@string/IDS_device_pair_connect"/>
    <LinearLayout
        orientation="1"
        layout_width="-1"
        layout_height="-1">
        <com.huawei.ui.commonui.scrollview.HealthScrollView
            id="@+id/device_pairing_guide_watch"
            paddingBottom="@dimen/_2131362577_res_0x7f0a0311"
            layout_width="-1"
            layout_height="0dp"
            layout_weight="1">
            <LinearLayout
                orientation="1"
                id="@+id/pair_result_progress_img"
                layout_width="-1"
                layout_height="-1">
                <RelativeLayout
                    id="@+id/ll_icon_pair"
                    layout_width="-1"
                    layout_height="-1"
                    minHeight="300dp">
                    <LinearLayout
                        gravity="0x11"
                        orientation="0"
                        layout_width="-1"
                        layout_height="-2"
                        layout_centerInParent="true">
                        <View
                            background="@color/_2131299926_res_0x7f090e56"
                            layout_width="0dp"
                            layout_height="-2"
                            layout_weight="1"/>
                        <ImageView
                            layout_gravity="0x10"
                            layout_width="144dp"
                            layout_height="144dp"
                            src="@drawable/_2131430976_res_0x7f0b0e40"
                            scaleType="3"/>
                        <View
                            background="@color/_2131299926_res_0x7f090e56"
                            layout_width="6dp"
                            layout_height="-2"/>
                        <ImageView
                            layout_gravity="0x10"
                            id="@+id/pair_result_img"
                            layout_width="144dp"
                            layout_height="144dp"
                            scaleType="3"/>
                        <View
                            background="@color/_2131299926_res_0x7f090e56"
                            layout_width="0dp"
                            layout_height="-2"
                            layout_weight="1"/>
                    </LinearLayout>
                    <RelativeLayout
                        layout_width="-2"
                        layout_height="-2"
                        layout_centerInParent="true">
                        <ImageView
                            id="@+id/pair_progress_anim"
                            visibility="0"
                            layout_width="-2"
                            layout_height="-2"
                            src="@anim/_2130772013_res_0x7f01002d"
                            layout_centerInParent="true"/>
                    </RelativeLayout>
                </RelativeLayout>
                <RelativeLayout
                    id="@+id/pair_result_img_text"
                    layout_width="-1"
                    layout_height="-2"
                    layout_marginTop="24dp"
                    layout_below="@+id/ll_icon_pair">
                    <com.huawei.ui.commonui.healthtextview.HealthTextView
                        textSize="@dimen/_2131365500_res_0x7f0a0e7c"
                        textColor="@color/_2131299845_res_0x7f090e05"
                        gravity="0x11"
                        id="@+id/pair_device_name"
                        layout_width="-1"
                        layout_height="-2"
                        layout_centerHorizontal="true"
                        lineSpacingExtra="@dimen/_2131362470_res_0x7f0a02a6"
                        fontFamily="@string/_2130852833_res_0x7f023be1"
                        layout_marginStart="@dimen/_2131364901_res_0x7f0a0c25"
                        layout_marginEnd="@dimen/_2131364900_res_0x7f0a0c24"/>
                </RelativeLayout>
            </LinearLayout>
        </com.huawei.ui.commonui.scrollview.HealthScrollView>
        <com.huawei.ui.commonui.columnlayout.HealthColumnLinearLayout
            gravity="0x1"
            layout_gravity="0x1"
            orientation="0"
            id="@+id/cancel_button_layout"
            layout_width="-1"
            layout_height="-2"
            layout_marginBottom="@dimen/_2131362465_res_0x7f0a02a1"
            NOT_FOUND_0x1a="1">
            <com.huawei.ui.commonui.button.HealthButton
                gravity="0x11"
                id="@+id/continue_button"
                layout_width="-2"
                text="@string/_2130845712_res_0x7f022010"
                style="@style/health_button_style_emphasize"/>
        </com.huawei.ui.commonui.columnlayout.HealthColumnLinearLayout>
    </LinearLayout>
</LinearLayout>
