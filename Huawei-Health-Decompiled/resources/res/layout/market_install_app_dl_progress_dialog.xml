<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/action"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        layout_height="-2"
        layout_marginBottom="16dp"
        layout_marginStart="24dp"
        layout_marginEnd="16dp">
        <RelativeLayout
            paddingTop="24dp"
            layout_width="-1"
            layout_height="-2"
            layout_marginBottom="4dp">
            <TextView
                textSize="@dimen/_2131364859_res_0x7f0a0bfb"
                id="@+id/third_app_dl_progress_text"
                layout_width="-2"
                layout_height="-2"
                layout_marginEnd="48dp"
                layout_alignParentEnd="true"/>
            <TextView
                textSize="@dimen/_2131364859_res_0x7f0a0bfb"
                id="@+id/third_app_warn_text"
                layout_width="-1"
                layout_height="-2"
                text="@string/_2130852590_res_0x7f023aee"
                layout_marginEnd="16dp"
                layout_toStartOf="@+id/third_app_dl_progress_text"/>
        </RelativeLayout>
        <RelativeLayout
            gravity="0x10"
            layout_width="-1"
            layout_height="-2">
            <RelativeLayout
                id="@+id/cancel_bg"
                focusable="true"
                layout_width="40dp"
                layout_height="40dp"
                layout_centerVertical="true"
                layout_alignParentEnd="true">
                <ImageView
                    id="@+id/cancel_imageview"
                    background="@drawable/_2131431195_res_0x7f0b0f1b"
                    layout_width="24dp"
                    layout_height="24dp"
                    layout_centerInParent="true"
                    contentDescription="@string/_2130852578_res_0x7f023ae2"/>
            </RelativeLayout>
            <ProgressBar
                id="@+id/third_app_dl_progressbar"
                layout_width="-1"
                layout_height="-2"
                layout_centerVertical="true"
                layout_marginEnd="8dp"
                layout_toStartOf="@+id/cancel_bg"
                style="?android:attr/progressBarStyleHorizontal"/>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
