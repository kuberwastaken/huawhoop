<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:setting="http://schemas.android.com/apk/res-auto"
    background="@color/_2131297867_res_0x7f09064b"
    layout_width="-1"
    layout_height="-1">
    <com.huawei.ui.commonui.toolbar.HealthToolBar
        gravity="0x1"
        id="@+id/health_detail_tool_bar"
        layout_width="-1"
        layout_height="-2"
        layout_alignParentBottom="true"/>
    <FrameLayout
        orientation="1"
        id="@+id/health_detail_no_data_container"
        layout_width="-1"
        layout_height="-1"
        layout_above="@+id/health_detail_tool_bar"/>
    <com.huawei.ui.commonui.titlebar.CustomTitleBar
        id="@+id/health_detail_title_bar"
        layout_width="-1"
        layout_height="-2"
        NOT_FOUND_0x11="2"/>
    <LinearLayout
        orientation="1"
        id="@+id/health_detail_notification_layout"
        visibility="2"
        layout_width="-1"
        layout_height="-2"
        layout_below="@+id/health_detail_title_bar"/>
    <FrameLayout
        orientation="1"
        id="@+id/health_detail_has_data_container"
        layout_width="-1"
        layout_height="-2"
        layout_above="@+id/health_detail_tool_bar"
        layout_below="@+id/health_detail_notification_layout"/>
    <LinearLayout
        gravity="0x11"
        orientation="1"
        id="@+id/health_detail_loading"
        layout_width="-1"
        layout_height="-1"
        layout_below="@+id/health_detail_title_bar"
        layout_centerInParent="true">
        <com.huawei.ui.commonui.progressbar.HealthProgressBar
            gravity="0x11"
            layout_gravity="0x1"
            id="@+id/data_loading_progress"
            layout_width="-2"
            layout_height="-2"
            style="@style/hw_health_progressbar_style_large"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365483_res_0x7f0a0e6b"
            textColor="@color/_2131299850_res_0x7f090e0a"
            gravity="0x11"
            layout_gravity="0x1"
            layout_width="-2"
            layout_height="-2"
            text="@string/_2130837596_res_0x7f02005c"
            layout_below="@+id/data_loading_progress"
            lineSpacingMultiplier="1.2"
            fontFamily="@string/_2130852834_res_0x7f023be2"/>
    </LinearLayout>
    <LinearLayout
        orientation="1"
        id="@+id/extra_guide_layout_container"
        visibility="2"
        layout_width="-1"
        layout_height="-1"/>
</RelativeLayout>
