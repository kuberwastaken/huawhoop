<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:setting="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@color/_2131296667_res_0x7f09019b"
    layout_width="-1"
    layout_height="-1">
    <com.huawei.ui.commonui.titlebar.CustomTitleBar
        id="@+id/local_music_resource_titlebar"
        layout_width="-1"
        layout_height="-2"
        NOT_FOUND_0x15="2"
        NOT_FOUND_0x16="0"/>
    <LinearLayout
        orientation="1"
        id="@+id/data_ll"
        layout_width="-1"
        layout_height="-1"
        layout_below="@+id/local_music_resource_titlebar">
