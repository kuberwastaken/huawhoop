                id="@+id/musics_songs_in_menu_list"
                scrollbars="0x0"
                layout_width="-2"
                layout_height="-1"
                fillViewport="true"/>
        </RelativeLayout>
        <com.huawei.ui.commonui.toolbar.HealthToolBar
            gravity="0x1"
            orientation="1"
            id="@+id/bottom_operate_toolbar"
            visibility="2"
            layout_width="-1"
            layout_height="-2"
            layout_marginTop="8dp"
            layout_alignParentBottom="true"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x1"
        orientation="1"
        id="@+id/empty_ll"
        layout_width="-1"
        layout_height="-2"
        layout_centerInParent="true">
        <ImageView
            layout_width="@dimen/_2131362494_res_0x7f0a02be"
            layout_height="@dimen/_2131362494_res_0x7f0a02be"
            src="@drawable/_2131428785_res_0x7f0b05b1"
            style="@style/health_default_img_tint"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131363699_res_0x7f0a0773"
            textColor="@color/_2131299383_res_0x7f090c37"
            layout_width="-2"
            layout_height="-2"
            text="@string/_2130843585_res_0x7f0217c1"
            fontFamily="Roboto-Regular"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x1"
        orientation="1"
        id="@+id/load_ll"
        visibility="2"
        layout_width="-1"
        layout_height="-2"
        layout_centerInParent="true">
        <com.huawei.ui.commonui.progressbar.HealthProgressBar
            id="@+id/load_progressbar"
            layout_width="@dimen/_2131363758_res_0x7f0a07ae"
            layout_height="@dimen/_2131363758_res_0x7f0a07ae"
            tint="@color/_2131297849_res_0x7f090639"
            tintMode="5"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131363699_res_0x7f0a0773"
            textColor="@color/_2131299383_res_0x7f090c37"
            id="@+id/load_tip_tv"
            layout_width="-2"
            layout_height="-2"
            text="@string/_2130843768_res_0x7f021878"
            fontFamily="Roboto-Regular"/>
    </LinearLayout>
</RelativeLayout>
