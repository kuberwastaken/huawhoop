<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    tag="base"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        orientation="0"
        paddingTop="6dp"
        layout_width="-2"
        layout_height="-2"
        paddingStart="16dp"
        paddingEnd="16dp">
        <ImageView
            layout_gravity="0x10"
            id="@+id/icon"
            layout_width="14dp"
            layout_height="14dp"
            layout_marginEnd="5dp"/>
        <TextView
            textSize="14sp"
            textColor="@color/_2131298206_res_0x7f09079e"
            id="@+id/app_name_text"
            layout_width="-2"
            layout_height="-2"
            singleLine="true"
            layout_marginStart="3dp"
            layout_marginEnd="2dp"/>
    </LinearLayout>
    <include
        layout_width="-1"
        layout_height="-2"
        layout_marginBottom="10dp"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"
        layout="@layout/sport_data_notification_tar31"/>
</LinearLayout>
