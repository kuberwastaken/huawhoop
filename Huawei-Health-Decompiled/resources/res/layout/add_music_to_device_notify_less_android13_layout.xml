<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-2"
    layout_marginTop="8dp"
    layout_marginBottom="8dp"
    paddingStart="12dp"
    paddingEnd="16dp">
    <LinearLayout
        orientation="0"
        layout_width="-1"
        layout_height="-2"
        minHeight="20dp">
        <ImageView
            layout_width="18dp"
            layout_height="18dp"
            src="@mipmap/_2131820837_res_0x7f110125"/>
        <TextView
            textSize="12sp"
            textColor="@color/_2131298206_res_0x7f09079e"
            layout_width="-2"
            layout_height="-2"
            text="@string/IDS_app_name_health"
            layout_marginStart="8dp"/>
    </LinearLayout>
    <LinearLayout
        orientation="0"
        layout_width="-1"
        layout_height="-2"
        layout_marginTop="2dp">
        <TextView
            textAppearance="@android:style/TextAppearance.Material.Notification.Info"
            ellipsize="3"
            id="@+id/adding_to_watch_tv"
            layout_width="0dp"
            layout_height="-2"
            singleLine="true"
            layout_weight="1"
            layout_alignParentStart="true"/>
        <TextView
            textAppearance="@android:style/TextAppearance.Material.Notification.Info"
            id="@+id/total_progress_tv"
            layout_width="-2"
            layout_height="-2"
            text="1/2"
            layout_marginStart="8dp"
            layout_alignParentEnd="true"/>
    </LinearLayout>
    <ProgressBar
        id="@+id/transfer_music_progress_bar"
        layout_width="-1"
        layout_height="2dp"
        layout_marginTop="12dp"
        layout_marginBottom="24dp"
        max="100"
        progress="0"
        progressDrawable="@drawable/_2131431310_res_0x7f0b0f8e"
        style="@style/Health.CommonUI.HealthProgressBar.Horizontal"/>
</LinearLayout>
