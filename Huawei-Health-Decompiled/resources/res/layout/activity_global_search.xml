<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    layout_height="-1">
    <View
        id="@+id/statusbar_panel"
        layout_width="-1"
        layout_height="-2"
        layout_alignParentTop="true"/>
    <RelativeLayout
        id="@+id/global_search_layout"
        layout_width="-1"
        layout_height="-2"
        layout_below="@+id/statusbar_panel"
        layout_marginStart="@dimen/_2131363021_res_0x7f0a04cd"
        layout_marginEnd="@dimen/_2131363021_res_0x7f0a04cd">
        <ImageView
            id="@+id/global_search_back"
            layout_width="-2"
            layout_height="-2"
            src="@drawable/_2131428608_res_0x7f0b0500"
            layout_centerVertical="true"
            contentDescription="@string/_2130848058_res_0x7f02293a"
            layout_marginEnd="@dimen/_2131363172_res_0x7f0a0564"
            layout_alignParentStart="true"
            style="@style/health_default_img_tint"/>
        <com.huawei.ui.commonui.searchview.HealthSearchView
            ellipsize="4"
            id="@+id/global_search_view"
            focusable="true"
            layout_width="-1"
            layout_height="-2"
            minHeight="@dimen/_2131363601_res_0x7f0a0711"
            layout_centerVertical="true"
            layout_toStartOf="@+id/global_search_button"
            layout_toEndOf="@+id/global_search_back"
            NOT_FOUND_0x17="@layout/hwsearchview_icon_hint_search_view"
            style="@style/Health.CommonUI.HealthSearchView.White"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131362970_res_0x7f0a049a"
            textColor="@color/_2131296661_res_0x7f090195"
            id="@+id/global_search_button"
            layout_width="-2"
            layout_height="-2"
            text="@string/_2130847656_res_0x7f0227a8"
            layout_centerVertical="true"
            fontFamily="@string/_2130852833_res_0x7f023be1"
            layout_marginStart="@dimen/_2131363172_res_0x7f0a0564"
            layout_alignParentEnd="true"/>
    </RelativeLayout>
    <FrameLayout
        layout_width="-1"
        layout_height="-1"
        layout_below="@+id/global_search_layout">
        <LinearLayout
            orientation="1"
            id="@+id/superui_fragment_container"
            layout_width="-1"
            layout_height="-1"/>
        <com.huawei.ui.commonui.recycleview.HealthRecycleView
            id="@+id/search_suggest_recycler_view"
            visibility="2"
            layout_width="-1"
            layout_height="-2"/>
    </FrameLayout>
</RelativeLayout>
