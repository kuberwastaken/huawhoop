<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-1">
    <include layout="@layout/mtrl_calendar_month_navigation"/>
    <FrameLayout
        id="@+id/mtrl_calendar_selection_frame"
        layout_width="-1"
        layout_height="-1">
        <androidx.recyclerview.widget.RecyclerView
            layout_gravity="0x1"
            id="@+id/mtrl_calendar_year_selector_frame"
            scrollbars="0x0"
            layout_width="-2"
            layout_height="-1"/>
        <LinearLayout
            orientation="1"
            id="@+id/mtrl_calendar_day_selector_frame"
            layout_width="-2"
            layout_height="-1">
            <include layout="@layout/mtrl_calendar_days_of_week"/>
            <include layout="@layout/mtrl_calendar_months"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
