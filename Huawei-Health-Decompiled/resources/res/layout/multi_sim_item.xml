                layout_height="-2"
                fontFamily="@string/_2130852834_res_0x7f023be2"
                textDirection="5"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                textColor="@color/_2131299850_res_0x7f090e0a"
                layout_gravity="0x10"
                id="@+id/item_phone_number"
                layout_width="-1"
                layout_height="-2"
                layout_marginTop="@dimen/_2131362106_res_0x7f0a013a"
                fontFamily="@string/_2130852834_res_0x7f023be2"
                textDirection="3"
                textAlignment="5"/>
        </LinearLayout>
        <com.huawei.ui.commonui.radiobutton.HealthRadioButton
            id="@+id/item_radio_button"
            focusable="false"
            clickable="false"
            layout_width="-2"
            layout_height="-2"
            layout_centerVertical="true"
            layout_alignParentEnd="true"
            style="@style/health_radio_button_style"/>
    </RelativeLayout>
    <View
        id="@+id/item_display_line"
        background="@drawable/_2131431162_res_0x7f0b0efa"
        layout_width="-1"
        layout_height="@dimen/_2131365306_res_0x7f0a0dba"/>
</LinearLayout>
