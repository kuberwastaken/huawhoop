<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/step_rate_large_scale_layout"
    layout_width="-1"
    layout_height="-2">
    <com.huawei.ui.commonui.healthtextview.HealthTextView
        textSize="15dp"
        textColor="#7f000000"
        gravity="0x10"
        id="@+id/step_rate_info"
        layout_width="-1"
        layout_height="32dp"
        layout_marginTop="12dp"
        text="@string/_2130844415_res_0x7f021aff"
        paddingStart="16dp"
        paddingEnd="16dp"/>
    <RelativeLayout
        id="@+id/step_rate_layout"
        layout_width="-1"
        layout_height="-2"
        layout_marginTop="12dp"
        layout_marginStart="16dp"
        layout_marginEnd="16dp">
        <RelativeLayout
            gravity="0x800003"
            layout_width="-1"
            layout_height="-2"
            layout_toStartOf="@+id/heart_step_center">
            <LinearLayout
                orientation="1"
                layout_width="-2"
                layout_height="-2"
                layout_alignParentStart="true">
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    textSize="13dp"
                    textColor="@color/_2131298226_res_0x7f0907b2"
                    id="@+id/step_avg"
                    layout_width="-2"
                    layout_height="-2"
                    text="@string/_2130839869_res_0x7f02093d"/>
                <RelativeLayout
                    layout_width="-2"
                    layout_height="-2">
                    <com.huawei.ui.commonui.healthtextview.HealthTextView
                        textSize="@dimen/_2131363711_res_0x7f0a077f"
                        textColor="#000000"
                        layout_gravity="0x1"
                        id="@+id/sug_tv_tb_bupinrate"
                        layout_width="-2"
                        layout_height="-2"
                        text="@string/_2130851415_res_0x7f023657"/>
                    <com.huawei.ui.commonui.healthtextview.HealthTextView
                        textSize="@dimen/_2131365484_res_0x7f0a0e6c"
                        textColor="#000000"
                        id="@+id/sug_tv_tb_bupinrate_unit"
                        visibility="2"
                        layout_width="-2"
                        layout_height="-2"
                        text="@string/_2130839882_res_0x7f02094a"
                        layout_alignBaseline="@+id/sug_tv_tb_bupinrate"
                        layout_marginStart="4dp"
                        layout_toEndOf="@+id/sug_tv_tb_bupinrate"/>
                </RelativeLayout>
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            gravity="0x800005"
            layout_width="-1"
            layout_height="-2"
            layout_toEndOf="@+id/heart_step_center">
            <LinearLayout
                orientation="1"
                layout_width="-2"
                layout_height="-2"
                layout_alignParentEnd="true">
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    textSize="13dp"
                    textColor="@color/_2131298226_res_0x7f0907b2"
                    id="@+id/step_max"
                    layout_width="-2"
                    layout_height="-2"
                    text="@string/_2130839868_res_0x7f02093c"/>
                <RelativeLayout
                    layout_width="-2"
                    layout_height="-2">
                    <com.huawei.ui.commonui.healthtextview.HealthTextView
                        textSize="@dimen/_2131363711_res_0x7f0a077f"
                        textColor="#000000"
                        layout_gravity="0x1"
                        id="@+id/sug_tv_tb_bupinbig"
                        layout_width="-2"
                        layout_height="-2"
                        text="@string/_2130851415_res_0x7f023657"/>
                    <com.huawei.ui.commonui.healthtextview.HealthTextView
                        textSize="@dimen/_2131365484_res_0x7f0a0e6c"
                        textColor="#000000"
                        id="@+id/sug_tv_tb_bupinbig_unit"
                        visibility="2"
                        layout_width="-2"
                        layout_height="-2"
                        text="@string/_2130839882_res_0x7f02094a"
                        layout_alignBaseline="@+id/sug_tv_tb_bupinbig"
                        layout_marginStart="4dp"
                        layout_toEndOf="@+id/sug_tv_tb_bupinbig"/>
                </RelativeLayout>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>
    <com.huawei.ui.commonui.healthtextview.HealthTextView
        textSize="@dimen/_2131363695_res_0x7f0a076f"
        textColor="#50000000"
        id="@+id/step_rate_y_unit"
        layout_width="-2"
        layout_height="-2"
        text="@string/_2130839870_res_0x7f02093e"
        layout_marginStart="@dimen/_2131363704_res_0x7f0a0778"/>
    <com.huawei.health.sport.view.SugChart
        id="@+id/sug_sc_j_bupin"
        layout_width="-1"
        layout_height="100dp"
        layout_marginTop="7dp"
        paddingStart="8dp"
        paddingEnd="8dp"
        layout_marginStart="8dp"
        layout_marginEnd="8dp"/>
    <com.huawei.ui.commonui.healthtextview.HealthTextView
        textSize="11dp"
        textColor="#50000000"
        gravity="0x800005"
        id="@+id/step_rate_x_unit"
        layout_width="-1"
        layout_height="-2"
        layout_marginTop="8dp"
        layout_marginBottom="16dp"
        text="@string/_2130842722_res_0x7f021462"
        paddingEnd="8dp"/>
</LinearLayout>
