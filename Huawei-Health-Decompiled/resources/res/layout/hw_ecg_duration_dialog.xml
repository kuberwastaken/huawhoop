<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/settings_gender_view_layout"
    layout_width="-1"
    layout_height="-2"
    baselineAligned="false">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        layout_height="-2"
        layout_weight="1">
        <RelativeLayout
            id="@+id/settings_close_ecg_duration"
            layout_width="-1"
            layout_height="48dp">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                id="@+id/settings_close_ecg_text"
                layout_centerVertical="true"
                style="@style/list_text_title_primary"/>
            <com.huawei.ui.commonui.radiobutton.HealthRadioButton
                id="@+id/settings_close_ecg_button"
                focusable="false"
                clickable="false"
                layout_width="-2"
                layout_height="-2"
                layout_centerVertical="true"
                layout_alignParentEnd="true"
                style="@style/health_radio_button_style"/>
        </RelativeLayout>
        <com.huawei.ui.commonui.divider.HealthDivider
            id="@+id/gender_picker_divide_line2"
            layout_width="-2"
            layout_height="-2"/>
        <RelativeLayout
            id="@+id/settings_open_ecg_duration"
            layout_width="-1"
            layout_height="48dp">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                id="@+id/settings_open_ecg_text"
                layout_centerVertical="true"
                style="@style/list_text_title_primary"/>
            <com.huawei.ui.commonui.radiobutton.HealthRadioButton
                id="@+id/settings_open_ecg_button"
                focusable="false"
                clickable="false"
                layout_width="-2"
                layout_height="-2"
                layout_centerVertical="true"
                layout_alignParentEnd="true"
                style="@style/health_radio_button_style"/>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>
