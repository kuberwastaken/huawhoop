<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    layout_height="-1">
    <View
        id="@+id/statusbar_panel_view"
        layout_width="-1"
        layout_height="-2"/>
    <RelativeLayout
        id="@+id/tab_layout"
        layout_width="-1"
        layout_height="-2"
        layout_below="@+id/statusbar_panel_view"
        animateLayoutChanges="true">
        <LinearLayout
            orientation="1"
            id="@+id/sport_tab_titlebar"
            layout_width="-1"
            layout_height="-2"
            layout_marginStart="@dimen/_2131362013_res_0x7f0a00dd"
            layout_toStartOf="@+id/sport_search_icon">
            <ViewStub
                id="@+id/viewstub_tablayout"
                layout="@layout/layout_entrance_tablayout"
                layout_width="-1"
                layout_height="-2"/>
            <ViewStub
                id="@+id/viewstub_tahiti_tablayout"
                layout="@layout/layout_tahiti_tablayout"
                layout_width="-1"
                layout_height="-2"/>
        </LinearLayout>
        <ImageView
            id="@+id/sport_search_icon"
            background="@drawable/_2131428958_res_0x7f0b065e"
            visibility="2"
            layout_width="-2"
            layout_height="@dimen/_2131363109_res_0x7f0a0525"
            src="@drawable/_2131431795_res_0x7f0b1173"
            layout_centerVertical="true"
            contentDescription="@string/_2130848053_res_0x7f022935"
            paddingStart="@dimen/_2131363964_res_0x7f0a087c"
            paddingEnd="@dimen/_2131363964_res_0x7f0a087c"
            layout_toStartOf="@+id/more_and_red_point"
            style="@style/health_default_img_tint"/>
        <com.huawei.ui.commonui.view.RedPointImageView
            id="@+id/more_and_red_point"
            background="@drawable/_2131428958_res_0x7f0b065e"
            visibility="1"
            layout_width="-2"
            layout_height="@dimen/_2131363965_res_0x7f0a087d"
            src="@drawable/_2131429925_res_0x7f0b0a25"
            layout_centerVertical="true"
            contentDescription="@string/_2130848066_res_0x7f022942"
            paddingStart="@dimen/_2131363964_res_0x7f0a087c"
            paddingEnd="@dimen/_2131363964_res_0x7f0a087c"
            layout_marginEnd="@dimen/_2131362371_res_0x7f0a0243"
            layout_alignParentEnd="true"
            style="@style/health_default_img_tint"/>
    </RelativeLayout>
    <com.huawei.ui.commonui.searchview.HealthSearchView
        ellipsize="4"
        gravity="0x10"
        id="@+id/sport_global_search_view"
        layout_width="-1"
        layout_height="-2"
        minHeight="@dimen/_2131362594_res_0x7f0a0322"
        layout_below="@+id/tab_layout"
        layout_marginStart="@dimen/_2131362013_res_0x7f0a00dd"
        layout_marginEnd="@dimen/_2131362011_res_0x7f0a00db"
        NOT_FOUND_0x16="@layout/hwsearchview_icon_hint_search_view"
        style="@style/Health.CommonUI.HealthSearchView.White"/>
    <RelativeLayout
        id="@+id/sport_viewPager_container"
        layout_width="-1"
        layout_height="-1"
        layout_below="@+id/sport_global_search_view">
        <RelativeLayout
            orientation="1"
            id="@+id/map_layout_container"
            layout_width="-1"
            layout_height="-1"/>
        <com.huawei.ui.commonui.viewpager.HealthNativeViewPager
            id="@+id/viewPager_sport"
            clickable="false"
            layout_width="-1"
            layout_height="-2"
            layout_below="@+id/viewstub_aw70_connect_tips"
            NOT_FOUND_0x17="100"/>
        <ViewStub
            id="@+id/viewstub_aw70_connect_tips"
            layout="@layout/aw70_connect_tips"
            layout_width="-1"
            layout_height="-2"/>
    </RelativeLayout>
    <LinearLayout
        orientation="1"
        id="@+id/sport_help_layout"
        visibility="2"
        clickable="true"
        layout_width="-1"
        layout_height="-1"/>
    <include
        id="@+id/more_sport_window"
        visibility="2"
        layout="@layout/more_sport_layout"/>
</RelativeLayout>
