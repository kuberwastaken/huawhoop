<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    id="@+id/scan_title_landscape"
    visibility="2"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        id="@+id/back_layout_landscape"
        background="@drawable/_2131431770_res_0x7f0b115a"
        layout_width="48dp"
        layout_height="48dp"
        layout_marginTop="4dp"
        layout_marginBottom="4dp"
        layout_marginStart="12dp"
        layout_alignParentStart="true">
        <ImageView
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/scankit_back_img_in_land"
            clickable="true"
            layout_width="24dp"
            layout_height="24dp"
            layout_margin="12dp"
            src="@drawable/_2131431782_res_0x7f0b1166"
            contentDescription="@string/_2130852743_res_0x7f023b87"
            layout_alignParentStart="true"/>
    </LinearLayout>
    <LinearLayout
        id="@+id/gallery_Layout_landscape"
        background="@drawable/_2131431770_res_0x7f0b115a"
        layout_width="48dp"
        layout_height="48dp"
        layout_marginTop="4dp"
        layout_marginBottom="4dp"
        layout_marginEnd="12dp"
        layout_alignParentEnd="true">
        <ImageView
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/scankit_img_btn_in_land"
            clickable="true"
            layout_width="24dp"
            layout_height="24dp"
            layout_margin="12dp"
            src="@drawable/_2131431786_res_0x7f0b116a"
            contentDescription="@string/_2130852744_res_0x7f023b88"
            layout_alignParentEnd="true"/>
    </LinearLayout>
    <TextView
        textSize="18sp"
        textColor="#ffffff"
        gravity="0x11"
        id="@+id/scankit_title_scan_land"
        layout_width="-1"
        layout_height="-2"
        layout_marginTop="16dp"
        layout_marginBottom="4dp"
        text="@string/_2130852746_res_0x7f023b8a"
        shadowColor="#4d000000"
        shadowRadius="4"
        layout_weight="1"
        layout_centerHorizontal="true"
        textAllCaps="false"
        fontFamily="sans-serif-medium"
        layout_marginStart="68dp"
        layout_marginEnd="68dp"/>
    <TextView
        textSize="14sp"
        textStyle="0x0"
        textColor="#99ffffff"
        gravity="0x1"
        id="@+id/scankit_title_scan_land_level_two"
        layout_width="-1"
        layout_height="-2"
        layout_marginTop="4dp"
        text="@string/_2130852747_res_0x7f023b8b"
        shadowColor="#4d000000"
        shadowRadius="4"
        layout_below="@+id/scankit_title_scan_land"
        layout_centerHorizontal="true"
        textAllCaps="false"
        layout_marginStart="68dp"
        layout_marginEnd="68dp"/>
</RelativeLayout>
