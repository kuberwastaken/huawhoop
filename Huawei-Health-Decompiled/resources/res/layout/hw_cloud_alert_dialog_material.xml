<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x800033"
    orientation="1"
    id="@+id/parentPanel"
    background="@drawable/_2131428826_res_0x7f0b05da"
    layout_width="-1"
    layout_height="-2">
    <include layout="@layout/hw_cloud_alert_dialog_title_material"/>
    <FrameLayout
        id="@+id/contentPanel"
        layout_width="-1"
        layout_height="0dp"
        layout_weight="1">
        <View
            layout_gravity="0x30"
            id="@+id/scrollIndicatorUp"
            visibility="2"
            layout_width="-1"
            layout_height="1dp"/>
        <ScrollView
            id="@+id/scrollView"
            clipToPadding="false"
            layout_width="-1"
            layout_height="-2">
            <LinearLayout
                orientation="1"
                layout_width="-1"
                layout_height="-2">
                <android.widget.Space
                    id="@+id/textSpacerNoTitle"
                    visibility="2"
                    layout_width="-1"
                    layout_height="@dimen/hw_cloud_dialog_space_dimen"/>
                <TextView
                    id="@android:id/message"
                    paddingLeft="@dimen/hw_cloud_dialog_title_left_padding"
                    paddingRight="@dimen/hw_cloud_dialog_title_right_padding"
                    layout_width="-1"
                    layout_height="-2"
                    style="@style/HwCloudAlertDialogMessage"/>
                <android.widget.Space
                    id="@+id/textSpacerNoButtons"
                    visibility="2"
                    layout_width="-1"
                    layout_height="@dimen/hw_cloud_dialog_space_dimen"/>
            </LinearLayout>
        </ScrollView>
        <View
            layout_gravity="0x50"
            id="@+id/scrollIndicatorDown"
            visibility="2"
            layout_width="-1"
            layout_height="1dp"/>
    </FrameLayout>
    <FrameLayout
        id="@+id/customPanel"
        layout_width="-1"
        layout_height="0dp"
        layout_marginBottom="10dp"
        minHeight="48dp"
        layout_weight="1">
        <FrameLayout
            id="@+id/custom"
            layout_width="-1"
            layout_height="-2"/>
    </FrameLayout>
    <include
        layout_width="-1"
        layout_height="-2"
        layout_marginTop="8dp"
        layout="@layout/hw_cloud_alert_dialog_button_bar_material"/>
</LinearLayout>
