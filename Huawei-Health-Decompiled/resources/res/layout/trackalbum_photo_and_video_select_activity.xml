<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-1">
    <LinearLayout
        orientation="1"
        id="@+id/image_select_content"
        layout_width="-1"
        layout_height="-1">
        <include
            id="@+id/image_select_title_bar"
            layout_width="-2"
            layout_height="-2"
            layout="@layout/trackalbum_image_select_title"/>
        <com.huawei.ui.commonui.subtab.HealthSubTabWidget
            id="@+id/photo_and_video_tab"
            layout_width="-1"
            layout_height="-2"
            style="@style/health_sub_tab_style"/>
        <com.huawei.ui.commonui.viewpager.HealthViewPager
            id="@+id/photo_and_video_viewpager"
            persistentDrawingCache="0x1"
            layout_width="-1"
            layout_height="-1"
            flipInterval="30"
            layout_weight="1"
            layout_alignParentBottom="true"
            layout_alignParentStart="true"/>
    </LinearLayout>
</LinearLayout>
