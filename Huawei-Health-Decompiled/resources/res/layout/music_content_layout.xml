<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    id="@+id/music_control_and_content"
    background="@drawable/music_content_background"
    layout_width="-2"
    layout_height="48dp"
    layout_alignParentEnd="true">
    <ImageView
        id="@+id/music_element"
        layout_width="40dp"
        layout_height="40dp"
        src="@drawable/_2131431308_res_0x7f0b0f8c"
        scaleType="6"
        layout_centerVertical="true"
        layout_marginStart="4dp"
        layout_alignParentStart="true"/>
    <com.huawei.ui.commonui.healthtextview.HealthTextView
        textSize="@dimen/_2131365483_res_0x7f0a0e6b"
        textColor="@color/_2131299845_res_0x7f090e05"
        gravity="0x11"
        id="@+id/music_content"
        visibility="2"
        layout_width="-2"
        layout_height="-2"
        maxWidth="102dp"
        maxLines="1"
        layout_centerVertical="true"
        fontFamily="@string/_2130852834_res_0x7f023be2"
        layout_marginStart="6dp"
        layout_marginEnd="8dp"
        layout_toStartOf="@+id/music_collect"
        layout_toEndOf="@+id/music_element"
        NOT_FOUND_0x14="true"/>
    <ImageView
        id="@+id/music_collect"
        visibility="2"
        layout_width="-2"
        layout_height="-2"
        src="@drawable/_2131430972_res_0x7f0b0e3c"
        layout_centerVertical="true"
        layout_marginEnd="8dp"
        layout_toStartOf="@+id/music_previous"/>
    <ImageView
        id="@+id/music_previous"
        visibility="2"
        layout_width="-2"
        layout_height="-2"
        src="@drawable/_2131431520_res_0x7f0b1060"
        layout_centerVertical="true"
        layout_marginEnd="8dp"
        layout_toStartOf="@+id/play_or_pause"/>
    <ImageView
        id="@+id/play_or_pause"
        visibility="2"
        layout_width="-2"
        layout_height="-2"
        src="@drawable/_2131431377_res_0x7f0b0fd1"
        layout_centerVertical="true"
        layout_marginEnd="8dp"
        layout_toStartOf="@+id/music_next"/>
    <ImageView
        id="@+id/music_next"
        layout_width="-2"
        layout_height="-2"
        src="@drawable/_2131431318_res_0x7f0b0f96"
        layout_centerVertical="true"
        layout_marginEnd="8dp"
        layout_toStartOf="@+id/music_cancel"/>
    <ImageView
        id="@+id/music_cancel"
        visibility="1"
        layout_width="-2"
        layout_height="-2"
        layout_centerVertical="true"
        layout_marginEnd="8dp"
        layout_alignParentEnd="true"/>
</RelativeLayout>
