<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        orientation="0"
        layout_width="-1"
        layout_height="-2"
        layout_marginBottom="2dp">
        <TextView
            textAppearance="@android:style/TextAppearance.Material.Notification.Title"
            ellipsize="3"
            id="@+id/adding_to_watch_tv"
            layout_width="0dp"
            layout_height="-2"
            singleLine="true"
            layout_weight="1"
            layout_alignParentStart="true"/>
        <TextView
            textAppearance="@android:style/TextAppearance.Material.Notification.Title"
            id="@+id/total_progress_tv"
            layout_width="-2"
            layout_height="-2"
            text="1/2"
            layout_marginStart="8dp"
            layout_alignParentEnd="true"/>
    </LinearLayout>
    <ProgressBar
        id="@+id/transfer_music_progress_bar"
        layout_width="-1"
        layout_height="@dimen/_2131363112_res_0x7f0a0528"
        layout_marginTop="10dp"
        layout_marginBottom="10dp"
        max="100"
        progress="0"
        progressDrawable="@drawable/_2131431310_res_0x7f0b0f8e"
        style="@style/Health.CommonUI.HealthProgressBar.Horizontal"/>
</LinearLayout>
