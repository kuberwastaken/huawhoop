<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    background="@drawable/_2131427891_res_0x7f0b0233"
    layout_width="-1"
    layout_height="-2"
    minHeight="98dp"
    paddingStart="@dimen/_2131364901_res_0x7f0a0c25"
    paddingEnd="@dimen/_2131364900_res_0x7f0a0c24">
    <RelativeLayout
        id="@+id/select_device_icon_layout"
        background="@drawable/add_device_child_image_bg"
        layout_width="82dp"
        layout_height="82dp"
        layout_centerVertical="true">
        <ImageView
            id="@+id/select_device_icon"
            layout_width="72dp"
            layout_height="72dp"
            layout_centerInParent="true"/>
    </RelativeLayout>
    <RelativeLayout
        layout_gravity="0x10"
        id="@+id/more_about_band_info"
        layout_width="-1"
        layout_height="-2"
        layout_centerVertical="true"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"
        layout_toStartOf="@+id/rightarrow_icon"
        layout_toEndOf="@+id/select_device_icon_layout">
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365482_res_0x7f0a0e6a"
            textColor="@color/_2131299845_res_0x7f090e05"
            ellipsize="3"
            id="@+id/select_device_content"
            layout_width="-2"
            layout_height="-2"
            singleLine="false"
            fontFamily="@string/_2130852834_res_0x7f023be2"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365483_res_0x7f0a0e6b"
            textColor="@color/_2131299850_res_0x7f090e0a"
            gravity="0x800003"
            id="@+id/select_device_summary"
            layout_width="-2"
            layout_height="-2"
            layout_marginTop="2dp"
            layout_below="@+id/select_device_content"
            lineSpacingExtra="@dimen/_2131364845_res_0x7f0a0bed"
            fontFamily="@string/_2130852834_res_0x7f023be2"/>
    </RelativeLayout>
    <ImageView
        id="@+id/rightarrow_icon"
        layout_width="12dp"
        layout_height="24dp"
        layout_centerVertical="true"
        layout_alignParentEnd="true"
        style="@style/health_default_img_tint"/>
    <View
        id="@+id/select_device_summary_line"
        background="@color/_2131297380_res_0x7f090464"
        layout_width="-1"
        layout_height="1px"
        layout_alignParentBottom="true"
        layout_marginStart="98dp"/>
</RelativeLayout>
