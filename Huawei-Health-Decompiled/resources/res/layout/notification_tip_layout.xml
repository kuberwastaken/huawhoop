<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/notification_tip"
    background="@color/_2131297897_res_0x7f090669"
    layout_width="-1"
    layout_height="-1">
    <RelativeLayout
        layout_width="-1"
        layout_height="-2"
        layout_centerInParent="true">
        <RelativeLayout
            gravity="0x10"
            id="@+id/notification_tip_relativeLayout"
            background="@drawable/_2131431342_res_0x7f0b0fae"
            layout_width="-1"
            layout_height="50dp"
            layout_marginStart="24dp"
            layout_marginEnd="24dp">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="15dp"
                textColor="@color/_2131296965_res_0x7f0902c5"
                gravity="0x10"
                id="@+id/notification_push_open_app"
                layout_width="-2"
                layout_height="-1"
                text="@string/IDS_app_name_health"
                layout_marginStart="12dp"/>
            <com.huawei.ui.commonui.switchbutton.HealthSwitchButton
                id="@+id/switch_button_notification"
                focusable="false"
                clickable="false"
                layout_width="-2"
                layout_height="-2"
                checked="false"
                layout_centerVertical="true"
                layout_alignParentEnd="true"
                style="@style/health_switch_style"/>
        </RelativeLayout>
        <ImageView
            background="@mipmap/_2131821552_res_0x7f1103f0"
            layout_width="117dp"
            layout_height="128dp"
            layout_marginTop="18dp"
            layout_alignParentEnd="true"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365501_res_0x7f0a0e7d"
            textColor="@color/_2131296950_res_0x7f0902b6"
            gravity="0x800003"
            layout_gravity="0x10"
            id="@+id/notification_push_open_prompt"
            layout_width="-2"
            layout_height="-2"
            layout_marginTop="8dp"
            text="@string/IDS_device_notification_mengban_text"
            layout_below="@+id/notification_tip_relativeLayout"
            layout_marginStart="24dp"
            layout_marginEnd="96dp"/>
    </RelativeLayout>
</RelativeLayout>
