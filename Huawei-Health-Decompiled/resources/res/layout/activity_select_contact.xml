<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:setting="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@color/_2131296667_res_0x7f09019b"
    layout_width="-1"
    layout_height="-1">
    <com.huawei.ui.commonui.titlebar.CustomTitleBar
        id="@+id/contant_select_titlebar"
        layout_width="-1"
        layout_height="-2"
        NOT_FOUND_0x16="1"
        NOT_FOUND_0x18="0"
        NOT_FOUND_0x19="@string/IDS_device_wifi_selectNone"/>
    <include
        id="@+id/search_layout"
        visibility="2"
        layout_marginTop="5dp"
        layout="@layout/contact_search_bar_layout"/>
    <RelativeLayout
        id="@+id/rela_info"
        visibility="2"
        layout_width="-1"
        layout_height="-1">
        <LinearLayout
            gravity="0x11"
            orientation="1"
            id="@+id/lin_no_data"
            visibility="2"
            layout_width="-2"
            layout_height="-2"
            layout_centerInParent="true">
            <ImageView
                layout_width="-2"
                layout_height="-2"
                src="@drawable/_2131430469_res_0x7f0b0c45"
                style="@style/health_default_img_tint"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                textColor="@color/_2131299850_res_0x7f090e0a"
                layout_width="-2"
                layout_height="-2"
                layout_marginTop="4.5dp"
                text="@string/_2130844205_res_0x7f021a2d"
                fontFamily="@string/_2130852834_res_0x7f023be2"/>
        </LinearLayout>
        <ListView
            id="@+id/hw_contact_select_list"
            scrollbars="0x0"
            layout_width="-1"
            layout_height="-1"
            divider="@null"
            fillViewport="true"
            layout_above="@+id/bottom_operate_toolbar"
            layout_marginEnd="@dimen/_2131362466_res_0x7f0a02a2"/>
        <com.huawei.ui.device.views.music.AlphabetIndexWaveSideBarView
            id="@+id/bar_list"
            layout_width="-1"
            layout_height="-1"
            layout_above="@+id/bottom_operate_toolbar"
            layout_centerVertical="true"
            layout_alignParentEnd="true"
            NOT_FOUND_0x17="true"/>
        <com.huawei.ui.commonui.toolbar.HealthToolBar
            gravity="0x1"
            orientation="1"
            id="@+id/bottom_operate_toolbar"
            layout_width="-1"
            layout_height="-2"
            layout_marginTop="8dp"
            layout_alignParentBottom="true"/>
    </RelativeLayout>
    <RelativeLayout
        id="@+id/load_progress"
        visibility="0"
        layout_width="-1"
        layout_height="-1">
        <include layout="@layout/common_loading_layout"/>
    </RelativeLayout>
</LinearLayout>
