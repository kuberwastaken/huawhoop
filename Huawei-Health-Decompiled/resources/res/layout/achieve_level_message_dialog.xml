<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/achieve_level_message_dialog"
    background="@color/_2131298143_res_0x7f09075f"
    layout_width="-1"
    layout_height="-1">
    <RelativeLayout
        id="@+id/achieve_level_dialog_view"
        layout_width="-2"
        layout_height="-2"
        layout_marginTop="@dimen/_2131363536_res_0x7f0a06d0"
        layout_marginEnd="@dimen/_2131363516_res_0x7f0a06bc">
        <ImageView
            id="@+id/achieve_level_dialog_title_ImageView"
            layout_width="@dimen/_2131363523_res_0x7f0a06c3"
            layout_height="@dimen/_2131363523_res_0x7f0a06c3"
            src="@drawable/_2131430471_res_0x7f0b0c47"
            contentDescription="@string/_2130848057_res_0x7f022939"
            layout_alignParentEnd="true"/>
    </RelativeLayout>
    <com.huawei.ui.commonui.healthtextview.HealthTextView
        textSize="@dimen/_2131363508_res_0x7f0a06b4"
        textColor="#ffffffff"
        id="@+id/achieve_level_dialog_date"
        layout_width="-2"
        layout_height="-2"
        layout_marginTop="@dimen/_2131363543_res_0x7f0a06d7"
