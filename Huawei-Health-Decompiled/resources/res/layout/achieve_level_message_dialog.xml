        gravity="0x11"
        orientation="0"
        layout_width="-1"
        layout_height="-2"
        layout_marginBottom="@dimen/_2131363561_res_0x7f0a06e9"
        weightSum="1"
        layout_alignParentBottom="true"
        layout_centerHorizontal="true">
        <com.huawei.ui.commonui.button.HealthButton
            gravity="0x11"
            id="@+id/achieve_level_dialog_share_button"
            layout_width="0dp"
            layout_height="-2"
            text="@string/_2130840953_res_0x7f020d79"
            layout_weight="0.5"
            style="@style/health_button_style_emphasize"/>
    </LinearLayout>
    <include layout="@layout/achieve_level_share_layout"/>
