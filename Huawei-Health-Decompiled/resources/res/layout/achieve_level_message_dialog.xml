        layout_below="@+id/achieve_level_dialog_view"
        layout_centerHorizontal="true"/>
    <RelativeLayout
        id="@+id/achieve_level_dialog_iv"
        background="@drawable/_2131427476_res_0x7f0b0094"
        layout_width="234dp"
        layout_height="234dp"
        layout_marginTop="@dimen/_2131363516_res_0x7f0a06bc"
        layout_below="@+id/achieve_level_dialog_date"
        layout_centerHorizontal="true">
        <RelativeLayout
            orientation="1"
            id="@+id/achieve_level_dialog_shine"
            background="@drawable/_2131427475_res_0x7f0b0093"
            layout_width="234dp"
            layout_height="202dp"
            layout_centerInParent="true"/>
    </RelativeLayout>
    <ImageView
        layout_gravity="0x11"
        id="@+id/achieve_level_animation_up_before"
        layout_width="202dp"
        layout_height="202dp"
        layout_marginTop="@dimen/_2131363534_res_0x7f0a06ce"
        layout_below="@+id/achieve_level_dialog_date"
        layout_centerHorizontal="true"/>
    <ImageView
        layout_gravity="0x11"
        id="@+id/achieve_level_animation_up_after"
        layout_width="202dp"
        layout_height="202dp"
        layout_marginTop="@dimen/_2131363534_res_0x7f0a06ce"
        layout_below="@+id/achieve_level_dialog_date"
        layout_centerHorizontal="true"/>
