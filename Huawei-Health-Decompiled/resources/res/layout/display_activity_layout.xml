<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:setting="http://schemas.android.com/apk/res-auto"
    background="#000000"
    fitsSystemWindows="true"
    layout_width="-1"
    layout_height="-1">
    <RelativeLayout
        id="@+id/count_down_view"
        background="@drawable/gradient_background"
        visibility="2"
        layout_width="-1"
        layout_height="-1">
        <ImageView
            id="@+id/track_conut_down_num_round"
            visibility="2"
            layout_width="490px"
            layout_height="490px"
            src="@drawable/_2131432413_res_0x7f0b13dd"
            layout_centerInParent="true"/>
        <ImageView
            id="@+id/track_conut_down_num"
            visibility="2"
            layout_width="450px"
            layout_height="450px"
            layout_centerInParent="true"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="500px"
            textColor="@color/_2131300016_res_0x7f090eb0"
            id="@+id/track_conut_down_num_text"
            visibility="2"
            layout_width="-2"
            layout_height="-2"
            layout_centerInParent="true"/>
    </RelativeLayout>
    <ImageView
        id="@+id/runwayBackground"
        background="@drawable/_2131431761_res_0x7f0b1151"
        visibility="0"
        layout_width="-1"
        layout_height="-2"
        layout_alignParentBottom="true"/>
    <ImageView
        id="@+id/runway"
        background="@drawable/_2131431762_res_0x7f0b1152"
        layout_width="-1"
        layout_height="-2"
        layout_alignParentBottom="true"/>
    <LinearLayout
        orientation="1"
        id="@+id/linearlayout_display"
        layout_width="-1"
        layout_height="-1">
        <com.huawei.ui.commonui.viewpager.HealthViewPager
            id="@+id/mViewPager"
            layout_width="-1"
            layout_height="@dimen/_2131362907_res_0x7f0a045b"
            layout_weight="3"/>
        <RelativeLayout
            id="@+id/bottom_layout"
            layout_width="-1"
            layout_height="@dimen/_2131362907_res_0x7f0a045b"
            layout_weight="1">
            <LinearLayout
                layout_gravity="0x1"
                orientation="0"
                id="@+id/dots_layout"
                layout_width="-2"
                layout_height="-2"
                layout_marginTop="@dimen/_2131363021_res_0x7f0a04cd"
                layout_centerHorizontal="true"/>
            <com.huawei.ui.commonui.columnlayout.HealthColumnRelativeLayout
                id="@+id/btn_layout"
                layout_width="-1"
                layout_height="-2"
                layout_marginTop="@dimen/_2131363002_res_0x7f0a04ba"
                layout_below="@+id/dots_layout"
                layout_centerHorizontal="true"
                NOT_FOUND_0x14="0">
                <ImageView
                    id="@+id/horizontal_screen"
                    layout_width="-2"
                    layout_height="-2"
                    src="@drawable/_2131430640_res_0x7f0b0cf0"
                    layout_centerVertical="true"/>
                <LinearLayout
                    id="@+id/control_button_linearlayout"
                    layout_width="-2"
                    layout_height="-2"
                    layout_centerInParent="true">
                    <com.huawei.health.basesport.controls.ControlButtonLayout
                        id="@+id/control_button"
                        layout_width="-2"
                        layout_height="@dimen/_2131362910_res_0x7f0a045e"
                        layout_marginTop="@dimen/_2131362916_res_0x7f0a0464"
                        layout_marginEnd="@dimen/_2131362962_res_0x7f0a0492"/>
                </LinearLayout>
                <com.huawei.indoorequip.ui.CircleProgressButtonForIndoorEquip
                    id="@+id/track_main_page_btn_stop"
                    layout_width="76.5dp"
                    layout_height="76.5dp"
                    layout_centerInParent="true"/>
                <ImageView
                    id="@+id/voice_image"
                    layout_width="-2"
                    layout_height="-2"
                    src="@drawable/_2131430652_res_0x7f0b0cfc"
                    layout_centerVertical="true"
                    layout_alignParentEnd="true"/>
            </com.huawei.ui.commonui.columnlayout.HealthColumnRelativeLayout>
        </RelativeLayout>
    </LinearLayout>
</RelativeLayout>
