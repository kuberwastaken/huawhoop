<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    background="@color/_2131296667_res_0x7f09019b"
    layout_width="-1"
    layout_height="-1">
    <include
        id="@+id/title_bar_layout"
        layout="@layout/open_service_title_bar_layout"/>
    <RelativeLayout
        id="@+id/open_service_load"
        visibility="0"
        layout_width="-1"
        layout_height="-1"
        layout_below="@+id/title_bar_layout">
        <include layout="@layout/open_service_load_layout"/>
    </RelativeLayout>
    <RelativeLayout
        orientation="1"
        id="@+id/open_service_ex_layout"
        visibility="2"
        layout_width="-1"
        layout_height="-1">
        <RelativeLayout
            gravity="0x11"
            id="@+id/social_reload_layout"
            layout_width="-2"
            layout_height="-1"
            layout_above="@+id/social_btn_no_net_work_layout">
            <ImageView
                id="@+id/social_img_no_net_work"
                layout_width="-2"
                layout_height="-2"
                src="@drawable/_2131430497_res_0x7f0b0c61"
                layout_centerHorizontal="true"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textColor="@color/_2131298240_res_0x7f0907c0"
                gravity="0x11"
                id="@+id/center_text"
                layout_width="-1"
                layout_height="-2"
                text="@string/_2130842404_res_0x7f021324"
                layout_below="@+id/social_img_no_net_work"
                layout_marginStart="@dimen/_2131363675_res_0x7f0a075b"
                layout_marginEnd="@dimen/_2131363675_res_0x7f0a075b"/>
        </RelativeLayout>
        <LinearLayout
            gravity="0x11"
            id="@+id/social_btn_no_net_work_layout"
            layout_width="-1"
            layout_height="-2"
            layout_marginBottom="@dimen/_2131363675_res_0x7f0a075b"
            weightSum="1"
            layout_alignParentBottom="true">
            <com.huawei.ui.commonui.button.HealthButton
                id="@+id/net_setting_btn"
                layout_width="0dp"
                text="@string/_2130842408_res_0x7f021328"
                layout_weight="0.5"
                style="@style/health_button_style"/>
        </LinearLayout>
    </RelativeLayout>
    <RelativeLayout
        id="@+id/open_service_main"
        visibility="2"
        layout_width="-1"
        layout_height="-1"
        layout_below="@+id/title_bar_layout">
        <include layout="@layout/open_service_main_layout"/>
    </RelativeLayout>
</RelativeLayout>
