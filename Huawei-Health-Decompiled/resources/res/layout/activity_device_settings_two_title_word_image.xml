<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    background="@drawable/device_item_background"
    layout_width="-1"
    layout_height="-2">
    <RelativeLayout
        id="@+id/setting_device_rela"
        layout_width="-2"
        layout_height="-2"
        minHeight="@dimen/_2131362462_res_0x7f0a029e"
        paddingStart="@dimen/_2131364900_res_0x7f0a0c24"
        paddingEnd="@dimen/_2131364900_res_0x7f0a0c24">
        <ImageView
            id="@+id/item_icon"
            layout_width="24dp"
            layout_height="24dp"
            src="@mipmap/_2131820977_res_0x7f1101b1"
            layout_centerVertical="true"
            layout_marginEnd="16dp"
            layout_alignParentStart="true"
            style="@style/health_default_img_tint"/>
        <LinearLayout
            layout_gravity="0x10"
            orientation="1"
            id="@+id/linear_two_title_switch"
            paddingTop="8dp"
            paddingBottom="8dp"
            layout_width="-2"
            layout_height="-2"
            layout_centerVertical="true"
            layout_marginEnd="8dp"
            layout_toStartOf="@+id/right_text"
            layout_toEndOf="@+id/item_icon">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365482_res_0x7f0a0e6a"
                textColor="@color/_2131299845_res_0x7f090e05"
                id="@+id/content"
                text="@string/_2130841844_res_0x7f0210f4"
                fontFamily="@string/_2130852834_res_0x7f023be2"
                style="@style/device_fragment_setting_text_style"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                textColor="@color/_2131299850_res_0x7f090e0a"
                ellipsize="3"
                id="@+id/sub_content"
                paddingTop="2dp"
                layout_width="-2"
                layout_height="-2"
                text="@string/_2130841733_res_0x7f021085"
                singleLine="false"
                layout_below="@+id/content"
                fontFamily="@string/_2130852834_res_0x7f023be2"/>
        </LinearLayout>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365483_res_0x7f0a0e6b"
            textColor="@color/_2131299850_res_0x7f090e0a"
            ellipsize="3"
            gravity="0x800005"
            id="@+id/right_text"
            layout_width="-2"
            layout_height="-2"
            singleLine="false"
            layout_centerVertical="true"
            lineSpacingExtra="3dp"
            fontFamily="@string/_2130852834_res_0x7f023be2"
            layout_marginStart="@dimen/_2131362461_res_0x7f0a029d"
            layout_marginEnd="@dimen/_2131362460_res_0x7f0a029c"
            layout_toStartOf="@+id/settings_switch"/>
        <ImageView
            id="@+id/settings_switch"
            background="@drawable/_2131427877_res_0x7f0b0225"
            layout_width="-2"
            layout_height="-2"
            layout_centerVertical="true"
            layout_alignParentEnd="true"
            style="@style/health_default_background_tint"/>
        <View
            id="@+id/item_line"
            visibility="0"
            style="@style/device_fragment_setting_line_21"/>
    </RelativeLayout>
</RelativeLayout>
