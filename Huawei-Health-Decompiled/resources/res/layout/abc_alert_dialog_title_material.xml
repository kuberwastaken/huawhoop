<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/topPanel"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        gravity="0x800013"
        orientation="0"
        id="@+id/title_template"
        paddingLeft="?attr/_2131100102_res_0x7f0601c6"
        paddingTop="@dimen/_2131361902_res_0x7f0a006e"
        paddingRight="?attr/_2131100102_res_0x7f0601c6"
        layout_width="-1"
        layout_height="-2">
        <ImageView
            id="@android:id/icon"
            layout_width="32dp"
            layout_height="32dp"
            layout_marginRight="8dp"
            src="@null"
            scaleType="3"
            layout_marginEnd="8dp"/>
        <androidx.appcompat.widget.DialogTitle
            ellipsize="3"
            layout_gravity="0x800003"
            id="@+id/alertTitle"
            layout_width="-1"
            layout_height="-2"
            singleLine="true"
            textAlignment="5"
            style="?android:attr/windowTitleStyle"/>
