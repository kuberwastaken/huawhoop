<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    layout_height="-1">
    <include
        layout_width="-1"
        layout_height="-2"
        layout="@layout/common_data_empty"/>
    <com.huawei.ui.commonui.horizontalscrollview.HealthHorizontalScrollView
        layout_gravity="0x11"
        id="@+id/running_route_type_list"
        scrollbars="0x0"
        layout_width="-2"
        layout_height="-2"
        minHeight="@dimen/_2131363090_res_0x7f0a0512">
        <LinearLayout
            orientation="0"
            id="@+id/running_route_type_buttons"
            layout_width="-2"
            layout_height="-1">
            <com.huawei.ui.commonui.spinner.HealthSpinner
                layout_gravity="0x11"
                id="@+id/spinner_sortType"
                visibility="2"
                layout_width="-2"
                layout_height="-1"
                NOT_FOUND_0x9="true"
                style="@style/Health.CommonUI.HealthSpinner"/>
            <com.huawei.ui.commonui.spinner.HealthSpinner
                layout_gravity="0x11"
                id="@+id/spinner_pathType"
                visibility="2"
                layout_width="-2"
                layout_height="-1"
                NOT_FOUND_0x9="true"
                style="@style/Health.CommonUI.HealthSpinner"/>
            <com.huawei.ui.commonui.spinner.HealthSpinner
                layout_gravity="0x11"
                id="@+id/spinner_distance"
                visibility="2"
                layout_width="-2"
                layout_height="-1"
                NOT_FOUND_0x9="true"
                style="@style/Health.CommonUI.HealthSpinner"/>
            <com.huawei.ui.commonui.spinner.HealthSpinner
                layout_gravity="0x11"
                id="@+id/spinner_pathTheme"
                visibility="2"
                layout_width="-2"
                layout_height="-1"
                NOT_FOUND_0x9="true"
                style="@style/Health.CommonUI.HealthSpinner"/>
        </LinearLayout>
    </com.huawei.ui.commonui.horizontalscrollview.HealthHorizontalScrollView>
    <com.huawei.ui.commonui.recycleview.HealthRecycleView
        id="@+id/recyclerView"
        scrollbars="0x200"
        layout_width="-1"
        layout_height="-2"
        fadeScrollbars="true"/>
    <include
        id="@+id/loading_layout"
        visibility="2"
        layout="@layout/sug_loading_layout"/>
</LinearLayout>
