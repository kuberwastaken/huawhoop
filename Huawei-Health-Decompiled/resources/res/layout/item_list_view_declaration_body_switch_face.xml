<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    paddingTop="16dp"
    layout_width="-1"
    layout_height="-2">
    <RelativeLayout
        layout_width="-1"
        layout_height="-2">
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="16sp"
            textColor="@color/_2131299850_res_0x7f090e0a"
            gravity="0x800003"
            id="@+id/text_view_name"
            layout_width="-2"
            layout_height="-2"
            layout_toStartOf="@+id/text_view_switch"
            layout_alignParentStart="true"/>
        <ImageView
            id="@+id/iv_next"
            background="@drawable/_2131427877_res_0x7f0b0225"
            layout_width="-2"
            layout_height="-2"
            layout_centerVertical="true"
            layout_alignParentEnd="true"
            style="@style/health_default_background_tint"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="16sp"
            textColor="@color/_2131299850_res_0x7f090e0a"
            gravity="0x800005"
            id="@+id/text_view_switch"
            layout_width="-2"
            layout_height="-2"
            maxWidth="@dimen/_2131362584_res_0x7f0a0318"
            layout_centerVertical="true"
            layout_marginEnd="16dp"
            layout_toStartOf="@+id/iv_next"
            layout_alignParentEnd="true"/>
    </RelativeLayout>
    <com.huawei.ui.commonui.healthtextview.HealthTextView
        textSize="14sp"
        textColor="@color/_2131299850_res_0x7f090e0a"
        id="@+id/text_view_description"
        layout_width="-2"
        layout_height="-2"/>
</LinearLayout>
