<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/sleep_detail_ext_root_layout"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        orientation="1"
        id="@+id/night_sleep_layout"
        layout_width="-1"
        layout_height="-2"/>
    <com.huawei.ui.commonui.divider.HealthDivider
        id="@+id/night_sleep_layout_divider"
        visibility="2"
        style="@style/section_expand_report_list_divide_line_1"/>
    <LinearLayout
        orientation="1"
        id="@+id/day_sleep_layout"
        layout_width="-1"
        layout_height="-2">
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365483_res_0x7f0a0e6b"
            textColor="@color/_2131299850_res_0x7f090e0a"
            gravity="0x10"
            id="@+id/day_sleep_suggest_title"
            visibility="2"
            layout_width="-1"
            layout_height="-2"
            layout_marginTop="@dimen/_2131363172_res_0x7f0a0564"
            layout_marginBottom="@dimen/_2131362916_res_0x7f0a0464"
            fontFamily="@string/_2130852834_res_0x7f023be2"
            layout_marginStart="@dimen/_2131362934_res_0x7f0a0476"
            layout_marginEnd="@dimen/_2131362934_res_0x7f0a0476"/>
        <com.huawei.ui.commonui.divider.HealthDivider
            id="@+id/day_sleep_suggest_title_bottom_divider"
            visibility="2"
            style="@style/section_expand_report_list_divide_line_1"/>
        <LinearLayout
            orientation="1"
            id="@+id/day_sleep_recyclerview"
            layout_width="-1"
            layout_height="-2"/>
    </LinearLayout>
    <com.huawei.ui.commonui.divider.HealthDivider
        id="@+id/day_sleep_view_divider"
        visibility="2"
        style="@style/section_expand_report_list_divide_line_1"/>
    <LinearLayout
        orientation="1"
        id="@+id/total_sleep_layout"
        layout_width="-1"
        layout_height="-2"/>
    <com.huawei.ui.commonui.divider.HealthDivider
        id="@+id/total_sleep_view_divider"
        visibility="2"
        style="@style/section_expand_report_list_divide_line_1"/>
    <LinearLayout
        orientation="1"
        id="@+id/wake_up_feeling_layout"
        layout_width="-1"
        layout_height="-2"/>
</LinearLayout>
