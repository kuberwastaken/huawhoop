<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    focusable="true"
    focusableInTouchMode="true"
    layout_width="-1"
    layout_height="-1">
    <com.huawei.ui.commonui.scrollview.HealthScrollView
        id="@+id/fragment_social_sroll"
        background="@color/_2131296667_res_0x7f09019b"
        scrollbars="0x0"
        layout_width="-1"
        layout_height="-1"
        fillViewport="true"
        NOT_FOUND_0x20="true"
        NOT_FOUND_0x21="true">
        <FrameLayout
            layout_width="-1"
            layout_height="-1">
            <include
                id="@+id/layout_loading"
                visibility="2"
                layout="@layout/sug_loading_layout"/>
            <RelativeLayout
                orientation="1"
                id="@+id/social_net_work_layout"
                visibility="2"
                layout_width="-1"
                layout_height="-1">
                <RelativeLayout
                    gravity="0x11"
                    id="@+id/social_reload_layout"
                    layout_width="-2"
                    layout_height="-1"
                    layout_above="@+id/social_btn_no_net_work_layout">
                    <ImageView
                        id="@+id/social_img_no_net_work"
                        layout_width="-2"
                        layout_height="-2"
                        src="@drawable/_2131430497_res_0x7f0b0c61"
                        layout_centerHorizontal="true"/>
                    <com.huawei.ui.commonui.healthtextview.HealthTextView
                        textColor="@color/_2131299845_res_0x7f090e05"
                        gravity="0x11"
                        id="@+id/social_tips_no_net_work"
                        layout_width="-1"
                        layout_height="-2"
                        text="@string/_2130842404_res_0x7f021324"
                        layout_below="@+id/social_img_no_net_work"
                        layout_marginStart="@dimen/_2131364901_res_0x7f0a0c25"
                        layout_marginEnd="@dimen/_2131364900_res_0x7f0a0c24"/>
                </RelativeLayout>
                <LinearLayout
                    gravity="0x11"
                    id="@+id/social_btn_no_net_work_layout"
                    layout_width="-1"
                    layout_height="-2"
                    layout_marginBottom="@dimen/_2131363675_res_0x7f0a075b"
                    weightSum="1"
                    layout_above="@+id/social_shop_view">
                    <com.huawei.ui.commonui.button.HealthButton
                        id="@+id/social_btn_no_net_work"
                        layout_width="0dp"
                        text="@string/_2130842408_res_0x7f021328"
                        layout_weight="0.5"
                        style="@style/health_button_style"/>
                </LinearLayout>
                <View
                    id="@+id/social_shop_view"
                    layout_width="-2"
                    layout_height="50dp"
                    layout_alignParentBottom="true"/>
            </RelativeLayout>
            <LinearLayout
                orientation="1"
                id="@+id/social_root_lyt"
                focusable="true"
                focusableInTouchMode="true"
                layout_width="-1"
                layout_height="-2">
                <View
                    layout_width="-1"
                    layout_height="8dp"/>
                <include
                    id="@+id/fragment_social_ad"
                    layout="@layout/common_top_banner"/>
                <LinearLayout
                    orientation="1"
                    id="@+id/fragment_social_content"
                    layout_width="-1"
                    layout_height="-2">
                    <include
                        id="@+id/fragment_item"
                        layout="@layout/item_social_pie_layout"/>
                    <LinearLayout
                        gravity="0x1"
                        layout_gravity="0x1"
                        orientation="1"
                        id="@+id/social_message_container"
                        layout_width="-1"
                        layout_height="-2"/>
                    <LinearLayout
                        orientation="1"
                        id="@+id/social_activity_container"
                        layout_width="-1"
                        layout_height="-2">
                        <RelativeLayout
                            id="@+id/social_activity_title"
                            paddingBottom="8dp"
                            layout_width="-1"
                            layout_height="@dimen/_2131363825_res_0x7f0a07f1"
                            layout_marginTop="@dimen/_2131363820_res_0x7f0a07ec"
                            layout_marginStart="@dimen/_2131364901_res_0x7f0a0c25"
                            layout_marginEnd="@dimen/_2131364900_res_0x7f0a0c24">
                            <com.huawei.ui.commonui.healthtextview.HealthTextView
                                textSize="@dimen/_2131365500_res_0x7f0a0e7c"
                                textColor="@color/_2131299845_res_0x7f090e05"
                                layout_width="-2"
                                layout_height="-2"
                                text="@string/_2130842741_res_0x7f021475"
                                layout_alignParentBottom="true"
                                textAllCaps="true"
                                fontFamily="@string/_2130852833_res_0x7f023be1"
                                layout_toStartOf="@+id/social_activity_more_layout"
                                layout_alignParentStart="true"/>
                            <LinearLayout
                                gravity="0x10"
                                orientation="0"
                                id="@+id/social_activity_more_layout"
                                background="@drawable/_2131428958_res_0x7f0b065e"
                                layout_width="-2"
                                layout_height="-2"
                                layout_alignParentBottom="true"
                                layout_alignParentEnd="true">
                                <com.huawei.ui.commonui.healthtextview.HealthTextView
                                    textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                                    textColor="@color/_2131299850_res_0x7f090e0a"
                                    id="@+id/social_activity_more"
                                    layout_width="-2"
                                    layout_height="-2"
                                    text="@string/_2130844374_res_0x7f021ad6"
                                    textAllCaps="true"
                                    fontFamily="@string/_2130852834_res_0x7f023be2"/>
                                <ImageView
                                    id="@+id/activity_red_dot"
                                    visibility="0"
                                    layout_width="-2"
                                    layout_height="-2"
                                    src="@drawable/_2131431596_res_0x7f0b10ac"
                                    layout_marginStart="@dimen/_2131363888_res_0x7f0a0830"
                                    layout_marginEnd="@dimen/_2131363888_res_0x7f0a0830"/>
                                <ImageView
                                    id="@+id/activity_more_arrow"
                                    layout_width="12dp"
                                    layout_height="24dp"
                                    style="@style/health_default_background_tint"/>
                            </LinearLayout>
                        </RelativeLayout>
                        <RelativeLayout
                            layout_width="-1"
                            layout_height="-2">
                            <com.huawei.ui.commonui.recycleview.HealthRecycleView
                                id="@+id/social_activity_recycle_view"
                                layout_width="-1"
                                layout_height="-2"
                                layout_marginStart="@dimen/_2131364901_res_0x7f0a0c25"
                                layout_marginEnd="@dimen/_2131364900_res_0x7f0a0c24"/>
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </com.huawei.ui.commonui.scrollview.HealthScrollView>
</RelativeLayout>
