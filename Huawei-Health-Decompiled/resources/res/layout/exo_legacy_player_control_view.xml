<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_gravity="0x50"
    orientation="1"
    background="#cc000000"
    layout_width="-1"
    layout_height="-2"
    layoutDirection="0">
    <LinearLayout
        gravity="0x11"
        orientation="0"
        paddingTop="4dp"
        layout_width="-1"
        layout_height="-2">
        <ImageButton
            id="@+id/exo_prev"
            style="@style/ExoMediaButton.Previous"/>
        <ImageButton
            id="@+id/exo_rew"
            style="@style/ExoMediaButton.Rewind"/>
        <ImageButton
            id="@+id/exo_shuffle"
            style="@style/ExoMediaButton"/>
        <ImageButton
            id="@+id/exo_repeat_toggle"
            style="@style/ExoMediaButton"/>
        <ImageButton
            id="@+id/exo_play"
            style="@style/ExoMediaButton.Play"/>
        <ImageButton
            id="@+id/exo_pause"
            style="@style/ExoMediaButton.Pause"/>
        <ImageButton
            id="@+id/exo_ffwd"
            style="@style/ExoMediaButton.FastForward"/>
        <ImageButton
            id="@+id/exo_next"
            style="@style/ExoMediaButton.Next"/>
        <ImageButton
            id="@+id/exo_vr"
            style="@style/ExoMediaButton.VR"/>
    </LinearLayout>
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        layout_height="-2"
        layout_marginTop="4dp">
        <TextView
            textSize="14sp"
            textStyle="0x1"
            textColor="#ffbebebe"
            id="@+id/exo_position"
            paddingLeft="4dp"
            paddingRight="4dp"
            layout_width="-2"
            layout_height="-2"
            includeFontPadding="false"/>
        <View
            id="@+id/exo_progress_placeholder"
            layout_width="0dp"
            layout_height="26dp"
            layout_weight="1"/>
        <TextView
            textSize="14sp"
            textStyle="0x1"
            textColor="#ffbebebe"
            id="@+id/exo_duration"
            paddingLeft="4dp"
            paddingRight="4dp"
            layout_width="-2"
            layout_height="-2"
            includeFontPadding="false"/>
    </LinearLayout>
</LinearLayout>
