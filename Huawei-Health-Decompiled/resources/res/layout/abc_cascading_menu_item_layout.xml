<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.view.menu.ListMenuItemView xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-2"
    minWidth="196dp">
    <ImageView
        id="@+id/group_divider"
        background="@drawable/_2131427425_res_0x7f0b0061"
        layout_width="-1"
        layout_height="1dp"
        layout_marginTop="4dp"
        layout_marginBottom="4dp"/>
    <LinearLayout
        id="@+id/content"
        duplicateParentState="true"
        layout_width="-1"
        layout_height="?attr/_2131100138_res_0x7f0601ea"
        style="@style/RtlOverlay.Widget.AppCompat.PopupMenuItem">
        <TextView
            textAppearance="?attr/_2131101686_res_0x7f0607f6"
            layout_gravity="0x10"
            id="@+id/title"
            duplicateParentState="true"
            layout_width="-2"
            layout_height="-2"
            singleLine="true"
            style="@style/RtlOverlay.Widget.AppCompat.PopupMenuItem.Title"/>
        <Space
            layout_width="0dp"
            layout_height="1dp"
            layout_weight="1"/>
        <TextView
            textAppearance="?attr/_2131101695_res_0x7f0607ff"
            layout_gravity="0x10"
            id="@+id/shortcut"
            duplicateParentState="true"
            layout_width="-2"
            layout_height="-2"
            singleLine="true"
            style="@style/RtlOverlay.Widget.AppCompat.PopupMenuItem.Shortcut"/>
        <ImageView
            layout_gravity="0x11"
            id="@+id/submenuarrow"
            visibility="2"
            layout_width="-2"
            layout_height="-2"
            scaleType="5"
            style="@style/RtlOverlay.Widget.AppCompat.PopupMenuItem.SubmenuArrow"/>
    </LinearLayout>
</androidx.appcompat.view.menu.ListMenuItemView>
