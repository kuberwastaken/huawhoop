<?xml version="1.0" encoding="utf-8"?>
<com.huawei.uikit.phone.hwcardview.widget.HwCardView xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/hwcardview_card"
    layout_width="-1"
    layout_height="-2"
    layout_margin="32dp">
    <LinearLayout
        layout_gravity="0x1"
        orientation="1"
        id="@+id/hwcardview_layout"
        layout_width="-1"
        layout_height="-1">
        <TextView
            id="@+id/hwcardview_text"
            layout_width="-2"
            layout_height="-2"
            layout_marginBottom="9dp"
            text="HwCardView is CardView  with EMUI blur background,  and same predefined pattern content layout. some pattern has textsizing feature.\10Material CardView is A FrameLayout with a rounded corner background and shadow\10\10Note: currently android use various implementation to show card like view : nofitication and mms"
            layout_marginStart="16dp"
            layout_marginEnd="16dp"/>
        <include layout="@layout/hwcardview_header_with_two_button"/>
        <include layout="@layout/hwcardview_footer_three_button"/>
    </LinearLayout>
</com.huawei.uikit.phone.hwcardview.widget.HwCardView>
