            focusable="true"
            clickable="true"
            layout_width="-1"
            layout_height="@dimen/_2131363090_res_0x7f0a0512"
            layout_marginTop="@dimen/_2131363739_res_0x7f0a079b"
            layout_marginBottom="@dimen/_2131363739_res_0x7f0a079b"
            text="@string/_2130849771_res_0x7f022feb"
