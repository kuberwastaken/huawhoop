<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-2"
    layout_height="-2"
    alpha="1">
    <com.huawei.ui.commonui.healthtextview.HealthTextView
        textAppearance="?android:attr/textAppearanceSmall"
        textSize="13dp"
        textColor="@android:color/white"
        ellipsize="3"
        layout_gravity="0x1"
        id="@+id/tvTime"
        layout_width="-2"
        layout_height="-2"
        layout_centerHorizontal="true"
        alpha="1"/>
    <com.huawei.ui.commonui.healthtextview.HealthTextView
        textAppearance="?android:attr/textAppearanceSmall"
        textSize="13dp"
        textColor="@android:color/white"
        ellipsize="3"
        layout_gravity="0x800003"
        id="@+id/tvContent"
        layout_width="-2"
        layout_height="-2"
        layout_centerHorizontal="true"
        lineSpacingMultiplier="1.3"
        alpha="1"/>
</LinearLayout>
