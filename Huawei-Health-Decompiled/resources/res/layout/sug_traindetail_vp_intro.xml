<?xml version="1.0" encoding="utf-8"?>
<com.huawei.ui.commonui.scrollview.HealthScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    scrollbars="0x0"
    layout_width="-1"
    layout_height="-1">
    <LinearLayout
        gravity="0x1"
        orientation="1"
        layout_width="-1"
        layout_height="-1">
        <androidx.constraintlayout.widget.ConstraintLayout
            id="@+id/sug_action_detail_banner"
            layout_width="-1"
            layout_height="-2">
            <TextureView
                id="@+id/sug_coachi_sv_pic"
                layout_width="0dp"
                layout_height="0dp"
                NOT_FOUND_0x1a="w,1:1"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0"/>
            <ImageView
                id="@+id/sug_coachi_iv_pic"
                background="#ffefefef"
                layout_width="0dp"
                layout_height="0dp"
                scaleType="6"
                adjustViewBounds="true"
                NOT_FOUND_0x1a="w,1:1"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0"/>
            <include
                id="@+id/sug_headView"
                layout_width="0dp"
                layout_height="0dp"
                NOT_FOUND_0x1a="w,1:1"
                NOT_FOUND_0x1b="0"
                NOT_FOUND_0x1c="0"
                NOT_FOUND_0x1d="0"
                layout="@layout/sug_video_headview"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.huawei.ui.commonui.columnlayout.HealthColumnLinearLayout
            gravity="0x1"
            orientation="1"
            id="@+id/sug_traindetail_content"
            layout_width="-1"
            layout_height="-2">
            <LinearLayout
                orientation="1"
                id="@+id/sug_coach_ll_first"
                layout_width="-1"
                layout_height="-2"
                layout_marginTop="24dp">
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    textSize="21dp"
                    textColor="@color/_2131299845_res_0x7f090e05"
                    id="@+id/sug_coachi_tv_actiontitle"
                    layout_width="-2"
                    layout_height="-2"
                    fontFamily="@string/_2130852833_res_0x7f023be1"/>
                <RelativeLayout
                    layout_width="-2"
                    layout_height="-2"
                    layout_marginTop="8dp">
                    <com.huawei.ui.commonui.healthtextview.HealthTextView
                        textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                        textColor="@color/_2131299845_res_0x7f090e05"
                        id="@+id/sug_coachi_tv_traindif"
                        layout_width="-2"
                        layout_height="-2"
                        fontFamily="@string/_2130852834_res_0x7f023be2"/>
                    <RatingBar
                        id="@+id/sug_coachi_rtb_diff"
                        visibility="2"
                        layout_width="-2"
                        layout_height="-2"
                        numStars="3"
                        rating="2"
                        stepSize="1"
                        layout_toEndOf="@+id/sug_coachi_tv_traindif"
                        style="?android:attr/ratingBarStyleSmall"/>
                    <com.huawei.ui.commonui.healthtextview.HealthTextView
                        textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                        textColor="@color/_2131299845_res_0x7f090e05"
                        id="@+id/sug_coachi_tv_trainpoint"
                        layout_width="-2"
                        layout_height="-2"
                        maxLines="1"
                        fontFamily="@string/_2130852834_res_0x7f023be2"
                        layout_marginStart="14dp"
                        layout_marginEnd="14dp"
                        layout_toEndOf="@+id/sug_coachi_rtb_diff"/>
                    <com.huawei.ui.commonui.healthtextview.HealthTextView
                        textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                        textColor="@color/_2131299845_res_0x7f090e05"
                        id="@+id/sug_coachi_tv_equipment"
                        layout_width="-2"
                        layout_height="-2"
                        text="@string/_2130849859_res_0x7f023043"
                        maxLines="1"
                        fontFamily="@string/_2130852834_res_0x7f023be2"
                        layout_toEndOf="@+id/sug_coachi_tv_trainpoint"/>
                </RelativeLayout>
            </LinearLayout>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                textColor="@color/_2131299845_res_0x7f090e05"
                id="@+id/sug_tv_trainpoint"
                layout_width="-1"
                layout_height="-2"
                layout_marginTop="24dp"
                maxLines="1"
                minLines="1"
                fontFamily="@string/_2130852834_res_0x7f023be2"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                textColor="@color/_2131299845_res_0x7f090e05"
                id="@+id/sug_coachi_tv_des"
                layout_width="-2"
                layout_height="-2"
                layout_marginTop="8dp"
                lineSpacingExtra="4dp"
                fontFamily="@string/_2130852834_res_0x7f023be2"/>
        </com.huawei.ui.commonui.columnlayout.HealthColumnLinearLayout>
        <LinearLayout
            gravity="0x800015"
            orientation="0"
            layout_width="-1"
            layout_height="24dp"
            layout_marginTop="45dp"
            layout_marginEnd="@dimen/_2131364900_res_0x7f0a0c24">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365484_res_0x7f0a0e6c"
                textColor="@color/_2131299850_res_0x7f090e0a"
                id="@+id/sug_coach_intro_orign_new_textview"
                layout_width="-2"
                layout_height="-2"
                text="@string/_2130849584_res_0x7f022f30"
                fontFamily="@string/_2130852834_res_0x7f023be2"/>
            <ImageView
                layout_gravity="0x10"
                id="@+id/sug_iv_coach_intro_orign"
                layout_width="64dp"
                layout_height="24dp"
                src="@drawable/_2131432103_res_0x7f0b12a7"
                scaleType="1"/>
        </LinearLayout>
    </LinearLayout>
</com.huawei.ui.commonui.scrollview.HealthScrollView>
