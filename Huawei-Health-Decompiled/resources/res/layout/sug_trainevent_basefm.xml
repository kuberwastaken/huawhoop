<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-1">
    <include layout="@layout/sug_fitness_have_norecord"/>
    <LinearLayout
        orientation="1"
        id="@+id/sug_content"
        background="@color/_2131296667_res_0x7f09019b"
        layout_width="-1"
        layout_height="-1">
        <FrameLayout
            id="@+id/sug_trainevent_time"
            visibility="2"
            layout_width="-1"
            layout_height="-2"
            layout_marginStart="@dimen/_2131364900_res_0x7f0a0c24"
            layout_marginEnd="@dimen/_2131364901_res_0x7f0a0c25">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                textColor="@color/_2131299850_res_0x7f090e0a"
                gravity="0x11"
                id="@+id/sug_tv_tevent_stime"
                layout_width="-1"
                layout_height="40dp"
                fontFamily="@string/_2130852834_res_0x7f023be2"/>
            <ImageView
                layout_gravity="0x800013"
                id="@+id/sug_event_last"
                background="@drawable/_2131427876_res_0x7f0b0224"
                layout_width="-2"
                layout_height="-2"
                style="@style/health_default_background_tint"/>
            <ImageView
                layout_gravity="0x800015"
                id="@+id/sug_event_next"
                background="@drawable/_2131427877_res_0x7f0b0225"
                layout_width="-2"
                layout_height="-2"
                style="@style/health_default_background_tint"/>
        </FrameLayout>
        <FrameLayout
            layout_width="-2"
            layout_height="-2">
            <com.huawei.ui.commonui.recycleview.HealthRecycleView
                id="@+id/sug_train_rcv_events"
                layout_width="-1"
                layout_height="-1"/>
            <ImageView
                id="@+id/sug_iv_ani"
                layout_width="-1"
                layout_height="-1"/>
        </FrameLayout>
    </LinearLayout>
    <include
        id="@+id/sug_loading_layout"
        layout="@layout/sug_loading_layout"/>
</FrameLayout>
