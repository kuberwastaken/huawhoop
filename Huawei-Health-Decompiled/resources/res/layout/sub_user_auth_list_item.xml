<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        layout_height="-1">
        <ImageView
            id="@+id/image_head"
            layout_width="40dp"
            layout_height="40dp"
            layout_marginTop="16dp"
            layout_marginBottom="16dp"
            layout_marginEnd="16dp"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365482_res_0x7f0a0e6a"
            textColor="@color/_2131299845_res_0x7f090e05"
            id="@+id/text_message"
            layout_width="0dp"
            layout_height="-2"
            layout_weight="1"
            layout_centerVertical="true"
            layout_toEndOf="@+id/image_head"/>
        <com.huawei.ui.commonui.button.HealthButton
            id="@+id/btn_agree"
            visibility="2"
            layout_width="72dp"
            layout_height="28dp"
            text="@string/IDS_hw_device_wifi_subuser_request_authorize_agree"
            layout_marginStart="8dp"
            style="@style/Health.CommonUI.HealthButton.Emphasize"/>
        <com.huawei.ui.commonui.button.HealthButton
            id="@+id/btn_reject"
            visibility="2"
            layout_width="72dp"
            layout_height="28dp"
            text="@string/IDS_hw_device_wifi_subuser_request_authorize_reject"
            layout_marginStart="8dp"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365483_res_0x7f0a0e6b"
            textColor="@color/_2131299850_res_0x7f090e0a"
            id="@+id/text_status"
            visibility="2"
            layout_width="-2"
            layout_height="-2"
            layout_marginStart="16dp"/>
    </LinearLayout>
    <com.huawei.ui.commonui.divider.HealthDivider
        id="@+id/item_divide_line_view"
        layout_width="-1"
        layout_height="-2"
        layout_marginStart="56dp"/>
</LinearLayout>
