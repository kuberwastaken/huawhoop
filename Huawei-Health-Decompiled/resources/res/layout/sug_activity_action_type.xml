<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:setting="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    layout_height="-1">
    <FrameLayout
        layout_width="-1"
        layout_height="-2">
        <com.huawei.ui.commonui.titlebar.CustomTitleBar
            id="@+id/sug_fitness_title"
            layout_width="-1"
            layout_height="-2"
            NOT_FOUND_0x8="3"
            NOT_FOUND_0x9="@drawable/_2131431795_res_0x7f0b1173"
            NOT_FOUND_0xa="@string/_2130847656_res_0x7f0227a8"/>
        <fragment
            name="com.huawei.health.suggestion.ui.fragment.FitnessSearchFragmentBar"
            id="@+id/fragment_FitSearchFragmentBar"
            layout_width="-1"
            layout_height="-1"/>
    </FrameLayout>
    <FrameLayout
        layout_width="-1"
        layout_height="-1">
        <com.huawei.health.suggestion.ui.view.PullRecyclerViewGroup
            id="@+id/normal_content_layout"
            layout_width="-1"
            layout_height="-1"
            layout_marginStart="@dimen/_2131362372_res_0x7f0a0244"
            layout_marginEnd="@dimen/_2131362371_res_0x7f0a0243">
            <com.huawei.ui.commonui.recycleview.HealthRecycleView
                id="@+id/recyclerview_action_type"
                layout_width="-1"
                layout_height="-1"/>
        </com.huawei.health.suggestion.ui.view.PullRecyclerViewGroup>
        <include
            id="@+id/sug_action_no_data_set_network"
            layout="@layout/sug_action_type_no_network"/>
        <FrameLayout
            id="@+id/search_content_layout"
            visibility="1"
            layout_width="-1"
            layout_height="-1">
            <fragment
                name="com.huawei.health.suggestion.ui.fragment.FitnessActionSearchFragmentRecycleView"
                id="@+id/fragment_FitnessActionSearchFragmentFlowLayout"
                layout_width="-1"
                layout_height="-1"/>
            <fragment
                name="com.huawei.health.suggestion.ui.fragment.FitSearchFragmentFlowLayout"
                id="@+id/fragment_FitSearchFragmentFlowLayout"
                layout_width="-1"
                layout_height="-1"/>
            <include
                visibility="2"
                layout="@layout/sug_search_no_show"/>
        </FrameLayout>
    </FrameLayout>
</LinearLayout>
