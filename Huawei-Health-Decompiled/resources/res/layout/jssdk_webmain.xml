<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-1">
    <FrameLayout
        orientation="1"
        id="@+id/webviewlay"
        visibility="1"
        layout_width="-1"
        layout_height="-1">
        <WebView
            id="@+id/webView"
            layout_width="-1"
            layout_height="-1"/>
        <ProgressBar
            id="@+id/progressbar_hor"
            layout_width="-1"
            layout_height="-2"
            layout_marginTop="-3dp"
            style="?android:attr/progressBarStyleHorizontal"/>
    </FrameLayout>
    <include
        layout_width="-1"
        layout_height="-1"
        layout="@layout/jssdk_loading_progressbar"/>
    <include
        visibility="2"
        layout_width="-1"
        layout_height="-1"
        layout="@layout/jssdk_nonet_fail_common"/>
</LinearLayout>
