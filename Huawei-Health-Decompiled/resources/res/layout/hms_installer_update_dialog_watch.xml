<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    background="#000000"
    paddingTop="10dp"
    layout_width="-1"
    layout_height="-1"
    paddingStart="26dp"
    paddingEnd="26dp">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        layout_height="-2">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            layout_height="-2"
            layout_marginLeft="24dp"
            layout_marginRight="24dp">
            <TextView
                textSize="19sp"
                textStyle="0x1"
                textColor="#dbffffff"
                gravity="0x11"
                layout_gravity="0x11"
                id="@+id/title"
                visibility="2"
                layout_width="-2"
                layout_height="-1"/>
        </LinearLayout>
        <TextView
            textSize="18sp"
            textColor="#dbffffff"
            gravity="0x11"
            layout_gravity="0x11"
            id="@+id/message"
            layout_width="-1"
            layout_height="-2"
            layout_marginTop="16dp"/>
        <LinearLayout
            orientation="1"
            id="@+id/update_dialog_button"
            layout_width="-1"
            layout_height="-2">
            <Button
                textSize="19sp"
                ellipsize="3"
                layout_gravity="0x11"
                id="@+id/install"
                layout_width="-1"
                layout_height="-2"
                layout_marginTop="16dp"
                minHeight="40dp"
                singleLine="true"
                textAllCaps="false"/>
            <Button
                textSize="19sp"
                ellipsize="3"
                layout_gravity="0x11"
                id="@+id/cancel"
                layout_width="-1"
                layout_height="-2"
                layout_marginTop="12dp"
                layout_marginBottom="12dp"
                minHeight="40dp"
                singleLine="true"
                textAllCaps="false"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
