<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="0"
    id="@+id/topPanel"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        gravity="0x800013"
        orientation="0"
        id="@+id/title_template"
        paddingLeft="@dimen/hw_cloud_dialog_title_left_padding"
        paddingRight="@dimen/hw_cloud_dialog_title_right_padding"
        layout_width="-2"
        layout_height="-2">
        <ImageView
            id="@android:id/icon"
            layout_width="32dp"
            layout_height="32dp"
            layout_marginRight="8dp"
            src="@null"
            scaleType="3"
            layout_marginEnd="8dp"/>
        <LinearLayout
            orientation="1"
            layout_width="-1"
            layout_height="-2"
            layout_marginTop="16dp"
            layout_marginBottom="16dp">
            <TextView
                textSize="20sp"
                textStyle="0x1"
                ellipsize="3"
                layout_gravity="0x800003"
                id="@+id/alertTitle"
                layout_width="-1"
                layout_height="-2"
                textAlignment="5"
                style="@style/HwCloudAlertDialogTitle"/>
            <TextView
                id="@+id/subTitle"
                visibility="2"
                layout_width="-1"
                layout_height="-2"
                style="@style/HwCloudAlertDialogSubTitle"/>
        </LinearLayout>
    </LinearLayout>
    <android.widget.Space
        id="@+id/titleDividerNoCustom"
        visibility="2"
        layout_width="-1"
        layout_height="@dimen/hw_cloud_dialog_button_vertical_divider_bottom_height"/>
</LinearLayout>
