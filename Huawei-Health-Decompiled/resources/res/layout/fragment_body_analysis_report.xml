                textColor="@color/_2131299845_res_0x7f090e05"
                id="@+id/hw_show_health_weight_mid_weight_score"
                layout_width="-2"
                layout_height="-2"
                text="@string/_2130838135_res_0x7f020277"
                fontFamily="@string/_2130852833_res_0x7f023be1"/>
            <LinearLayout
                orientation="0"
                layout_width="-2"
                layout_height="-2">
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    textSize="28dp"
                    textColor="@color/_2131299845_res_0x7f090e05"
                    layout_gravity="0x50"
                    id="@+id/body_show_weight_score"
                    layout_width="-2"
                    layout_height="-2"
                    fontFamily="@string/_2130852833_res_0x7f023be1"/>
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    textSize="8dp"
                    textColor="@color/_2131299845_res_0x7f090e05"
                    layout_gravity="0x50"
                    id="@+id/hw_show_health_data_weight_mid_score_unit"
                    layout_width="-2"
                    layout_height="-2"
                    text="@string/_2130850208_res_0x7f0231a0"
                    fontFamily="@string/_2130852833_res_0x7f023be1"
                    layout_marginStart="@dimen/_2131363820_res_0x7f0a07ec"/>
            </LinearLayout>
        </LinearLayout>
        <View
            layout_gravity="0x10"
            background="@color/_2131298221_res_0x7f0907ad"
            layout_width="0.5dp"
            layout_height="32dp"
            layout_marginStart="26dp"
            layout_marginEnd="26dp"/>
        <LinearLayout
            orientation="1"
            layout_width="-2"
            layout_height="-2">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365487_res_0x7f0a0e6f"
                textColor="@color/_2131299845_res_0x7f090e05"
                layout_width="-2"
                layout_height="-2"
                layout_marginBottom="5dp"
                text="@string/_2130838013_res_0x7f0201fd"
                fontFamily="@string/_2130852833_res_0x7f023be1"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="8dp"
                textColor="@color/_2131299850_res_0x7f090e0a"
                layout_gravity="0x10"
                id="@+id/body_show_fit_score_analysis"
                layout_width="-2"
                layout_height="-2"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        layout_width="-1"
        layout_height="0dp"
        layout_weight="1"/>
    <LinearLayout
        gravity="0x11"
        layout_gravity="0x11"
        orientation="0"
        id="@+id/title"
        layout_width="-1"
        layout_height="-2"
        layout_marginBottom="15dp">
        <ImageView
            layout_width="32dp"
            layout_height="27dp"
            src="@drawable/_2131431375_res_0x7f0b0fcf"
            scaleType="1"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="8dp"
            textColor="@color/_2131299853_res_0x7f090e0d"
            layout_width="-2"
            layout_height="-2"
            text="@string/_2130838112_res_0x7f020260"
            fontFamily="@string/_2130852833_res_0x7f023be1"
            layout_marginStart="6dp"/>
    </LinearLayout>
