        id="@+id/report_item_recycle_view"
        layout_width="-1"
        layout_height="-2"
        layout_marginStart="16dp"
        layout_marginEnd="16dp"/>
    <LinearLayout
        orientation="0"
        id="@+id/report_body_show_weight_score_layout"
        layout_width="-1"
        layout_height="-2"
        layout_marginTop="8dp"
        layout_marginStart="32dp"
        layout_marginEnd="28dp">
        <LinearLayout
            orientation="1"
            layout_width="-2"
            layout_height="-2">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
