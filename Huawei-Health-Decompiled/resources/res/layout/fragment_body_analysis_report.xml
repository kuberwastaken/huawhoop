<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    id="@+id/weight_share_fragment"
    background="@color/_2131296667_res_0x7f09019b"
    layout_width="@dimen/_2131365213_res_0x7f0a0d5d"
    layout_height="-2"
    layout_centerHorizontal="true">
    <include
        id="@+id/report_head"
        layout_width="-1"
        layout_height="-2"
        layout_marginStart="32dp"
        layout_marginEnd="28dp"
        layout="@layout/fragment_body_analysis_report_head"/>
