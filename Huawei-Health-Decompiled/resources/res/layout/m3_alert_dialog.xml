<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.AlertDialogLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    gravity="0x800033"
    orientation="1"
    id="@+id/parentPanel"
    layout_width="-1"
    layout_height="-2">
    <include layout="@layout/m3_alert_dialog_title"/>
    <FrameLayout
        id="@+id/contentPanel"
        layout_width="-1"
        layout_height="-2"
        minHeight="48dp">
        <ImageView
            layout_gravity="0x30"
            id="@+id/scrollIndicatorUp"
            background="#1f000000"
            visibility="2"
            layout_width="-1"
            layout_height="1dp"
            contentDescription="@null"
            NOT_FOUND_0xd="?android:attr/colorForeground"/>
        <androidx.core.widget.NestedScrollView
            id="@+id/scrollView"
            clipToPadding="false"
            layout_width="-1"
            layout_height="-2">
            <LinearLayout
                orientation="1"
                layout_width="-1"
                layout_height="-2">
                <android.widget.Space
                    id="@+id/textSpacerNoTitle"
                    visibility="2"
                    layout_width="-1"
                    layout_height="@dimen/_2131361902_res_0x7f0a006e"/>
                <TextView
                    id="@android:id/message"
                    paddingLeft="?attr/_2131100102_res_0x7f0601c6"
                    paddingRight="?attr/_2131100102_res_0x7f0601c6"
                    layout_width="-1"
                    layout_height="-2"
                    style="?attr/_2131101137_res_0x7f0605d1"/>
                <android.widget.Space
                    id="@+id/textSpacerNoButtons"
                    visibility="2"
                    layout_width="-1"
                    layout_height="@dimen/_2131361902_res_0x7f0a006e"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
        <ImageView
            layout_gravity="0x50"
            id="@+id/scrollIndicatorDown"
            background="#1f000000"
            visibility="2"
            layout_width="-1"
            layout_height="1dp"
            contentDescription="@null"
            NOT_FOUND_0xd="?android:attr/colorForeground"/>
    </FrameLayout>
    <FrameLayout
        id="@+id/customPanel"
        layout_width="-1"
        layout_height="-2"
        minHeight="48dp">
        <FrameLayout
            id="@+id/custom"
            layout_width="-1"
            layout_height="-2"/>
    </FrameLayout>
    <include
        layout_width="-1"
        layout_height="-2"
        layout="@layout/m3_alert_dialog_actions"/>
</androidx.appcompat.widget.AlertDialogLayout>
