<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    background="@drawable/_2131427891_res_0x7f0b0233"
    layout_width="-1"
    layout_height="-2">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        layout_width="-1"
        layout_height="-2"
        minHeight="48dp"
        layout_marginStart="@dimen/_2131364901_res_0x7f0a0c25"
        layout_marginEnd="@dimen/_2131364900_res_0x7f0a0c24">
        <ImageView
            layout_gravity="0x11"
            id="@+id/item_weight_current_user_photo"
            layout_width="@dimen/_2131363802_res_0x7f0a07da"
            layout_height="@dimen/_2131363802_res_0x7f0a07da"
            src="@drawable/_2131430307_res_0x7f0b0ba3"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            ellipsize="3"
            gravity="0x10"
            id="@+id/item_right_title_text"
            layout_width="0dp"
            layout_height="50dp"
            layout_weight="1"
            textDirection="5"
            textAlignment="5"
            layoutDirection="3"
            layout_marginStart="16dp"
            layout_marginEnd="16dp"
            style="@style/list_text_title_primary"/>
        <ImageView
            layout_gravity="0x11"
            id="@+id/hw_health_weight_user_manager_arrow"
            layout_width="12dp"
            layout_height="24dp"
            src="@drawable/_2131427877_res_0x7f0b0225"
            style="@style/health_default_img_tint"/>
    </LinearLayout>
    <com.huawei.ui.commonui.divider.HealthDivider
        id="@+id/user_manager_line"
        layout_width="-1"
        layout_height="-2"
        layout_marginStart="@dimen/_2131364901_res_0x7f0a0c25"
        layout_marginEnd="@dimen/_2131364900_res_0x7f0a0c24"/>
</LinearLayout>
