<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    layout_width="-1"
    layout_height="-2"
    minHeight="96dp"
    textDirection="5"
    layoutDirection="3">
    <RelativeLayout
        id="@+id/item_device"
        layout_width="-1"
        layout_height="-2"
        textDirection="5"
        layoutDirection="3">
        <RelativeLayout
            id="@+id/select_device_icon_layout"
            layout_width="80dp"
            layout_height="80dp"
            layout_centerVertical="true"
            layoutDirection="3"
            layout_alignParentStart="true">
            <ImageView
                id="@+id/select_device_icon"
                layout_width="80dp"
                layout_height="80dp"
                layout_centerInParent="true"/>
        </RelativeLayout>
        <RelativeLayout
            layout_gravity="0x10"
            id="@+id/more_about_band_info"
            layout_width="-2"
            layout_height="-2"
            layout_centerVertical="true"
            textDirection="5"
            layoutDirection="3"
            layout_marginStart="4dp"
            layout_toEndOf="@+id/select_device_icon_layout">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365482_res_0x7f0a0e6a"
                textColor="@color/_2131299845_res_0x7f090e05"
                id="@+id/select_device_content"
                layout_width="-2"
                layout_height="-2"
                singleLine="false"
                fontFamily="@string/_2130852833_res_0x7f023be1"
                textDirection="5"
                breakStrategy="1"
                hyphenationFrequency="1"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                textColor="@color/_2131299850_res_0x7f090e0a"
                gravity="0x800003"
                id="@+id/select_device_summary"
                layout_width="-2"
                layout_height="-2"
                layout_marginTop="2dp"
                layout_below="@+id/select_device_content"
                textDirection="5"
                breakStrategy="1"
                hyphenationFrequency="1"/>
        </RelativeLayout>
        <View
            id="@+id/select_device_summary_line"
            background="@color/_2131299721_res_0x7f090d89"
            layout_width="-1"
            layout_height="0.5dp"
            layout_alignParentBottom="true"
            layout_marginStart="88dp"/>
    </RelativeLayout>
    <View
        id="@+id/band_margin"
        visibility="2"
        layout_width="-1"
        layout_height="@dimen/_2131362578_res_0x7f0a0312"
        layout_below="@+id/item_device"/>
</RelativeLayout>
