<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:setting="http://schemas.android.com/apk/res-auto"
    orientation="1"
    layout_width="-1"
    layout_height="-2"
    importantForAccessibility="2">
    <com.huawei.ui.commonui.divider.HealthDivider
        id="@+id/weight_father_divider"
        layout_width="-1"
        layout_height="-2"
        importantForAccessibility="2"
        NOT_FOUND_0xf="1"/>
    <LinearLayout
        gravity="0x50"
        orientation="0"
        id="@+id/health_data_weight_father_ll"
        background="@drawable/_2131427891_res_0x7f0b0233"
        layout_width="-1"
        layout_height="48dp"
        importantForAccessibility="1"
        paddingStart="@dimen/_2131364901_res_0x7f0a0c25"
        paddingEnd="@dimen/_2131364900_res_0x7f0a0c24">
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            layout_gravity="0x10"
            id="@+id/hw_show_health_data_weight_history_listview_father_textview1"
            layout_width="0dp"
            layout_height="-2"
            layout_weight="1"
            importantForAccessibility="2"
            fontFamily="@string/_2130852833_res_0x7f023be1"
            style="@style/health_subheader_grid_title_primary"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            gravity="0x10"
            layout_gravity="0x10"
            id="@+id/hw_show_health_data_weight_history_listview_father_avg_textview"
            layout_width="-2"
            layout_height="-2"
            text="@string/_2130837598_res_0x7f02005e"
            importantForAccessibility="2"
            fontFamily="@string/_2130852833_res_0x7f023be1"
            style="@style/list_text_title_right"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            gravity="0x10"
            layout_gravity="0x10"
            id="@+id/hw_show_health_data_weight_history_listview_father_textview2"
            layout_width="-2"
            layout_height="-2"
            importantForAccessibility="2"
            fontFamily="@string/_2130852833_res_0x7f023be1"
            style="@style/list_text_title_right"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            gravity="0x10"
            layout_gravity="0x10"
            id="@+id/health_data_weight_history_list_view_father_textview2_unit"
            layout_width="-2"
            layout_height="-2"
            importantForAccessibility="2"
            fontFamily="@string/_2130852833_res_0x7f023be1"
            layout_marginEnd="@dimen/_2131363820_res_0x7f0a07ec"
            style="@style/list_text_title_right"/>
        <ImageView
            layout_gravity="0x10"
            id="@+id/father_img_arrow"
            layout_width="-2"
            layout_height="-1"
            src="@drawable/ic_health_list_drop_down_arrow_nor"
            importantForAccessibility="2"
            style="@style/health_default_img_tint"/>
    </LinearLayout>
</LinearLayout>
