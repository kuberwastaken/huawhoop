<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/custom_target_input_layout"
    focusable="true"
    focusableInTouchMode="true"
    layout_width="-1"
    layout_height="-2">
    <com.huawei.ui.commonui.edittext.HealthEditText
        gravity="0x800013"
        id="@+id/custom_target_editText"
        background="@android:color/transparent"
        layout_width="-1"
        layout_height="-2"
        singleLine="true"
        layout_centerVertical="true"
        style="@style/Widget.Emui.HwEditText.Linear"/>
    <com.huawei.ui.commonui.healthtextview.HealthTextView
        textSize="@dimen/_2131362383_res_0x7f0a024f"
        textColor="@color/_2131299845_res_0x7f090e05"
        id="@+id/custom_target_unit"
        visibility="2"
        layout_width="-2"
        layout_height="-2"
        layout_centerVertical="true"
        layout_alignParentEnd="true"/>
    <ImageView
        id="@+id/custom_target_under_line"
        background="@color/_2131298836_res_0x7f090a14"
        layout_width="-1"
        layout_height="2px"
        layout_below="@+id/custom_target_editText"/>
</RelativeLayout>
