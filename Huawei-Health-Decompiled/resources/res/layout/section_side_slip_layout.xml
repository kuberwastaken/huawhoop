<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/layout_section_side_slip"
    layout_width="-1"
    layout_height="-1">
    <com.huawei.ui.commonui.subheader.HealthSubHeader
        id="@+id/section_side_slip_sub_header"
        layout_width="-1"
        layout_height="-2"
        NOT_FOUND_0x6="false"
        NOT_FOUND_0x7="3"/>
    <RelativeLayout
        id="@+id/section_side_slip_recycler_view_out"
        descendantFocusability="2"
        layout_width="-2"
        layout_height="-2">
        <com.huawei.ui.commonui.recycleview.HealthRecycleView
            id="@+id/section_side_slip_recycler_view"
            layout_width="-1"
            layout_height="-2"
            NOT_FOUND_0x5="false"/>
    </RelativeLayout>
</LinearLayout>
