<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/sug_ll_plan"
    background="@color/_2131296667_res_0x7f09019b"
    layout_width="-1"
    layout_height="-1">
    <com.huawei.ui.commonui.titlebar.CustomTitleBar
        id="@+id/sug_fitness_title"
        layout_width="-1"
        layout_height="-2"
        NOT_FOUND_0x1c="2"
        NOT_FOUND_0x1e="@string/_2130842098_res_0x7f0211f2"/>
    <com.huawei.ui.commonui.scrollview.HealthScrollView
        id="@+id/sug_all_type_plan"
        scrollbars="0x0"
        fadingEdge="0x2000"
        layout_width="-1"
        layout_height="-2"
        fillViewport="true"
        layout_below="@+id/sug_fitness_title"
        fadeScrollbars="false"
        hardwareAccelerated="true"
        NOT_FOUND_0x1d="true">
        <LinearLayout
            orientation="1"
            id="@+id/plans_layout"
            layout_width="-1"
            layout_height="-1"
            animateLayoutChanges="true"/>
    </com.huawei.ui.commonui.scrollview.HealthScrollView>
    <RelativeLayout
        orientation="1"
        id="@+id/network_disable_layout"
        background="@color/_2131296667_res_0x7f09019b"
        visibility="2"
        layout_width="-1"
        layout_height="-1"
        layout_below="@+id/sug_fitness_title">
        <RelativeLayout
            id="@+id/reload_layout"
            layout_width="-2"
            layout_height="-2">
            <ImageView
                id="@+id/img_no_net_work"
                layout_width="-2"
                layout_height="-2"
                layout_marginTop="200dp"
                src="@drawable/_2131430497_res_0x7f0b0c61"
                layout_centerHorizontal="true"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                textColor="@color/_2131299845_res_0x7f090e05"
                gravity="0x11"
                id="@+id/tips_no_net_work"
                layout_width="-1"
                layout_height="-2"
                text="@string/_2130851503_res_0x7f0236af"
                layout_below="@+id/img_no_net_work"
                fontFamily="@string/_2130852834_res_0x7f023be2"
                layout_marginStart="16dp"
                layout_marginEnd="16dp"/>
        </RelativeLayout>
        <LinearLayout
            gravity="0x11"
            layout_width="-1"
            layout_height="-2"
            layout_marginBottom="@dimen/_2131361819_res_0x7f0a001b"
            weightSum="1"
            layout_alignParentBottom="true">
            <com.huawei.ui.commonui.button.HealthButton
                gravity="0x11"
                layout_gravity="0x11"
                id="@+id/btn_set_network"
                layout_width="0dp"
                text="@string/_2130842408_res_0x7f021328"
                layout_weight="0.5"
                style="@style/health_button_style"/>
        </LinearLayout>
    </RelativeLayout>
    <include
        id="@+id/sug_loading"
        layout_width="-1"
        layout_height="-1"
        layout_below="@+id/sug_fitness_title"
        layout="@layout/sug_loading_layout"/>
</RelativeLayout>
