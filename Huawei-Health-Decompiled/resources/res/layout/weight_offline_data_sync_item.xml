<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    gravity="0x10"
    layout_gravity="0x10"
    orientation="0"
    layout_width="-1"
    layout_height="64dp">
    <LinearLayout
        gravity="0x10"
        orientation="0"
        id="@+id/weight_conflict_list_item"
        layout_width="-1"
        layout_height="-2"
        layout_marginTop="8dp"
        layout_marginBottom="8dp">
        <LinearLayout
            orientation="1"
            layout_width="-2"
            layout_height="-2"
            layout_weight="1">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365482_res_0x7f0a0e6a"
                textColor="@color/_2131299845_res_0x7f090e05"
                id="@+id/weight_offline_data_item_weight_value"
                layout_width="-2"
                layout_height="-2"
                fontFamily="@string/_2130852834_res_0x7f023be2"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="@dimen/_2131365483_res_0x7f0a0e6b"
                textColor="@color/_2131299850_res_0x7f090e0a"
                id="@+id/weight_offline_data_item_measure_time"
                layout_width="-2"
                layout_height="-2"
                layout_marginTop="2dp"
                fontFamily="@string/_2130852834_res_0x7f023be2"/>
        </LinearLayout>
        <com.huawei.ui.commonui.checkbox.HealthCheckBox
            layout_gravity="0x10"
            id="@+id/weight_offline_data_list_checkbox"
            layout_width="-2"
            layout_height="-2"
            checked="false"
            style="@style/health_checkbox_style"/>
    </LinearLayout>
    <com.huawei.ui.commonui.divider.HealthDivider
        id="@+id/weight_conflict_list_divider"
        layout_width="-1"
        layout_height="-2"
        layout_below="@+id/weight_conflict_list_item"/>
</RelativeLayout>
