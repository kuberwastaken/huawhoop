<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    id="@+id/ll_third_part_item"
    style="@style/third_service_item_layout_style">
    <ImageView
        id="@+id/iv_app_icon"
        layout_marginStart="@dimen/_2131362013_res_0x7f0a00dd"
        style="@style/discovery_service_imageview_style"/>
    <RelativeLayout
        layout_width="-1"
        layout_height="-1"
        layout_marginStart="@dimen/_2131365521_res_0x7f0a0e91">
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            ellipsize="3"
            id="@+id/htv_app_name"
            layout_width="-2"
            layout_height="-2"
            text="@string/_2130842087_res_0x7f0211e7"
            layout_centerVertical="true"
            layout_toStartOf="@+id/myfitnesspal_arrow_gray"
            layout_alignParentStart="true"
            style="@style/third_service_title_textview_style"/>
        <com.huawei.ui.commonui.divider.HealthDivider
            id="@+id/third_part_app_divider"
            layout_width="-1"
            layout_height="-2"
            layout_alignParentBottom="true"
            layout_marginEnd="@dimen/_2131362011_res_0x7f0a00db"/>
        <ImageView
            id="@+id/myfitnesspal_arrow_gray"
            layout_width="-2"
            layout_height="-2"
            layout_marginEnd="@dimen/_2131362011_res_0x7f0a00db"
            style="@style/third_service_right_imageview_style"/>
    </RelativeLayout>
</LinearLayout>
