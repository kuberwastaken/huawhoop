<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    orientation="1"
    id="@+id/ie_layout_map_tracking"
    background="#000000"
    fitsSystemWindows="true"
    layout_width="-1"
    layout_height="-1"
    keepScreenOn="true">
    <LinearLayout
        orientation="1"
        layout_width="-1"
        layout_height="-2">
        <View
            layout_width="-1"
            layout_height="8dp"/>
        <RelativeLayout
            layout_width="-1"
            layout_height="-2">
            <com.huawei.ui.commonui.columnlayout.HealthColumnLinearLayout
                gravity="0x1"
                id="@+id/music_column_layout"
                layout_width="-1"
                layout_height="-2"
                layout_centerHorizontal="true"
                layout_marginStart="@dimen/_2131364901_res_0x7f0a0c25"
                layout_marginEnd="@dimen/_2131364900_res_0x7f0a0c24">
                <com.huawei.healthcloud.plugintrack.ui.view.MusicControlLayout
                    layout_gravity="0x1"
                    id="@+id/music_content_layout"
                    layout_width="-2"
                    layout_height="48dp"/>
            </com.huawei.ui.commonui.columnlayout.HealthColumnLinearLayout>
            <FrameLayout
                layout_width="-2"
                layout_height="-2"
                layout_marginTop="8dp"
                layout_below="@+id/music_column_layout"
                layout_marginStart="@dimen/_2131362647_res_0x7f0a0357">
                <include layout="@layout/indoor_connect_icons"/>
                <com.huawei.ui.commonui.progressbar.HealthProgressBar
                    id="@+id/hw_recycler_loading_hpb"
                    visibility="2"
                    layout_width="-2"
                    layout_height="-2"
                    NOT_FOUND_0x14="@color/_2131296950_res_0x7f0902b6"
                    style="@style/health_progressbar_style"/>
            </FrameLayout>
            <LinearLayout
                orientation="0"
                layout_width="-2"
                layout_height="-2"
                layout_marginTop="8dp"
                layout_below="@+id/music_column_layout"
                layout_alignParentEnd="true">
                <ImageView
                    id="@+id/ie_miracast_icon"
                    layout_width="@dimen/_2131364629_res_0x7f0a0b15"
                    layout_height="@dimen/_2131364629_res_0x7f0a0b15"
                    src="@drawable/_2131430705_res_0x7f0b0d31"
                    layout_marginEnd="@dimen/_2131364619_res_0x7f0a0b0b"/>
                <ImageView
                    id="@+id/ie_music_icon"
                    layout_width="40dp"
                    layout_height="40dp"
                    src="@drawable/_2131430642_res_0x7f0b0cf2"
                    layout_marginEnd="@dimen/_2131362646_res_0x7f0a0356"/>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
    <com.huawei.ui.commonui.scrollview.HealthScrollView
        scrollbars="0x0"
        layout_width="-1"
        layout_height="-2">
        <LinearLayout
            orientation="1"
            layout_width="-1"
            layout_height="-2">
            <LinearLayout
                orientation="1"
                id="@+id/linearlayout_view_stub"
                layout_width="-1"
                layout_height="-2"
                layout_marginTop="@dimen/_2131363096_res_0x7f0a0518">
                <ViewStub
                    layout_gravity="0x1"
                    id="@+id/view_stub_distance"
                    layout="@layout/view_stub_distance"
                    layout_width="-1"
                    layout_height="-2"/>
                <ViewStub
                    id="@+id/view_stub_duration_course"
                    layout="@layout/view_stub_duration_course"
                    layout_width="-1"
                    layout_height="-2"
                    layout_centerInParent="true"/>
            </LinearLayout>
            <LinearLayout
                orientation="1"
                layout_width="-1"
                layout_height="-2">
                <com.huawei.indoorequip.ui.view.SportEquipItemDrawer
                    id="@+id/first_display_item_drawer"
                    layout_width="-1"
                    layout_height="-2"/>
            </LinearLayout>
        </LinearLayout>
    </com.huawei.ui.commonui.scrollview.HealthScrollView>
</LinearLayout>
