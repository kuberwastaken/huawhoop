<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    orientation="1"
    layout_width="-1"
    layout_height="-1">
    <RelativeLayout
        background="#000000"
        layout_width="-1"
        layout_height="48dp">
        <ImageView
            id="@+id/iv_back"
            layout_width="-2"
            layout_height="-2"
            layout_margin="10dp"
            src="@mipmap/hw_health_edit_share_edit_pic_cancle"
            layout_centerVertical="true"
            layout_alignParentStart="true"/>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365500_res_0x7f0a0e7c"
            textColor="#ffffff"
            layout_width="-2"
            layout_height="-2"
            text="@string/_2130842461_res_0x7f02135d"
            layout_centerInParent="true"/>
        <ImageView
            id="@+id/tv_use"
            padding="10dp"
            layout_width="-2"
            layout_height="-2"
            src="@mipmap/hw_health_edit_share_edit_pic_select"
            layout_centerVertical="true"
            layout_alignParentEnd="true"/>
    </RelativeLayout>
    <View
        background="#262626"
        layout_width="-1"
        layout_height="2dp"/>
    <RelativeLayout
        background="#000000"
        layout_width="-1"
        layout_height="-1">
        <com.huawei.pluginsocialshare.camera.ClipImageLayout
            id="@+id/clipImageLayout"
            layout_width="-1"
            layout_height="-1"/>
    </RelativeLayout>
</LinearLayout>
