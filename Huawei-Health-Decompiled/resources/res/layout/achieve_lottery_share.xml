<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:setting="http://schemas.android.com/apk/res-auto"
    layout_width="-1"
    layout_height="-1">
    <com.huawei.ui.commonui.titlebar.CustomTitleBar
        id="@+id/lottery_title"
        layout_width="-1"
        layout_height="-2"
        NOT_FOUND_0x12="2"
        NOT_FOUND_0x13="@string/_2130840982_res_0x7f020d96"/>
    <RelativeLayout
        id="@+id/share_rlayout"
        background="@color/_2131296371_res_0x7f090073"
        layout_width="-1"
        layout_height="-1"
        layout_below="@+id/lottery_title">
        <RelativeLayout
            id="@+id/lottery_head_layout"
            layout_width="-1"
            layout_height="-2"
            layout_marginTop="16dp"
            layout_marginStart="16dp"
            layout_marginEnd="16dp">
            <ImageView
                id="@+id/lottery_head"
                layout_width="44dp"
                layout_height="44dp"
                src="@mipmap/_2131821171_res_0x7f110273"
                layout_alignParentStart="true"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="15dp"
                textColor="@color/_2131296373_res_0x7f090075"
                id="@+id/lottery_nick"
                layout_width="-1"
                layout_height="-2"
                layout_centerHorizontal="true"
                layout_centerVertical="true"
                layout_marginStart="12dp"
                layout_toEndOf="@+id/lottery_head"/>
        </RelativeLayout>
        <RelativeLayout
            id="@+id/lottery_rlayout"
            background="@drawable/_2131427470_res_0x7f0b008e"
            layout_width="328dp"
            layout_height="300dp"
            layout_marginTop="36dp"
            layout_below="@+id/lottery_head_layout"
            layout_centerHorizontal="true"
            layout_marginStart="16dp"
            layout_marginEnd="16dp">
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="13dp"
                textColor="@color/_2131296384_res_0x7f090080"
                gravity="0x11"
                id="@+id/lottery_text_title"
                layout_width="-1"
                layout_height="-2"
                layout_marginTop="9dp"
                text="@string/_2130840983_res_0x7f020d97"
                singleLine="true"
                layout_centerHorizontal="true"
                layout_marginStart="55dp"
                layout_marginEnd="55dp"/>
            <com.huawei.ui.commonui.healthtextview.HealthTextView
                textSize="30dp"
                textColor="@color/_2131296384_res_0x7f090080"
                gravity="0x11"
                id="@+id/lottery_text_prize_name"
                layout_width="-1"
                layout_height="-2"
                layout_marginTop="6dp"
                singleLine="true"
                layout_below="@+id/lottery_text_title"
                layout_marginStart="75dp"
                layout_marginEnd="75dp"/>
            <ImageView
                id="@+id/lottery_img_prize"
                layout_width="-2"
                layout_height="120dp"
                layout_marginTop="@dimen/_2131364680_res_0x7f0a0b48"
                layout_below="@+id/lottery_text_prize_name"
                layout_centerHorizontal="true"
                layout_marginStart="75dp"
                layout_marginEnd="75dp"/>
        </RelativeLayout>
        <com.huawei.ui.commonui.healthtextview.HealthTextView
            textSize="@dimen/_2131365502_res_0x7f0a0e7e"
            textColor="@color/_2131296383_res_0x7f09007f"
            gravity="0x11"
            id="@+id/lottery_share_content"
            layout_width="-1"
            layout_height="-2"
            layout_marginTop="13dp"
            text="@string/_2130840984_res_0x7f020d98"
            layout_below="@+id/lottery_rlayout"
            layout_centerHorizontal="true"
            layout_marginStart="14dp"
            layout_marginEnd="16dp"/>
    </RelativeLayout>
</RelativeLayout>
