            visibility="1"
            layout_width="30dp"
            layout_height="-2"/>
        <LinearLayout
            orientation="1"
            layout_width="-1"
            layout_height="-1">
            <LinearLayout
                gravity="0x11"
                layout_width="-1"
                layout_height="-2"
                minHeight="@dimen/_2131363884_res_0x7f0a082c">
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    layout_width="0dp"
                    layout_height="-2"
                    text="@string/_2130839934_res_0x7f02097e"
                    layout_weight="2.5"
                    textDirection="5"
                    style="@style/SwimSegmentItemTitleStyle"/>
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    layout_width="0dp"
                    layout_height="-2"
                    text="@string/_2130844417_res_0x7f021b01"
                    layout_weight="2"
                    textDirection="5"
                    style="@style/SwimSegmentItemTitleStyle"/>
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    layout_width="0dp"
                    layout_height="-2"
                    text="@string/_2130844423_res_0x7f021b07"
                    layout_weight="3"
                    textDirection="5"
                    style="@style/SwimSegmentItemTitleStyle"/>
            </LinearLayout>
            <LinearLayout
