                        ellipsize="3"
                        id="@+id/text_swim_pace_unit"
                        layout_width="-2"
                        layout_height="-2"
                        maxLines="1"
                        layout_marginStart="4dp"
                        style="@style/SwimSegmentItemTitleStyle"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
