                id="@+id/text_duration"
                layout_width="0dp"
                layout_height="-1"
                layout_weight="3"
                style="@style/SwimSegmentItemStyle"/>
        </LinearLayout>
    </LinearLayout>
    <com.huawei.ui.commonui.divider.HealthDivider
