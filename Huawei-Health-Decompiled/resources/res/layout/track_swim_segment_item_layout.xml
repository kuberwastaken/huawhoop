                id="@+id/text_stroke_type"
                layout_width="0dp"
                layout_height="-1"
                layout_weight="2.5"
                style="@style/SwimSegmentItemStyle"/>
            <LinearLayout
                gravity="0x800013"
                orientation="0"
                layout_width="0dp"
                layout_height="-1"
                layout_weight="2">
