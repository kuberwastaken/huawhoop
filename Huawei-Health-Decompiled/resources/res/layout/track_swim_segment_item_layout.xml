            textColor="@color/_2131299845_res_0x7f090e05"
            id="@+id/text_segment_index"
            layout_width="30dp"
            layout_height="-2"
            text="1"
            fontFamily="@string/_2130852833_res_0x7f023be1"
            NOT_FOUND_0x12="@dimen/_2131365484_res_0x7f0a0e6c"
            NOT_FOUND_0x13="@dimen/_2131365473_res_0x7f0a0e61"/>
        <LinearLayout
            layout_width="-1"
            layout_height="-2">
