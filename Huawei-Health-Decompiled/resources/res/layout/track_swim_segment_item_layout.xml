                layout_width="-1"
                layout_height="-2">
                <com.huawei.ui.commonui.healthtextview.HealthTextView
                    id="@+id/text_pull_times"
                    layout_width="0dp"
                    layout_height="-2"
                    layout_weight="2.5"
                    style="@style/SwimSegmentItemContentStyle"/>
