<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item drawable="@drawable/_2131429113_res_0x7f0b06f9"/>
    <item gravity="0x11">
        <selector>
            <item
                state_focused="true"
                state_window_focused="true"
                drawable="@drawable/_2131429104_res_0x7f0b06f0"/>
        </selector>
    </item>
    <item>
        <animated-selector>
            <item
                state_enabled="false"
                state_checked="true"
                id="@+id/disable_on"
                drawable="@drawable/_2131429267_res_0x7f0b0793"/>
            <item
                state_enabled="false"
                state_checked="false"
                id="@+id/disable_off"
                drawable="@drawable/_2131429249_res_0x7f0b0781"/>
            <item
                state_checked="true"
                id="@+id/checked"
                drawable="@drawable/_2131429276_res_0x7f0b079c"/>
            <item
                state_checked="false"
                id="@+id/unchecked"
                drawable="@drawable/_2131429258_res_0x7f0b078a"/>
            <transition
                id="@+id/off2on"
                drawable="@drawable/_2131429122_res_0x7f0b0702"
                toId="@+id/checked"
                fromId="@+id/unchecked"/>
            <transition
                id="@+id/on2off"
                drawable="@drawable/_2131429176_res_0x7f0b0738"
                toId="@+id/unchecked"
                fromId="@+id/checked"/>
        </animated-selector>
    </item>
</layer-list>
