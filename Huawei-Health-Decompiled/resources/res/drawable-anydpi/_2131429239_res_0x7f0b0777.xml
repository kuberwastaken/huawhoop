<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item drawable="@drawable/_2131429116_res_0x7f0b06fc"/>
    <item gravity="0x11">
        <selector>
            <item
                state_focused="true"
                state_window_focused="true"
                drawable="@drawable/_2131429107_res_0x7f0b06f3"/>
        </selector>
    </item>
    <item>
        <animated-selector>
            <item
                state_enabled="false"
                state_checked="true"
                id="@+id/disable_checked"
                drawable="@drawable/_2131429270_res_0x7f0b0796"/>
            <item
                state_enabled="false"
                state_checked="false"
                id="@+id/disable_unchecked"
                drawable="@drawable/_2131429252_res_0x7f0b0784"/>
            <item
                state_checked="true"
                id="@+id/checked"
                drawable="@drawable/_2131429279_res_0x7f0b079f"/>
            <item
                state_checked="false"
                id="@+id/unchecked"
                drawable="@drawable/_2131429261_res_0x7f0b078d"/>
            <transition
                id="@+id/off2on"
                drawable="@drawable/_2131429125_res_0x7f0b0705"
                toId="@+id/checked"
                fromId="@+id/unchecked"/>
            <transition
                id="@+id/on2off"
                drawable="@drawable/_2131429179_res_0x7f0b073b"
                toId="@+id/unchecked"
                fromId="@+id/checked"/>
        </animated-selector>
    </item>
</layer-list>
