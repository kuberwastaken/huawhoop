<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item drawable="@drawable/_2131429118_res_0x7f0b06fe"/>
    <item gravity="0x11">
        <selector>
            <item
                state_focused="true"
                state_window_focused="true"
                drawable="@drawable/_2131429109_res_0x7f0b06f5"/>
        </selector>
    </item>
    <item>
        <animated-selector>
            <item
                state_enabled="false"
                state_checked="true"
                id="@+id/disable_checked"
                drawable="@drawable/_2131429272_res_0x7f0b0798"/>
            <item
                state_enabled="false"
                state_checked="false"
                id="@+id/disable_unchecked"
                drawable="@drawable/_2131429254_res_0x7f0b0786"/>
            <item
                state_checked="true"
                id="@+id/checked"
                drawable="@drawable/_2131429281_res_0x7f0b07a1"/>
            <item
                state_checked="false"
                id="@+id/unchecked"
                drawable="@drawable/_2131429263_res_0x7f0b078f"/>
            <transition
                id="@+id/off2on"
                drawable="@drawable/_2131429127_res_0x7f0b0707"
                toId="@+id/checked"
                fromId="@+id/unchecked"/>
            <transition
                id="@+id/on2off"
                drawable="@drawable/_2131429181_res_0x7f0b073d"
                toId="@+id/unchecked"
                fromId="@+id/checked"/>
        </animated-selector>
    </item>
</layer-list>
